@namespace Workshop.Components.Marketing
@using Microsoft.AspNetCore.Components

<article class="mk-feature-row @(Reversed ? "mk-feature-row-reversed" : string.Empty)">
    <div class="mk-feature-row-copy mk-reveal">
        <span class="mk-icon-chip"><IconGlyph Name="@Icon" /></span>
        <h3>@Title</h3>
        <p>@Description</p>
    </div>
    <div class="mk-feature-preview mk-reveal mk-reveal-delay-1">
        <span>Product preview</span>
    </div>
</article>

@code {
    [Parameter] public string Icon { get; set; } = "dot";
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public bool Reversed { get; set; }
}
