@page "/manage-service-categories"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Workshop.Models
@using Workshop.Services
@inject JobCatalogService Catalog
@inject SuggestedCatalogService SuggestedCatalog
@inject Workshop.Data.TenantContext TenantContext
@inject IJSRuntime JS

<div class="sd-shell">
    <header class="sd-header">
        <h3>Service Categories</h3>
        <p>Manage your service category structure for this tenant.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <section class="sd-flash @(IsError ? "error" : "success")">@Message</section>
    }

    <section class="sd-card">
        <div class="sd-toolbar">
            <div class="sd-filter">
                <input class="inline-input filter-input"
                       placeholder="Category filter"
                       @bind="CategoryFilter"
                       @bind:event="oninput" />
            </div>
            <div class="sd-toolbar-actions">
                <span class="sd-count">@FilteredCategory1Rows.Count root categories</span>
                <button type="button" class="sd-btn sd-btn-primary" @onclick="ImportSuggestedCategoriesAsync">Import Suggested Categories</button>
            </div>
        </div>

        @if (FilteredCategory1Rows.Count == 0)
        {
            <div class="sd-empty">No categories match the current filter.</div>
        }
        else
        {
            <div class="root-list">
                @for (var i = 0; i < FilteredCategory1Rows.Count; i++)
                {
                    var root = FilteredCategory1Rows[i];
                    var subRows = SubRows(root);

                    <article class="category-card">
                        <div class="category-head">
                            <span class="drag-handle" aria-hidden="true">&#9776;</span>

                            <label class="category-dot-picker" title="Edit category color">
                                <input type="color"
                                       value="@NormalizeColor(GetColor(root))"
                                       @onchange="e => SaveRootColorAsync(root, e.Value?.ToString())" />
                                <span class="category-dot" style="@($"background:{NormalizeColor(GetColor(root))};")"></span>
                            </label>

                            <div class="category-main">
                                @if (EditingRootOriginalName is not null
                                  && root.Equals(EditingRootOriginalName, StringComparison.OrdinalIgnoreCase))
                                {
                                    <input class="inline-input root-name-input"
                                           @bind="RootNameInput"
                                           @bind:event="oninput"
                                           @onblur="CommitRootEditAsync"
                                           @onkeydown="OnRootEditKeyDown" />
                                }
                                else
                                {
                                    <span class="category-name">@root</span>
                                }
                                <span class="category-meta">@subRows.Count sub-categories</span>
                            </div>

                            <div class="row-icons">
                                <button type="button" class="icon-btn edit-icon-btn" title="Edit category" @onclick="() => BeginRootEdit(root)">
                                    <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                        <path d="M12 20h9"></path>
                                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                                    </svg>
                                </button>
                                <button type="button" class="icon-btn danger" title="Delete category" @onclick="() => DeleteRootAsync(root)">
                                    <i data-lucide="trash-2" class="sd-lucide" aria-hidden="true"></i>
                                </button>
                                <button type="button"
                                        class="icon-btn chevron-btn @(IsExpanded(root) ? "expanded" : "")"
                                        title="Expand/collapse"
                                        @onclick="() => ToggleExpanded(root)">
                                    <svg viewBox="0 0 24 24" class="chevron-svg" aria-hidden="true" focusable="false">
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        @if (IsExpanded(root))
                        {
                            <div class="category-body">
                                <div class="sub-list">
                                    @for (var subIndex = 0; subIndex < subRows.Count; subIndex++)
                                    {
                                        var sub = subRows[subIndex];
                                        <div class="sub-row">
                                            <span class="drag-handle" aria-hidden="true">&#9776;</span>

                                            @if (EditingSubRootName is not null
                                              && EditingSubOriginalName is not null
                                              && root.Equals(EditingSubRootName, StringComparison.OrdinalIgnoreCase)
                                              && sub.Equals(EditingSubOriginalName, StringComparison.OrdinalIgnoreCase))
                                            {
                                                <input class="inline-input sub-name-input"
                                                       @bind="SubNameInput"
                                                       @bind:event="oninput"
                                                       @onblur="CommitSubEditAsync"
                                                       @onkeydown="OnSubEditKeyDown" />
                                            }
                                            else
                                            {
                                                <span class="sub-name">@sub</span>
                                            }

                                            <div class="row-icons">
                                                <button type="button" class="icon-btn edit-icon-btn" title="Edit sub-category" @onclick="() => BeginSubEdit(root, sub)">
                                                    <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                                        <path d="M12 20h9"></path>
                                                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                                                    </svg>
                                                </button>
                                                <button type="button" class="icon-btn danger" title="Delete sub-category" @onclick="() => DeleteSubAsync(root, sub)">
                                                    <i data-lucide="trash-2" class="sd-lucide" aria-hidden="true"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }

                                    @if (IsDraftSubRow(root))
                                    {
                                        <div class="sub-row draft">
                                            <span class="drag-handle" aria-hidden="true">&#9776;</span>
                                            <input class="inline-input sub-name-input"
                                                   placeholder="New category 2"
                                                   @bind="NewSubDraftValue"
                                                   @bind:event="oninput"
                                                   @onblur="CommitNewSubAsync"
                                                   @onkeydown="OnNewSubKeyDown" />
                                            <div class="row-icons">
                                                <button type="button" class="icon-btn danger" title="Discard new row" @onclick="ClearNewSubDraft">
                                                    <i data-lucide="trash-2" class="sd-lucide" aria-hidden="true"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }

                                    <div class="sub-list-footer">
                                        <button type="button" class="icon-btn plus" title="Add Category 2" @onclick="() => BeginNewSub(root)">
                                            <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                                <path d="M12 5v14"></path>
                                                <path d="M5 12h14"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </article>
                }

                @if (IsRootDraftActive)
                {
                    <article class="category-card root-draft-card">
                        <div class="category-head">
                            <span class="drag-handle" aria-hidden="true">&#9776;</span>
                            <label class="category-dot-picker" title="Choose color">
                                <input type="color"
                                       value="@NormalizeColor(NewRootDraftColor)"
                                       @onchange="OnRootDraftColorChanged" />
                                <span class="category-dot" style="@($"background:{NormalizeColor(NewRootDraftColor)};")"></span>
                            </label>
                            <div class="category-main">
                                <input class="inline-input root-name-input"
                                       placeholder="New category 1"
                                       @bind="NewRootDraftName"
                                       @bind:event="oninput"
                                       @onblur="CommitNewRootDraftAsync"
                                       @onkeydown="OnNewRootDraftKeyDown" />
                            </div>
                            <div class="row-icons">
                                <button type="button" class="icon-btn danger" title="Discard new row" @onclick="ClearRootDraft">
                                    <i data-lucide="trash-2" class="sd-lucide" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    </article>
                }

                <div class="root-list-footer">
                    <button type="button" class="icon-btn plus" title="Add Category 1" @onclick="BeginNewRoot">
                        <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                            <path d="M12 5v14"></path>
                            <path d="M5 12h14"></path>
                        </svg>
                    </button>
                </div>
            </div>
        }
    </section>
</div>

@code {
    private const string DefaultColor = "#94a3b8";

    private string Message = "";
    private bool IsError;
    private string CategoryFilter = "";

    private string RootNameInput = "";
    private string RootColorInput = DefaultColor;
    private string? EditingRootOriginalName;

    private string SubNameInput = "";
    private string? EditingSubRootName;
    private string? EditingSubOriginalName;

    private bool IsRootDraftActive;
    private string NewRootDraftName = "";
    private string NewRootDraftColor = DefaultColor;

    private string NewSubDraftCategory1 = "";
    private string NewSubDraftValue = "";

    private string? ExpandedRootName;
    private bool RootExpansionInitialized;

    protected override async Task OnInitializedAsync()
    {
        await Catalog.EnsureInitializedAsync();
        EnsureSeededStructure();
        SyncExpandedRoot();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            await JS.InvokeVoidAsync("marketingIcons.refresh");
        }
        catch
        {
            // No-op if lucide helper is unavailable.
        }
    }

    private List<string> Category1Rows =>
        Catalog.OrderCategories(
                Catalog.ServiceCategoryHierarchy.Keys
                    .Union(Catalog.Categories, StringComparer.OrdinalIgnoreCase)
                    .Select(NormalizeCategory1)
                    .Where(v => !string.IsNullOrWhiteSpace(v)))
            .ToList();

    private List<string> FilteredCategory1Rows =>
        Category1Rows
            .Where(MatchesFilter)
            .ToList();

    private List<string> SubRows(string category1)
    {
        if (!Catalog.ServiceCategoryHierarchy.TryGetValue(category1, out var items))
            return new List<string>();

        return Catalog
            .OrderCategory2Options(category1, items)
            .ToList();
    }

    private bool MatchesFilter(string category1)
    {
        var filter = (CategoryFilter ?? "").Trim();
        if (string.IsNullOrWhiteSpace(filter))
            return true;

        if (category1.Contains(filter, StringComparison.OrdinalIgnoreCase))
            return true;

        return SubRows(category1).Any(c => c.Contains(filter, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsExpanded(string category1) =>
        !string.IsNullOrWhiteSpace(ExpandedRootName)
        && category1.Equals(ExpandedRootName, StringComparison.OrdinalIgnoreCase);

    private void ToggleExpanded(string category1)
    {
        ExpandedRootName = IsExpanded(category1) ? null : category1;
        ClearSubEditState();
    }

    private void SyncExpandedRoot()
    {
        var roots = Category1Rows;
        if (!RootExpansionInitialized)
        {
            ExpandedRootName = roots.FirstOrDefault();
            RootExpansionInitialized = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(ExpandedRootName)
            || roots.All(r => !r.Equals(ExpandedRootName, StringComparison.OrdinalIgnoreCase)))
        {
            ExpandedRootName = roots.FirstOrDefault();
        }
    }

    private string GetColor(string category1)
    {
        if (Catalog.CategoryColors.TryGetValue(category1, out var color))
            return color;
        return DefaultColor;
    }

    private void EnsureSeededStructure()
    {
        if (Catalog.ServiceCategoryHierarchy.Count > 0)
            return;

        var hierarchy = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);
        foreach (var category1 in Catalog.Categories)
            hierarchy[category1] = new List<string>();

        foreach (var job in Catalog.Jobs)
        {
            var category1 = NormalizeCategory1(job.Category);
            var category2 = NormalizeCategory2(job.Category2);
            if (!hierarchy.TryGetValue(category1, out var sub))
            {
                sub = new List<string>();
                hierarchy[category1] = sub;
            }

            if (!string.IsNullOrWhiteSpace(category2)
                && !sub.Any(v => v.Equals(category2, StringComparison.OrdinalIgnoreCase)))
            {
                sub.Add(category2);
            }
        }

        foreach (var category1 in hierarchy.Keys.ToList())
            hierarchy[category1] = Catalog.OrderCategory2Options(category1, hierarchy[category1]).ToList();

        Catalog.ReplaceServiceCategoryHierarchy(hierarchy);
    }

    private async Task RefreshAsync()
    {
        await Catalog.ReloadAsync();
        EnsureSeededStructure();
        SyncExpandedRoot();
    }

    private async Task SaveRootAsync()
    {
        Message = "";
        IsError = false;

        var newName = NormalizeCategory1(RootNameInput);
        if (string.IsNullOrWhiteSpace(newName))
        {
            Message = "Category 1 name is required.";
            IsError = true;
            return;
        }

        var hierarchy = new Dictionary<string, List<string>>(Catalog.ServiceCategoryHierarchy, StringComparer.OrdinalIgnoreCase);
        var colors = new Dictionary<string, string>(Catalog.CategoryColors, StringComparer.OrdinalIgnoreCase);

        if (EditingRootOriginalName is not null
            && !EditingRootOriginalName.Equals(newName, StringComparison.OrdinalIgnoreCase))
        {
            if (hierarchy.ContainsKey(newName) || colors.ContainsKey(newName))
            {
                Message = "Category 1 already exists.";
                IsError = true;
                return;
            }

            if (hierarchy.TryGetValue(EditingRootOriginalName, out var existingChildren))
                hierarchy.Remove(EditingRootOriginalName);
            else
                existingChildren = new List<string>();

            var oldColor = colors.TryGetValue(EditingRootOriginalName, out var oldColorHex)
                ? oldColorHex
                : DefaultColor;
            colors.Remove(EditingRootOriginalName);
            colors[newName] = NormalizeColor(RootColorInput, oldColor);
            hierarchy[newName] = existingChildren;

            foreach (var job in Catalog.Jobs.Where(j => j.Category.Equals(EditingRootOriginalName, StringComparison.OrdinalIgnoreCase)))
            {
                job.Category = newName;
                await Catalog.SaveJobAsync(job);
            }
        }
        else
        {
            if (!hierarchy.ContainsKey(newName))
                hierarchy[newName] = new List<string>();

            colors[newName] = NormalizeColor(RootColorInput, GetColor(newName));
        }

        Catalog.CategoryColors.Clear();
        foreach (var entry in colors)
            Catalog.CategoryColors[entry.Key] = entry.Value;

        Catalog.ReplaceServiceCategoryHierarchy(hierarchy);
        await Catalog.SaveSettingsAsync();
        await RefreshAsync();

        ExpandedRootName = newName;
        Message = "Saved category.";
        IsError = false;
        ResetRootEditor();
    }

    private void BeginRootEdit(string category1)
    {
        ClearRootDraft();
        ClearSubEditState();
        EditingRootOriginalName = category1;
        RootNameInput = category1;
        RootColorInput = GetColor(category1);
        ExpandedRootName = category1;
    }

    private async Task CommitRootEditAsync()
    {
        if (EditingRootOriginalName is null)
            return;

        var updated = NormalizeCategory1(RootNameInput);
        if (string.IsNullOrWhiteSpace(updated))
        {
            ResetRootEditor();
            return;
        }

        await SaveRootAsync();
    }

    private async Task OnRootEditKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await CommitRootEditAsync();
        else if (args.Key == "Escape")
            ResetRootEditor();
    }

    private void ResetRootEditor()
    {
        EditingRootOriginalName = null;
        RootNameInput = "";
        RootColorInput = DefaultColor;
    }

    private async Task SaveRootColorAsync(string category1, string? rawColor)
    {
        var next = NormalizeColor(rawColor, DefaultColor);
        if (string.Equals(GetColor(category1), next, StringComparison.OrdinalIgnoreCase))
            return;

        Catalog.CategoryColors[category1] = next;
        await Catalog.SaveSettingsAsync();
        await RefreshAsync();
    }

    private void BeginNewRoot()
    {
        ResetRootEditor();
        ClearSubEditState();
        IsRootDraftActive = true;
        NewRootDraftName = "";
        NewRootDraftColor = DefaultColor;
    }

    private void OnRootDraftColorChanged(ChangeEventArgs args)
    {
        NewRootDraftColor = NormalizeColor(args.Value?.ToString(), DefaultColor);
    }

    private async Task CommitNewRootDraftAsync()
    {
        if (!IsRootDraftActive)
            return;

        var name = NormalizeCategory1(NewRootDraftName);
        if (string.IsNullOrWhiteSpace(name))
        {
            ClearRootDraft();
            return;
        }

        EditingRootOriginalName = null;
        RootNameInput = name;
        RootColorInput = NormalizeColor(NewRootDraftColor, DefaultColor);
        await SaveRootAsync();
        ClearRootDraft();
    }

    private async Task OnNewRootDraftKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await CommitNewRootDraftAsync();
        else if (args.Key == "Escape")
            ClearRootDraft();
    }

    private void ClearRootDraft()
    {
        IsRootDraftActive = false;
        NewRootDraftName = "";
        NewRootDraftColor = DefaultColor;
    }

    private async Task DeleteRootAsync(string category1)
    {
        var hasJobs = Catalog.Jobs.Any(j => j.Category.Equals(category1, StringComparison.OrdinalIgnoreCase));
        if (hasJobs)
        {
            Message = "Cannot delete a Category 1 that is in use by services.";
            IsError = true;
            return;
        }

        var hierarchy = new Dictionary<string, List<string>>(Catalog.ServiceCategoryHierarchy, StringComparer.OrdinalIgnoreCase);
        hierarchy.Remove(category1);
        Catalog.ReplaceServiceCategoryHierarchy(hierarchy);

        Catalog.CategoryColors.Remove(category1);
        await Catalog.SaveSettingsAsync();
        await RefreshAsync();

        Message = "Deleted category.";
        IsError = false;
        ResetRootEditor();
        ClearSubEditState();
    }

    private void BeginSubEdit(string category1, string category2)
    {
        ResetRootEditor();
        ClearNewSubDraft();
        EditingSubRootName = category1;
        EditingSubOriginalName = category2;
        SubNameInput = category2;
        ExpandedRootName = category1;
    }

    private async Task CommitSubEditAsync()
    {
        if (string.IsNullOrWhiteSpace(EditingSubRootName) || string.IsNullOrWhiteSpace(EditingSubOriginalName))
            return;

        var newSub = NormalizeCategory2(SubNameInput);
        if (string.IsNullOrWhiteSpace(newSub))
        {
            ResetSubEditor();
            return;
        }

        await SaveSubAsync(EditingSubRootName);
    }

    private async Task OnSubEditKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await CommitSubEditAsync();
        else if (args.Key == "Escape")
            ResetSubEditor();
    }

    private async Task SaveSubAsync(string category1)
    {
        Message = "";
        IsError = false;

        var root = EditingSubRootName ?? category1;
        var newSub = NormalizeCategory2(SubNameInput);
        if (string.IsNullOrWhiteSpace(newSub))
        {
            Message = "Category 2 name is required.";
            IsError = true;
            return;
        }

        var hierarchy = new Dictionary<string, List<string>>(Catalog.ServiceCategoryHierarchy, StringComparer.OrdinalIgnoreCase);
        if (!hierarchy.TryGetValue(root, out var existing))
            existing = new List<string>();

        if (EditingSubOriginalName is not null)
            existing.RemoveAll(v => v.Equals(EditingSubOriginalName, StringComparison.OrdinalIgnoreCase));

        if (existing.Any(v => v.Equals(newSub, StringComparison.OrdinalIgnoreCase)))
        {
            Message = "Category 2 already exists under this Category 1.";
            IsError = true;
            return;
        }

        existing.Add(newSub);
        existing = Catalog.OrderCategory2Options(root, existing).ToList();
        hierarchy[root] = existing;
        Catalog.ReplaceServiceCategoryHierarchy(hierarchy);

        if (EditingSubOriginalName is not null)
        {
            foreach (var job in Catalog.Jobs.Where(j =>
                         j.Category.Equals(root, StringComparison.OrdinalIgnoreCase)
                         && (j.Category2 ?? "").Equals(EditingSubOriginalName, StringComparison.OrdinalIgnoreCase)))
            {
                job.Category2 = newSub;
                await Catalog.SaveJobAsync(job);
            }
        }

        await Catalog.SaveSettingsAsync();
        await RefreshAsync();

        Message = "Saved sub-category.";
        IsError = false;
        ResetSubEditor();
        ExpandedRootName = root;
    }

    private void BeginNewSub(string category1)
    {
        ResetRootEditor();
        ResetSubEditor();
        NewSubDraftCategory1 = category1;
        NewSubDraftValue = "";
        ExpandedRootName = category1;
    }

    private async Task CommitNewSubAsync()
    {
        if (string.IsNullOrWhiteSpace(NewSubDraftCategory1))
            return;

        var name = NormalizeCategory2(NewSubDraftValue);
        if (string.IsNullOrWhiteSpace(name))
        {
            ClearNewSubDraft();
            return;
        }

        EditingSubRootName = NewSubDraftCategory1;
        EditingSubOriginalName = null;
        SubNameInput = name;
        await SaveSubAsync(NewSubDraftCategory1);
        ClearNewSubDraft();
    }

    private async Task OnNewSubKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await CommitNewSubAsync();
        else if (args.Key == "Escape")
            ClearNewSubDraft();
    }

    private bool IsDraftSubRow(string category1) =>
        NewSubDraftCategory1.Equals(category1, StringComparison.OrdinalIgnoreCase);

    private void ClearNewSubDraft()
    {
        NewSubDraftCategory1 = "";
        NewSubDraftValue = "";
    }

    private void ResetSubEditor()
    {
        EditingSubRootName = null;
        EditingSubOriginalName = null;
        SubNameInput = "";
    }

    private void ClearSubEditState()
    {
        ResetSubEditor();
        ClearNewSubDraft();
    }

    private async Task DeleteSubAsync(string category1, string category2)
    {
        var hasJobs = Catalog.Jobs.Any(j =>
            j.Category.Equals(category1, StringComparison.OrdinalIgnoreCase)
            && (j.Category2 ?? "").Equals(category2, StringComparison.OrdinalIgnoreCase));
        if (hasJobs)
        {
            Message = "Cannot delete a Category 2 that is in use by services.";
            IsError = true;
            return;
        }

        var hierarchy = new Dictionary<string, List<string>>(Catalog.ServiceCategoryHierarchy, StringComparer.OrdinalIgnoreCase);
        if (!hierarchy.TryGetValue(category1, out var sub))
            return;

        sub = sub.Where(v => !v.Equals(category2, StringComparison.OrdinalIgnoreCase)).ToList();
        hierarchy[category1] = sub;
        Catalog.ReplaceServiceCategoryHierarchy(hierarchy);
        await Catalog.SaveSettingsAsync();
        await RefreshAsync();

        Message = "Deleted sub-category.";
        IsError = false;
        ResetSubEditor();
        ClearNewSubDraft();
    }

    private async Task ImportSuggestedCategoriesAsync()
    {
        Message = "";
        IsError = false;
        var result = await SuggestedCatalog.ImportSuggestedAsync(TenantContext.TenantId, SuggestedImportMode.CategoriesOnly);
        await RefreshAsync();
        Message = $"Imported suggested categories. Added: {result.CategoriesAdded}, Updated: {result.CategoriesUpdated}.";
    }

    private static string NormalizeCategory1(string? value)
    {
        var normalized = (value ?? "").Trim();
        return string.IsNullOrWhiteSpace(normalized) ? "" : normalized;
    }

    private static string NormalizeCategory2(string? value)
        => (value ?? "").Trim();

    private static string NormalizeColor(string? value, string fallback)
    {
        var normalized = (value ?? "").Trim();
        if (string.IsNullOrWhiteSpace(normalized))
            return fallback;

        if (!normalized.StartsWith("#", StringComparison.Ordinal))
            normalized = "#" + normalized;

        return normalized;
    }

    private static string NormalizeColor(string? value)
        => NormalizeColor(value, DefaultColor);
}
