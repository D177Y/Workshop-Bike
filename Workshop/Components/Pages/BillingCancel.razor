@page "/billing/cancel"
@layout PublicLayout
@attribute [AllowAnonymous]

<section class="auth-wrapper">
    <div class="auth-card">
        <h2>Checkout cancelled</h2>
        <div class="section-subtitle">No worries. You can restart checkout any time.</div>
        <div style="margin-top:18px;">
            <a class="btn solid" href="/signup">Try again</a>
        </div>
    </div>
</section>
