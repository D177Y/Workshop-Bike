        if (package is null)
            return;

        foreach (var servicePackage in ServicePackageJobs)
            _selectedQuoteJobIds.Remove(servicePackage.Id);

        _selectedQuoteJobIds.Add(package.Id);
        SyncManualQuoteOverrides();
