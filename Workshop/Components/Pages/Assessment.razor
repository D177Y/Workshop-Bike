    private string GenerateNextCustomerAccountNumber()
    {
        var highest = 0;
        foreach (var account in _customerIndex.Select(c => c.AccountNumber))
        {
            if (string.IsNullOrWhiteSpace(account))
                continue;

            var digits = new string(account.Where(char.IsDigit).ToArray());
            if (int.TryParse(digits, out var parsed) && parsed > highest)
                highest = parsed;
        }

        return $"CUST-{highest + 1:00000}";
    }

    private List<JobDefinition> GetRecommendedJobs()
    {
        var allJobs = Catalog.Jobs.ToList();
        if (allJobs.Count == 0)
            return new List<JobDefinition>();

        var flagged = FlaggedChecks;
        if (flagged.Count == 0)
        {
            var seed = new List<JobDefinition>();
            seed.AddRange(ServicePackageJobs);
            seed.AddRange(allJobs.Where(j => !IsServicePackage(j)).Take(8));
            return seed.DistinctBy(j => j.Id).ToList();
        }

        var scores = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        foreach (var check in flagged)
        {
            foreach (var job in allJobs)
            {
                var score = ScoreJob(check, job);
                if (score <= 0)
                    continue;

                if (check.Outcome == AssessmentOutcome.Fail)
                    score += 1;

                scores[job.Id] = scores.GetValueOrDefault(job.Id) + score;
            }
        }

        foreach (var package in ServicePackageJobs)
            scores[package.Id] = scores.GetValueOrDefault(package.Id) + Math.Max(1, flagged.Count / 2);

        return allJobs
            .Where(j => scores.ContainsKey(j.Id))
            .OrderByDescending(j => scores[j.Id])
            .ThenBy(j => IsServicePackage(j) ? 1 : 0)
            .ThenBy(j => j.BasePriceIncVat)
            .Take(16)
            .ToList();
    }

    private static int ScoreJob(AssessmentCheckState check, JobDefinition job)
    {
        var name = job.Name.ToLowerInvariant();
        var category = job.Category.ToLowerInvariant();
        var score = 0;

        foreach (var term in check.MatchTerms)
        {
            if (name.Contains(term) || category.Contains(term))
                score += 2;
        }

        if (check.Category.Equals("Brakes", StringComparison.OrdinalIgnoreCase) &&
            (name.Contains("brake") || category.Contains("brake")))
        {
            score += 2;
        }

        if (check.Category.Equals("Gear", StringComparison.OrdinalIgnoreCase) &&
            (name.Contains("gear") || name.Contains("chain") || category.Contains("gear")))
        {
            score += 2;
        }

        if (check.Category.Equals("E-Bike", StringComparison.OrdinalIgnoreCase) &&
            (name.Contains("e-bike") || name.Contains("ebike") || name.Contains("motor") || name.Contains("software")))
        {
            score += 3;
        }

        if (check.Title.Contains("chain wear", StringComparison.OrdinalIgnoreCase) &&
            job.Id.Equals("GEAR_CHAIN", StringComparison.OrdinalIgnoreCase))
        {
            score += 4;
        }

        if (check.Category.Equals("Brakes", StringComparison.OrdinalIgnoreCase) &&
            job.Id.Equals("BRAKE_BLEED", StringComparison.OrdinalIgnoreCase))
        {
            score += 4;
        }

        if (check.Category.Equals("E-Bike", StringComparison.OrdinalIgnoreCase) &&
            job.Id.Equals("EBIKE_SW", StringComparison.OrdinalIgnoreCase))
        {
            score += 5;
        }

        if (IsServicePackage(job))
            score += 1;

        return score;
    }

