@rendermode @(new InteractiveServerRenderMode(prerender: false))
@page "/assessment"
@attribute [Authorize]
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Grids
@using TooltipPosition = Syncfusion.Blazor.Popups.Position
@using Workshop.Models
@using Workshop.Services
@inject WorkshopData Data
@inject CustomerProfileService CustomerProfiles
@inject QuoteWorkflowService QuoteWorkflow
@inject JobCatalogService Catalog
@inject UserAccessService UserAccess
@inject NavigationManager Nav
@inject ILogger<Assessment> Logger

<div class="assessment-page">
    <header class="assessment-header">
        <h3>ASSESSMENT</h3>
        <p>
            Work through each check so nothing is missed on the shop floor. Flag issues, add notes, build the best-value estimate,
            and send it straight to booking if needed.
        </p>
    </header>

    @if (!HasStoreAccess)
    {
        <section class="assessment-panel">
            <p>You do not currently have access to any stores. Contact an administrator to enable assessment and booking access.</p>
        </section>
    }
    else
    {
        <section class="assessment-panel customer-panel">
            <div class="customer-panel-head">
                <h4>Customer Details</h4>
            </div>

            <div class="customer-grid">
                <div class="field">
                    <label>Account number</label>
                    <input type="text" @bind="CustomerAccountNumber" />
                </div>
                <div class="field">
                    <label>Customer first name <span class="required-marker">*</span></label>
                    <input type="text" @bind="CustomerFirstName" />
                </div>
                <div class="field">
                    <label>Customer last name <span class="required-marker">*</span></label>
                    <input type="text" @bind="CustomerLastName" />
                </div>
                <div class="field">
                    <label>Customer phone <span class="required-marker">*</span></label>
                    <input type="text" @bind="CustomerPhone" />
                </div>
                <div class="field">
                    <label>Customer email</label>
                    <input type="email" @bind="CustomerEmail" />
                </div>
                <div class="field field-span-all">
                    <label>Address line 1</label>
                    <input type="text" @bind="CustomerAddressLine1" />
                </div>
                <div class="field field-span-all">
                    <label>Address line 2</label>
                    <input type="text" @bind="CustomerAddressLine2" />
                </div>
                <div class="field">
                    <label>County</label>
                    <input type="text" @bind="CustomerCounty" />
                </div>
                <div class="field">
                    <label>Postcode</label>
                    <input type="text" @bind="CustomerPostcode" />
                </div>
            </div>

            <div class="customer-submit-row">
                <button type="button" class="btn-primary" @onclick="AddCustomer">Add customer</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_customerStatusMessage))
            {
                <div class="@(_customerStatusIsError ? "status error" : "status success")">@_customerStatusMessage</div>
            }
        </section>

        <SfDialog Width="920px"
                  IsModal="true"
                  ShowCloseIcon="true"
                  Header="Select Customer"
                  @bind-Visible="_showSelectCustomerDialog">
            <DialogTemplates>
                <Content>
                    @if (_matchedCustomers.Count == 0)
                    {
                        <div class="muted">No matching customers found.</div>
                    }
                    else
                    {
                        <div class="customer-dialog-copy">A matching customer already exists. Select one customer and continue.</div>
                        <div class="customer-match-wrap">
                            <table class="customer-match-table">
                                <thead>
                                    <tr>
                                        <th>Select</th>
                                        <th>Account</th>
                                        <th>First Name</th>
                                        <th>Last Name</th>
                                        <th>Phone</th>
                                        <th>Email</th>
                                        <th>Address</th>
                                        <th>Postcode</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var match in _matchedCustomers)
                                    {
                                        <tr>
                                            <td>
                                                <input type="checkbox"
                                                       checked="@string.Equals(_selectedMatchedCustomerAccount, match.AccountNumber, StringComparison.OrdinalIgnoreCase)"
                                                       @onchange="e => SelectMatchedCustomer(match.AccountNumber, e)" />
                                            </td>
                                            <td>@match.AccountNumber</td>
                                            <td>@match.FirstName</td>
                                            <td>@match.LastName</td>
                                            <td>@(string.IsNullOrWhiteSpace(match.Phone) ? "-" : match.Phone)</td>
                                            <td>@(string.IsNullOrWhiteSpace(match.Email) ? "-" : match.Email)</td>
                                            <td>@(string.IsNullOrWhiteSpace(match.AddressLine1) ? "-" : match.AddressLine1)</td>
                                            <td>@(string.IsNullOrWhiteSpace(match.Postcode) ? "-" : match.Postcode)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </Content>
            </DialogTemplates>
            <DialogButtons>
                <DialogButton Content="Cancel" IsPrimary="false" OnClick="CloseSelectCustomerDialog" />
                <DialogButton Content="Create new customer" IsPrimary="false" OnClick="CreateNewCustomerFromSelectDialog" />
                <DialogButton Content="Continue" IsPrimary="true" OnClick="ContinueWithSelectedCustomer" />
            </DialogButtons>
        </SfDialog>

        <SfDialog Width="620px"
                  IsModal="true"
                  ShowCloseIcon="true"
                  Header="Create Customer"
                  @bind-Visible="_showCreateCustomerDialog">
            <DialogTemplates>
                <Content>
                    @if (_pendingCustomerCreate is null)
                    {
                        <div class="muted">No customer details to confirm.</div>
                    }
                    else
                    {
                        <div class="customer-dialog-copy">No existing customer matched. Confirm to create this customer.</div>
                        <dl class="customer-confirm-list">
                            <dt>Account</dt>
                            <dd>@_pendingCustomerCreate.AccountNumber</dd>
                            <dt>First Name</dt>
                            <dd>@(_pendingCustomerCreate.FirstName)</dd>
                            <dt>Last Name</dt>
                            <dd>@(_pendingCustomerCreate.LastName)</dd>
                            <dt>Phone</dt>
                            <dd>@(string.IsNullOrWhiteSpace(_pendingCustomerCreate.Phone) ? "-" : _pendingCustomerCreate.Phone)</dd>
                            <dt>Email</dt>
                            <dd>@(string.IsNullOrWhiteSpace(_pendingCustomerCreate.Email) ? "-" : _pendingCustomerCreate.Email)</dd>
                            <dt>Address line 1</dt>
                            <dd>@(string.IsNullOrWhiteSpace(_pendingCustomerCreate.AddressLine1) ? "-" : _pendingCustomerCreate.AddressLine1)</dd>
                            <dt>Address line 2</dt>
                            <dd>@(string.IsNullOrWhiteSpace(_pendingCustomerCreate.AddressLine2) ? "-" : _pendingCustomerCreate.AddressLine2)</dd>
                            <dt>County</dt>
                            <dd>@(string.IsNullOrWhiteSpace(_pendingCustomerCreate.County) ? "-" : _pendingCustomerCreate.County)</dd>
                            <dt>Postcode</dt>
                            <dd>@(string.IsNullOrWhiteSpace(_pendingCustomerCreate.Postcode) ? "-" : _pendingCustomerCreate.Postcode)</dd>
                        </dl>
                    }
                </Content>
            </DialogTemplates>
            <DialogButtons>
                <DialogButton Content="Cancel" IsPrimary="false" OnClick="CloseCreateCustomerDialog" />
                <DialogButton Content="Confirm" IsPrimary="true" OnClick="ConfirmCreateCustomer" />
            </DialogButtons>
        </SfDialog>

        <section class="assessment-panel bike-panel">
            <div class="bike-panel-head">
                <h4>Bike details</h4>
            </div>

            <CustomerBikeSelector Bikes="@CustomerBikes"
                                  @bind-SelectedBikeId="_selectedBikeId"
                                  OnBikesChanged="PersistCustomerBikeListAsync"
                                  EmptyStateText="No bikes found for this customer yet. Add a bike to continue."
                                  ErrorCssClass="status error" />
        </section>

        <section class="assessment-mode-switch" aria-label="Checklist mode">
            <button type="button"
                    class="mode-pill @ModeClass(AssessmentMode.Beginner)"
                    @onclick="@(() => SetMode(AssessmentMode.Beginner))">
                Beginner
            </button>
            <button type="button"
                    class="mode-pill @ModeClass(AssessmentMode.Advanced)"
                    @onclick="@(() => SetMode(AssessmentMode.Advanced))">
                Advanced
            </button>
        </section>

        <section class="assessment-workspace">
            <div class="assessment-left">
                @foreach (var category in GroupedChecks)
                {
                    <section class="assessment-panel">
                        <h4>@category.Key</h4>
                        <div class="checklist">
                            @foreach (var item in category)
                            {
                                <article class="check-item @ResultClass(item)">
                                    <div class="check-head">
                                        <div class="check-options">
                                            <label class="option pass">
                                                <input type="radio"
                                                       name="@($"result-{item.Key}")"
                                                       checked="@(item.Outcome == AssessmentOutcome.Pass)"
                                                       @onchange="@(() => SetOutcome(item, AssessmentOutcome.Pass))" />
                                                <span>Pass</span>
                                            </label>
                                            <label class="option advisory">
                                                <input type="radio"
                                                       name="@($"result-{item.Key}")"
                                                       checked="@(item.Outcome == AssessmentOutcome.Advisory)"
                                                       @onchange="@(() => SetOutcome(item, AssessmentOutcome.Advisory))" />
                                                <span>Advisory</span>
                                            </label>
                                            <label class="option fail">
                                                <input type="radio"
                                                       name="@($"result-{item.Key}")"
                                                       checked="@(item.Outcome == AssessmentOutcome.Fail)"
                                                       @onchange="@(() => SetOutcome(item, AssessmentOutcome.Fail))" />
                                                <span>Fail</span>
                                            </label>
                                        </div>

                                        <div class="check-title-row">
                                            <div class="check-title">@item.Title</div>
                                            <SfTooltip CssClass="assessment-tooltip"
                                                       Content="@item.Tooltip"
                                                       Position="@TooltipPosition.TopRight">
                                                <span class="field-tip" tabindex="0" role="button" aria-label="@($"{item.Title} help")">?</span>
                                            </SfTooltip>
                                            <button type="button" class="clear-link" @onclick="@(() => SetOutcome(item, AssessmentOutcome.None))">Clear</button>
                                        </div>
                                    </div>

                                    @if (RequiresNote(item))
                                    {
                                        <div class="check-note">
                                            <label>Note required for advisory/fail</label>
                                            <textarea rows="2" @bind="item.Note" placeholder="Add findings, measurements, or customer-facing explanation."></textarea>
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    </section>
                }
            </div>

            <aside class="assessment-right">
                <div class="stats-sticky">
                    <section class="assessment-stats">
                        <div class="stat pass">
                            <span class="stat-label">Pass</span>
                            <strong>@PassCount</strong>
                        </div>
                        <div class="stat advisory">
                            <span class="stat-label">Advisory</span>
                            <strong>@AdvisoryCount</strong>
                        </div>
                        <div class="stat fail">
                            <span class="stat-label">Fail</span>
                            <strong>@FailCount</strong>
                        </div>
                        <div class="stat pending">
                            <span class="stat-label">Not set</span>
                            <strong>@NotSetCount</strong>
                        </div>
                    </section>
                </div>

                <section class="assessment-panel issues-panel">
                    <h4>Issues</h4>
                    @if (Issues.Count == 0)
                    {
                        <div class="muted">No failed checks yet.</div>
                    }
                    else
                    {
                        <ul class="issue-list">
                            @foreach (var issue in Issues)
                            {
                                <li>
                                    <div class="issue-title">@issue.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(issue.Note))
                                    {
                                        <div class="issue-note">@issue.Note.Trim()</div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </section>

                <section class="assessment-panel issues-panel">
                    <h4>Advisories</h4>
                    @if (Advisories.Count == 0)
                    {
                        <div class="muted">No advisory checks yet.</div>
                    }
                    else
                    {
                        <ul class="issue-list">
                            @foreach (var advisory in Advisories)
                            {
                                <li>
                                    <div class="issue-title">@advisory.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(advisory.Note))
                                    {
                                        <div class="issue-note">@advisory.Note.Trim()</div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </section>
            </aside>
        </section>

        <section class="assessment-panel quote-panel">
            <div class="quote-head">
                <h4>Service Options and Estimate</h4>
                <p>@BestValueSummary</p>
            </div>

            <div class="quote-actions">
                <button type="button" class="btn-secondary" @onclick="ApplySuggestedPackage" disabled="@(SuggestedPackage is null)">Use suggested package</button>
                <button type="button" class="btn-secondary" @onclick="UseTargetedRepairsOnly">Use targeted repairs only</button>
            </div>

            <div class="quote-job-list">
                @if (RecommendedJobs.Count == 0)
                {
                    <div class="muted">No matching jobs available yet. Add services in Manage Services, then return here.</div>
                }
                else
                {
                    @foreach (var job in RecommendedJobs)
                    {
                        <label class="quote-job-row">
                            <input type="checkbox"
                                   checked="@_selectedQuoteJobIds.Contains(job.Id)"
                                   @onchange="e => ToggleQuoteJob(job.Id, e)" />
                            <span class="quote-job-name">@job.Name</span>
                            <span class="quote-job-meta">@GetQuoteJobMinutesLabel(job)</span>
                            <span class="quote-job-meta">@GetQuoteJobPriceLabel(job)</span>
                            @if (IsServicePackage(job))
                            {
                                <span class="package-tag">Package</span>
                            }
                        </label>
                    }
                }
            </div>

            @if (SelectedManualQuoteJobs.Count > 0)
            {
                <section class="quote-manual-section">
                    <h5>Manual time and price required</h5>
                    @foreach (var job in SelectedManualQuoteJobs)
                    {
                        var hasError = IsManualQuoteOverrideInvalid(job.Id);
                        <div class="quote-manual-row">
                            <span class="quote-manual-name">@job.Name</span>
                            <label>
                                Minutes
                                <input type="number"
                                       min="0"
                                       value="@GetManualQuoteMinutes(job.Id)"
                                       class="@(hasError ? "manual-input-error" : "")"
                                       @onchange="e => SetManualQuoteMinutes(job.Id, e)" />
                            </label>
                            <label>
                                Price (GBP)
                                <input type="number"
                                       min="0"
                                       step="0.01"
                                       value="@GetManualQuotePrice(job.Id).ToString("0.00")"
                                       class="@(hasError ? "manual-input-error" : "")"
                                       @onchange="e => SetManualQuotePrice(job.Id, e)" />
                            </label>
                        </div>
                    }
                </section>
            }

            <div class="estimate-summary">
                <div><strong>Selected options:</strong> @(SelectedQuoteJobs.Count == 0 ? "-" : string.Join(", ", SelectedQuoteJobs.Select(j => j.Name)))</div>
                <div><strong>Estimated duration:</strong> @QuoteMinutes mins</div>
                <div><strong>Estimated price:</strong> GBP @QuotePrice.ToString("0.00")</div>
            </div>

            <section class="saved-quote-panel">
                <h5>Saved quotes for this customer</h5>
                @if (CurrentCustomerSavedQuotes.Count == 0)
                {
                    <div class="muted">No saved quotes yet.</div>
                }
                else
                {
                    <div class="saved-quote-list">
                        @foreach (var quote in CurrentCustomerSavedQuotes)
                        {
                            <div class="saved-quote-row">
                                <div class="saved-quote-meta">
                                    <strong>@quote.CreatedUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</strong>
                                    <span>@(string.IsNullOrWhiteSpace(quote.BikeDetails) ? "-" : quote.BikeDetails)</span>
                                </div>
                                <div class="saved-quote-summary">
                                    <span>@(quote.JobNames.Length == 0 ? "-" : string.Join(", ", quote.JobNames))</span>
                                    <span class="status-pill @QuoteStatusClass(quote)">@GetQuoteStatus(quote)</span>
                                    <span>GBP @quote.EstimatedPriceIncVat.ToString("0.00")</span>
                                </div>
                                <button type="button" class="btn-secondary" @onclick="() => LoadSavedQuote(quote.Id)">Load quote</button>
                            </div>
                        }
                    </div>
                }
            </section>

            @if (MissingNoteCount > 0)
            {
                <div class="validation-banner">
                    Add notes for @MissingNoteCount advisory/fail checks before passing this to booking.
                </div>
            }

            @if (MissingManualQuoteOverrideCount > 0)
            {
                <div class="validation-banner">
                    Set minutes and price for @MissingManualQuoteOverrideCount TBC service(s) before saving or sending to booking.
                </div>
            }

            <div class="final-actions">
                <button type="button" class="btn-secondary" @onclick="SaveQuote">Save quote</button>
                <button type="button" class="btn-secondary" @onclick="EmailQuote">Email quote to customer + booking</button>
                <button type="button" class="btn-primary" @onclick="SendToBooking">Send to booking</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <div class="@(_statusIsError ? "status error" : "status success")">@_statusMessage</div>
            }
        </section>
    }
</div>

@code {
    private readonly List<AssessmentCheckState> _beginnerChecks = BuildBeginnerChecks();
    private readonly List<AssessmentCheckState> _advancedChecks = BuildAdvancedChecks();
    private readonly HashSet<string> _selectedQuoteJobIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, CustomerQuoteManualServiceOverride> _manualQuoteOverridesByJobId = new(StringComparer.OrdinalIgnoreCase);
    private UserAccessScope _userAccess = UserAccessScope.AllowAll();
    private string _statusMessage = "";
    private bool _statusIsError;
    private AssessmentMode _mode = AssessmentMode.Beginner;

    private int _selectedStoreId;
    private readonly List<CustomerLookupRecord> _customerIndex = new();
    private readonly List<CustomerBikeRow> CustomerBikes = new();

    private string CustomerAccountNumber = "";
    private string CustomerFirstName = "";
    private string CustomerLastName = "";
    private string CustomerPhone = "";
    private string CustomerEmail = "";
    private string CustomerCounty = "";
    private string CustomerPostcode = "";
    private string CustomerAddressLine1 = "";
    private string CustomerAddressLine2 = "";
    private string _customerStatusMessage = "";
    private bool _customerStatusIsError;
    private bool _showSelectCustomerDialog;
    private bool _showCreateCustomerDialog;
    private List<CustomerLookupRecord> _matchedCustomers = new();
    private string? _selectedMatchedCustomerAccount;
    private CustomerLookupRecord? _pendingCustomerCreate;
    private string? _selectedBikeId;

    private IEnumerable<Store> AccessibleStores =>
        Data.Stores
            .Where(s => _userAccess.CanAccessStore(s.Id))
            .OrderBy(s => s.Name);

    private bool HasStoreAccess => AccessibleStores.Any();
    private List<AssessmentCheckState> ActiveChecks => _mode == AssessmentMode.Beginner ? _beginnerChecks : _advancedChecks;
    private CustomerBikeRow? SelectedBike =>
        string.IsNullOrWhiteSpace(_selectedBikeId)
            ? null
            : CustomerBikes.FirstOrDefault(b => b.RowId.Equals(_selectedBikeId, StringComparison.OrdinalIgnoreCase));
    private string SelectedBikeDetails => BikeDetailsService.BuildBikeDetailsText(SelectedBike);
    private CustomerLookupRecord? ActiveCustomer =>
        string.IsNullOrWhiteSpace(CustomerAccountNumber)
            ? null
            : _customerIndex.FirstOrDefault(c => c.AccountNumber.Equals(CustomerAccountNumber.Trim(), StringComparison.OrdinalIgnoreCase));
    private List<CustomerQuoteRecord> CurrentCustomerSavedQuotes =>
        ActiveCustomer?.Quotes
            .OrderByDescending(q => q.CreatedUtc)
            .Take(6)
            .Select(CloneQuote)
            .ToList() ?? new List<CustomerQuoteRecord>();

    private static string GetQuoteStatus(CustomerQuoteRecord quote) =>
        QuoteLifecycleService.ResolveStatus(quote, DateTime.UtcNow);

    private static string QuoteStatusClass(CustomerQuoteRecord quote)
    {
        var status = GetQuoteStatus(quote);
        if (status.Equals(QuoteLifecycleStatus.Sent, StringComparison.OrdinalIgnoreCase))
            return "sent";
        if (status.Equals(QuoteLifecycleStatus.Accepted, StringComparison.OrdinalIgnoreCase))
            return "accepted";
        if (status.Equals(QuoteLifecycleStatus.Expired, StringComparison.OrdinalIgnoreCase))
            return "expired";
        return "draft";
    }

    private int SelectedStoreId
    {
        get => _selectedStoreId;
        set
        {
            if (value != 0 && !AccessibleStores.Any(s => s.Id == value))
                return;

            _selectedStoreId = value;
        }
    }

    private IReadOnlyList<IGrouping<string, AssessmentCheckState>> GroupedChecks =>
        ActiveChecks.GroupBy(c => c.Category).ToList();

    private int PassCount => ActiveChecks.Count(c => c.Outcome == AssessmentOutcome.Pass);
    private int AdvisoryCount => ActiveChecks.Count(c => c.Outcome == AssessmentOutcome.Advisory);
    private int FailCount => ActiveChecks.Count(c => c.Outcome == AssessmentOutcome.Fail);
    private int NotSetCount => ActiveChecks.Count(c => c.Outcome == AssessmentOutcome.None);

    private List<AssessmentCheckState> FlaggedChecks =>
        ActiveChecks.Where(c => c.Outcome == AssessmentOutcome.Advisory || c.Outcome == AssessmentOutcome.Fail).ToList();

    private List<AssessmentCheckState> Issues =>
        ActiveChecks.Where(c => c.Outcome == AssessmentOutcome.Fail).ToList();

    private List<AssessmentCheckState> Advisories =>
        ActiveChecks.Where(c => c.Outcome == AssessmentOutcome.Advisory).ToList();

    private List<JobDefinition> SelectedQuoteJobs =>
        Catalog.Jobs
            .Where(j => _selectedQuoteJobIds.Contains(j.Id))
            .OrderBy(j => IsServicePackage(j) ? 1 : 0)
            .ThenBy(j => j.Name)
            .ToList();

    private List<JobDefinition> SelectedManualQuoteJobs =>
        SelectedQuoteJobs
            .Where(RequiresManualQuoteAtUse)
            .OrderBy(j => j.Name)
            .ToList();

    private List<JobDefinition> ServicePackageJobs =>
        Catalog.Jobs
            .Where(IsServicePackage)
            .OrderBy(j => j.BasePriceIncVat)
            .ToList();

    private List<JobDefinition> RecommendedJobs => GetRecommendedJobs();

    private int QuoteMinutes => SelectedQuoteJobs.Sum(j => ResolveQuoteJobMinutes(j));
    private decimal QuotePrice => SelectedQuoteJobs.Sum(j => ResolveQuoteJobPrice(j));
    private decimal TargetedRepairTotal => SelectedQuoteJobs.Where(j => !IsServicePackage(j)).Sum(j => ResolveQuoteJobPrice(j));
    private int MissingNoteCount => ActiveChecks.Count(c => RequiresNote(c) && string.IsNullOrWhiteSpace(c.Note));
    private int MissingManualQuoteOverrideCount => SelectedManualQuoteJobs.Count(j => IsManualQuoteOverrideInvalid(j.Id));

    private JobDefinition? SuggestedPackage
    {
        get
        {
            var packages = ServicePackageJobs;
            if (packages.Count == 0)
                return null;

            var issueScore = (FailCount * 2) + AdvisoryCount;
            if (issueScore >= 8)
                return packages[^1];

            if (issueScore >= 4)
                return packages[Math.Min(1, packages.Count - 1)];

            return packages[0];
        }
    }

    private string BestValueSummary
    {
        get
        {
            if (SelectedQuoteJobs.Count == 0)
                return "Select one or more service options to produce an estimate.";

            var package = SuggestedPackage;
            if (package is null)
                return "Best value estimate is currently based on your selected repair options.";

            var targeted = TargetedRepairTotal;
            if (targeted <= 0)
                return $"Suggested package for best value: {package.Name} (GBP {package.BasePriceIncVat:0.00}).";

            return package.BasePriceIncVat < targeted
                ? $"Best value currently looks like {package.Name} at GBP {package.BasePriceIncVat:0.00} (targeted repairs GBP {targeted:0.00})."
                : $"Best value currently looks like targeted repairs at GBP {targeted:0.00} ({package.Name} is GBP {package.BasePriceIncVat:0.00}).";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Data.EnsureInitializedAsync();
            await Catalog.EnsureInitializedAsync();
            _userAccess = await UserAccess.GetCurrentAsync();

            if (HasStoreAccess)
                SelectedStoreId = AccessibleStores.First().Id;

            RebuildCustomerIndex();
            RefreshRecommendations();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize assessment page.");
            _statusMessage = "Could not load assessment data. Please refresh and try again.";
            _statusIsError = true;
        }
    }

    private static bool IsServicePackage(JobDefinition job) =>
        job.Category.Equals("Service Packages", StringComparison.OrdinalIgnoreCase);

    private bool RequiresManualQuoteAtUse(JobDefinition job)
        => Catalog.RequiresManualQuoteAtUse(job);

    private int ResolveQuoteJobMinutes(JobDefinition job)
    {
        if (!RequiresManualQuoteAtUse(job))
            return Math.Max(0, job.DefaultMinutes);

        return _manualQuoteOverridesByJobId.TryGetValue(job.Id, out var overrideValue)
            ? Math.Max(0, overrideValue.Minutes)
            : 0;
    }

    private decimal ResolveQuoteJobPrice(JobDefinition job)
    {
        if (!RequiresManualQuoteAtUse(job))
            return Math.Max(0m, job.BasePriceIncVat);

        return _manualQuoteOverridesByJobId.TryGetValue(job.Id, out var overrideValue)
            ? Math.Max(0m, overrideValue.PriceIncVat)
            : 0m;
    }

    private string GetQuoteJobMinutesLabel(JobDefinition job)
        => RequiresManualQuoteAtUse(job) ? "TBC mins" : $"{Math.Max(0, job.DefaultMinutes)} mins";

    private string GetQuoteJobPriceLabel(JobDefinition job)
        => RequiresManualQuoteAtUse(job) ? "TBC price" : $"GBP {Math.Max(0m, job.BasePriceIncVat):0.00}";

    private int GetManualQuoteMinutes(string jobId)
        => _manualQuoteOverridesByJobId.TryGetValue(jobId, out var value) ? Math.Max(0, value.Minutes) : 0;

    private decimal GetManualQuotePrice(string jobId)
        => _manualQuoteOverridesByJobId.TryGetValue(jobId, out var value) ? Math.Max(0m, value.PriceIncVat) : 0m;

    private bool IsManualQuoteOverrideInvalid(string jobId)
    {
        if (!_manualQuoteOverridesByJobId.TryGetValue(jobId, out var value))
            return true;

        return value.Minutes <= 0 || value.PriceIncVat <= 0m;
    }

    private void SetManualQuoteMinutes(string jobId, ChangeEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(jobId))
            return;

        var current = _manualQuoteOverridesByJobId.TryGetValue(jobId, out var existing)
            ? existing
            : new CustomerQuoteManualServiceOverride { JobId = jobId };

        if (int.TryParse(e?.Value?.ToString(), out var minutes))
            current.Minutes = Math.Max(0, minutes);

        _manualQuoteOverridesByJobId[jobId] = current;
    }

    private void SetManualQuotePrice(string jobId, ChangeEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(jobId))
            return;

        var current = _manualQuoteOverridesByJobId.TryGetValue(jobId, out var existing)
            ? existing
            : new CustomerQuoteManualServiceOverride { JobId = jobId };

        var raw = (e?.Value?.ToString() ?? "").Trim();
        if (decimal.TryParse(raw, out var price)
            || decimal.TryParse(raw, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out price))
        {
            current.PriceIncVat = decimal.Round(Math.Max(0m, price), 2, MidpointRounding.AwayFromZero);
        }

        _manualQuoteOverridesByJobId[jobId] = current;
    }

    private void SyncManualQuoteOverrides()
    {
        var selectedManualJobs = SelectedQuoteJobs
            .Where(RequiresManualQuoteAtUse)
            .ToList();

        var selectedIds = selectedManualJobs
            .Select(j => j.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var staleIds = _manualQuoteOverridesByJobId.Keys
            .Where(id => !selectedIds.Contains(id))
            .ToList();
        foreach (var staleId in staleIds)
            _manualQuoteOverridesByJobId.Remove(staleId);

        foreach (var job in selectedManualJobs)
        {
            if (_manualQuoteOverridesByJobId.ContainsKey(job.Id))
                continue;

            _manualQuoteOverridesByJobId[job.Id] = new CustomerQuoteManualServiceOverride
            {
                JobId = job.Id,
                Minutes = Math.Max(0, job.DefaultMinutes),
                PriceIncVat = 0m
            };
        }
    }

    private string BuildManualQuoteOverridesQueryValue()
    {
        var items = SelectedManualQuoteJobs
            .Where(job => _manualQuoteOverridesByJobId.TryGetValue(job.Id, out var value)
                          && value.Minutes > 0
                          && value.PriceIncVat > 0m)
            .Select(job =>
            {
                var value = _manualQuoteOverridesByJobId[job.Id];
                var priceText = value.PriceIncVat.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
                return $"{job.Id}:{value.Minutes}:{priceText}";
            })
            .ToList();

        return items.Count == 0 ? "" : string.Join(",", items);
    }

    private void SetOutcome(AssessmentCheckState item, AssessmentOutcome outcome)
    {
        if (item.Outcome == outcome)
            return;

        item.Outcome = outcome;
        if (outcome is AssessmentOutcome.Pass or AssessmentOutcome.None)
            item.Note = "";

        _statusMessage = "";
        _statusIsError = false;
        RefreshRecommendations();
    }

    private static bool RequiresNote(AssessmentCheckState item) =>
        item.Outcome is AssessmentOutcome.Advisory or AssessmentOutcome.Fail;

    private static string OutcomeLabel(AssessmentOutcome outcome) => outcome switch
    {
        AssessmentOutcome.Pass => "Pass",
        AssessmentOutcome.Advisory => "Advisory",
        AssessmentOutcome.Fail => "Fail",
        _ => "Not set"
    };

    private static string ResultClass(AssessmentCheckState item) => item.Outcome switch
    {
        AssessmentOutcome.Pass => "result-pass",
        AssessmentOutcome.Advisory => "result-advisory",
        AssessmentOutcome.Fail => "result-fail",
        _ => "result-none"
    };

    private string ModeClass(AssessmentMode mode) => _mode == mode ? "active" : "";

    private void SetMode(AssessmentMode mode)
    {
        if (_mode == mode)
            return;

        _mode = mode;
        _statusMessage = "";
        _statusIsError = false;
        RefreshRecommendations();
    }

    private void AddCustomer()
    {
        _customerStatusMessage = "";
        _customerStatusIsError = false;

        var request = BuildCustomerRequestFromForm();
        var firstName = request.FirstName;
        var lastName = request.LastName;
        var phone = request.Phone;

        if (string.IsNullOrWhiteSpace(firstName) || string.IsNullOrWhiteSpace(lastName) || string.IsNullOrWhiteSpace(phone))
        {
            _customerStatusMessage = "First name, last name and phone are required.";
            _customerStatusIsError = true;
            return;
        }

        _matchedCustomers = FindDuplicateCustomers(request);
        if (_matchedCustomers.Count > 0)
        {
            _selectedMatchedCustomerAccount = null;
            _showSelectCustomerDialog = true;
            return;
        }

        request.AccountNumber = GenerateNextCustomerAccountNumber();
        _pendingCustomerCreate = request;
        _showCreateCustomerDialog = true;
    }

    private void CreateNewCustomerFromSelectDialog()
    {
        var request = BuildCustomerRequestFromForm();
        if (string.IsNullOrWhiteSpace(request.FirstName) || string.IsNullOrWhiteSpace(request.LastName) || string.IsNullOrWhiteSpace(request.Phone))
        {
            _customerStatusMessage = "First name, last name and phone are required.";
            _customerStatusIsError = true;
            return;
        }

        request.AccountNumber = GenerateNextCustomerAccountNumber();
        _pendingCustomerCreate = request;

        _showSelectCustomerDialog = false;
        _selectedMatchedCustomerAccount = null;
        _matchedCustomers = new List<CustomerLookupRecord>();

        _showCreateCustomerDialog = true;
    }

    private List<CustomerLookupRecord> FindDuplicateCustomers(CustomerLookupRecord request)
    {
        var requestPhoneDigits = NormalizeDigits(request.Phone);
        var requestAccount = request.AccountNumber.Trim();
        var requestEmail = request.Email.Trim();
        var requestLast = request.LastName.Trim();
        var requestPostcode = request.Postcode.Trim();

        return _customerIndex
            .Where(customer =>
                (!string.IsNullOrWhiteSpace(requestAccount) &&
                 customer.AccountNumber.Equals(requestAccount, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(requestPhoneDigits) &&
                    NormalizeDigits(customer.Phone).Equals(requestPhoneDigits, StringComparison.Ordinal))
                || (!string.IsNullOrWhiteSpace(requestEmail) &&
                    customer.Email.Equals(requestEmail, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(requestLast) &&
                    !string.IsNullOrWhiteSpace(requestPostcode) &&
                    customer.LastName.Equals(requestLast, StringComparison.OrdinalIgnoreCase) &&
                    customer.Postcode.Equals(requestPostcode, StringComparison.OrdinalIgnoreCase)))
            .ToList();
    }

    private void SelectMatchedCustomer(string accountNumber, ChangeEventArgs e)
    {
        var isChecked = e?.Value is bool b && b;
        if (isChecked)
        {
            _selectedMatchedCustomerAccount = accountNumber;
            return;
        }

        if (string.Equals(_selectedMatchedCustomerAccount, accountNumber, StringComparison.OrdinalIgnoreCase))
            _selectedMatchedCustomerAccount = null;
    }

    private void CloseSelectCustomerDialog()
    {
        _showSelectCustomerDialog = false;
        _selectedMatchedCustomerAccount = null;
        _matchedCustomers = new List<CustomerLookupRecord>();
    }

    private void ContinueWithSelectedCustomer()
    {
        if (string.IsNullOrWhiteSpace(_selectedMatchedCustomerAccount))
        {
            _customerStatusMessage = "Select one customer to continue.";
            _customerStatusIsError = true;
            return;
        }

        var customer = _customerIndex.FirstOrDefault(c =>
            c.AccountNumber.Equals(_selectedMatchedCustomerAccount, StringComparison.OrdinalIgnoreCase));
        if (customer is null)
        {
            _customerStatusMessage = "Selected customer was not found.";
            _customerStatusIsError = true;
            CloseSelectCustomerDialog();
            return;
        }

        ApplyCustomerToForm(customer, copyBikes: true);
        _customerStatusMessage = $"Using existing customer {customer.AccountNumber}.";
        _customerStatusIsError = false;
        CloseSelectCustomerDialog();
    }

    private void CloseCreateCustomerDialog()
    {
        _showCreateCustomerDialog = false;
        _pendingCustomerCreate = null;
    }

    private async Task ConfirmCreateCustomer()
    {
        if (_pendingCustomerCreate is null)
        {
            _customerStatusMessage = "No customer details available to create.";
            _customerStatusIsError = true;
            CloseCreateCustomerDialog();
            return;
        }

        try
        {
            var created = CloneCustomer(_pendingCustomerCreate);
            var saved = await SaveCustomerLookupAsync(created);
            ApplyCustomerToForm(saved, copyBikes: false);
            _customerStatusMessage = $"Customer created as {saved.AccountNumber}.";
            _customerStatusIsError = false;
            CloseCreateCustomerDialog();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create customer profile.");
            _customerStatusMessage = "Could not create customer profile. Please try again.";
            _customerStatusIsError = true;
        }
    }

