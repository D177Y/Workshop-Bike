                Bikes = new List<CustomerBikeRow>(),
                Quotes = new List<CustomerQuoteRecord>(),
                Communications = new List<CustomerCommunicationRecord>()
            };
            _customerIndex.Add(customer);
        }

        customer.FirstName = CustomerFirstName.Trim();
        customer.LastName = CustomerLastName.Trim();
        customer.Phone = CustomerPhone.Trim();
        customer.Email = CustomerEmail.Trim();
        customer.County = CustomerCounty.Trim();
