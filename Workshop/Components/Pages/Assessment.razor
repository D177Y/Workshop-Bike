    private static string BuildCustomerLookupKey(Booking booking)
    {
        var email = booking.CustomerEmail.Trim().ToLowerInvariant();
        if (!string.IsNullOrWhiteSpace(email))
            return $"email:{email}";

        var phone = NormalizeDigits(booking.CustomerPhone);
        if (!string.IsNullOrWhiteSpace(phone))
            return $"phone:{phone}";

        var first = booking.CustomerFirstName.Trim().ToLowerInvariant();
        var last = booking.CustomerLastName.Trim().ToLowerInvariant();
        if (!string.IsNullOrWhiteSpace(first) || !string.IsNullOrWhiteSpace(last))
            return $"name:{first}|{last}";

        return "";
    }

    private static string NormalizeDigits(string input) =>
        new(input.Where(char.IsDigit).ToArray());

