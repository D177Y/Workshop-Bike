    private void LoadSavedQuote(string quoteId)
    {
        if (string.IsNullOrWhiteSpace(quoteId))
            return;

        var quote = ActiveCustomer?.Quotes.FirstOrDefault(q =>
            q.Id.Equals(quoteId, StringComparison.OrdinalIgnoreCase));
        if (quote is null)
        {
            _statusMessage = "Saved quote not found.";
            _statusIsError = true;
            return;
        }

        _selectedQuoteJobIds.Clear();
        foreach (var jobId in quote.JobIds)
        {
            if (Catalog.Jobs.Any(j => j.Id.Equals(jobId, StringComparison.OrdinalIgnoreCase)))
                _selectedQuoteJobIds.Add(jobId);
        }

        _manualQuoteOverridesByJobId.Clear();
        foreach (var overrideValue in quote.ManualServiceOverrides ?? new List<CustomerQuoteManualServiceOverride>())
        {
            var jobId = (overrideValue.JobId ?? "").Trim();
            if (string.IsNullOrWhiteSpace(jobId))
                continue;

            _manualQuoteOverridesByJobId[jobId] = new CustomerQuoteManualServiceOverride
            {
                JobId = jobId,
                Minutes = Math.Max(0, overrideValue.Minutes),
                PriceIncVat = decimal.Round(Math.Max(0m, overrideValue.PriceIncVat), 2, MidpointRounding.AwayFromZero)
            };
        }

        SyncManualQuoteOverrides();

        _statusMessage = $"Loaded quote from {quote.CreatedUtc.ToLocalTime():dd MMM yyyy HH:mm}.";
        _statusIsError = false;
    }

    private async Task SaveQuote()
    {
        await SaveCurrentQuoteAsync(showSuccessMessage: true);
    }

    private async Task EmailQuote()
    {
        var (customer, quote) = await SaveCurrentQuoteAsync(showSuccessMessage: false);
        if (customer is null || quote is null)
            return;

        var customerEmail = (customer.Email ?? "").Trim();
        var store = Data.Stores.FirstOrDefault(s => s.Id == SelectedStoreId);
        var bookingEmail = (store?.Email ?? "").Trim();

        var validation = QuoteValidationService.ValidateCanEmailQuote(customerEmail);
        if (!validation.IsValid)
        {
            _statusMessage = validation.Message;
            _statusIsError = true;
            return;
        }

        var emailResult = await QuoteWorkflow.EmailQuoteAsync(new QuoteEmailDispatchRequest(
            customer.AccountNumber,
            customer.FirstName,
            customer.LastName,
            customerEmail,
            bookingEmail,
            quote));

        RebuildCustomerIndex();

        if (emailResult.Sent.Count == 0)
        {
            _statusMessage = "Quote email failed. Check email configuration and try again.";
            _statusIsError = true;
            return;
        }

        if (emailResult.Failed.Count == 0)
        {
            _statusMessage = $"Quote emailed to {string.Join(" and ", emailResult.Sent)}.";
            _statusIsError = false;
            return;
        }

        _statusMessage = $"Quote emailed to {string.Join(" and ", emailResult.Sent)}. Retry queued for {string.Join(" and ", emailResult.Failed)}.";
        _statusIsError = true;
    }

    private async Task<(CustomerLookupRecord? Customer, CustomerQuoteRecord? Quote)> SaveCurrentQuoteAsync(bool showSuccessMessage)
    {
        if (SelectedQuoteJobs.Count == 0)
        {
            _statusMessage = "Select at least one service option before saving a quote.";
            _statusIsError = true;
            return (null, null);
        }

        if (MissingNoteCount > 0)
        {
            _statusMessage = "Add notes to all advisory/fail checks before saving this quote.";
            _statusIsError = true;
            return (null, null);
        }

        if (MissingManualQuoteOverrideCount > 0)
        {
            _statusMessage = "Set minutes and price for all TBC services before saving this quote.";
            _statusIsError = true;
            return (null, null);
        }

        if (string.IsNullOrWhiteSpace(SelectedBikeDetails))
        {
            _statusMessage = "Select one bike for this quote before saving.";
            _statusIsError = true;
            return (null, null);
        }

        var customer = await EnsureCustomerProfileAsync(showValidationError: true);
        if (customer is null)
            return (null, null);

        var store = Data.Stores.FirstOrDefault(s => s.Id == SelectedStoreId);
        var quote = new CustomerQuoteRecord
        {
            Id = Guid.NewGuid().ToString("N"),
            CreatedUtc = DateTime.UtcNow,
            StoreId = SelectedStoreId,
            StoreName = store?.Name ?? "",
            BikeDetails = SelectedBikeDetails,
            JobIds = SelectedQuoteJobs.Select(j => j.Id).ToArray(),
            JobNames = SelectedQuoteJobs.Select(j => j.Name).ToArray(),
            ManualServiceOverrides = SelectedManualQuoteJobs
                .Where(j => _manualQuoteOverridesByJobId.TryGetValue(j.Id, out var value))
                .Select(j =>
                {
                    var value = _manualQuoteOverridesByJobId[j.Id];
                    return new CustomerQuoteManualServiceOverride
                    {
                        JobId = j.Id,
                        Minutes = Math.Max(0, value.Minutes),
                        PriceIncVat = decimal.Round(Math.Max(0m, value.PriceIncVat), 2, MidpointRounding.AwayFromZero)
                    };
                })
                .ToList(),
            EstimatedMinutes = QuoteMinutes,
            EstimatedPriceIncVat = QuotePrice,
            Notes = BuildBookingNotes(),
            CreatedBy = "Assessment"
        };

        var saved = await QuoteWorkflow.SaveQuoteAsync(customer.AccountNumber, quote);
        if (saved is null)
        {
            _statusMessage = "Could not save quote to customer account.";
            _statusIsError = true;
            return (null, null);
        }

        var updatedCustomer = UpsertLookupFromProfile(saved);
        if (showSuccessMessage)
        {
            _statusMessage = $"Quote saved to customer account {updatedCustomer.AccountNumber}.";
            _statusIsError = false;
        }

        return (updatedCustomer, quote);
    }

    private void RefreshRecommendations()
    {
        var recommendedIds = GetRecommendedJobs()
            .Select(j => j.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _selectedQuoteJobIds.RemoveWhere(id => !recommendedIds.Contains(id));

        if (_selectedQuoteJobIds.Count == 0)
        {
            foreach (var job in GetRecommendedJobs().Where(j => !IsServicePackage(j)).Take(4))
                _selectedQuoteJobIds.Add(job.Id);

            if (_selectedQuoteJobIds.Count == 0)
            {
                var fallbackPackage = SuggestedPackage;
                if (fallbackPackage is not null)
                    _selectedQuoteJobIds.Add(fallbackPackage.Id);
            }
        }

        SyncManualQuoteOverrides();
    }

    private void RebuildCustomerIndex()
    {
        _customerIndex.Clear();

        foreach (var profile in Data.CustomerProfiles
                     .OrderBy(c => c.LastName)
                     .ThenBy(c => c.FirstName)
                     .ThenBy(c => c.AccountNumber))
        {
            _customerIndex.Add(MapProfileToLookup(profile));
        }

        var groups = Data.Bookings
            .Where(b => _userAccess.CanAccessStore(b.StoreId))
            .Where(b =>
                !string.IsNullOrWhiteSpace(b.CustomerFirstName) ||
                !string.IsNullOrWhiteSpace(b.CustomerLastName) ||
                !string.IsNullOrWhiteSpace(b.CustomerPhone) ||
                !string.IsNullOrWhiteSpace(b.CustomerEmail))
            .GroupBy(BuildCustomerLookupKey)
            .Where(g => !string.IsNullOrWhiteSpace(g.Key))
            .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var group in groups)
        {
            var latest = group.OrderByDescending(b => b.Start).First();
            var bikes = group
                .Select(b => ParseBikeFromDetails(b.BikeDetails))
                .Where(b => b is not null)
                .Cast<CustomerBikeRow>()
                .GroupBy(GetBikeFingerprint, StringComparer.OrdinalIgnoreCase)
                .Select(g => CloneBike(g.First()))
                .ToList();

            var existing = _customerIndex.FirstOrDefault(c =>
                (!string.IsNullOrWhiteSpace(latest.CustomerAccountNumber) &&
                 c.AccountNumber.Equals(latest.CustomerAccountNumber.Trim(), StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(latest.CustomerEmail) &&
                    c.Email.Equals(latest.CustomerEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(latest.CustomerPhone) &&
                    NormalizeDigits(c.Phone).Equals(NormalizeDigits(latest.CustomerPhone), StringComparison.Ordinal)));

            if (existing is not null)
            {
                foreach (var bike in bikes)
                {
                    var fingerprint = GetBikeFingerprint(bike);
                    if (!existing.Bikes.Any(b => GetBikeFingerprint(b).Equals(fingerprint, StringComparison.OrdinalIgnoreCase)))
                        existing.Bikes.Add(CloneBike(bike));
                }
                continue;
            }

            _customerIndex.Add(new CustomerLookupRecord
            {
                AccountNumber = !string.IsNullOrWhiteSpace(latest.CustomerAccountNumber)
                    ? latest.CustomerAccountNumber.Trim()
                    : GenerateNextCustomerAccountNumber(),
                FirstName = latest.CustomerFirstName.Trim(),
                LastName = latest.CustomerLastName.Trim(),
                Phone = latest.CustomerPhone.Trim(),
                Email = latest.CustomerEmail.Trim(),
                County = "",
                Postcode = "",
                AddressLine1 = "",
                AddressLine2 = "",
                Bikes = bikes,
                Quotes = new List<CustomerQuoteRecord>(),
                Communications = new List<CustomerCommunicationRecord>()
            });
        }
    }

    private void LoadCustomerBikes(IEnumerable<CustomerBikeRow> bikes)
    {
        CustomerBikes.Clear();
        foreach (var bike in bikes)
            CustomerBikes.Add(CloneBike(bike));

        _selectedBikeId = CustomerBikes.FirstOrDefault()?.RowId;
    }

