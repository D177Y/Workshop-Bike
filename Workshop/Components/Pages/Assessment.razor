    private async Task<CustomerLookupRecord?> EnsureCustomerProfileAsync(bool showValidationError)
    {
        var first = CustomerFirstName.Trim();
        var last = CustomerLastName.Trim();
        var phone = CustomerPhone.Trim();
        if (string.IsNullOrWhiteSpace(first) || string.IsNullOrWhiteSpace(last) || string.IsNullOrWhiteSpace(phone))
        {
            if (showValidationError)
            {
                _statusMessage = "Customer first name, last name and phone are required.";
                _statusIsError = true;
            }

            return null;
        }

        var account = CustomerAccountNumber.Trim();

        var existing = _customerIndex.FirstOrDefault(c =>
            (!string.IsNullOrWhiteSpace(account) &&
             c.AccountNumber.Equals(account, StringComparison.OrdinalIgnoreCase))
            || (!string.IsNullOrWhiteSpace(CustomerEmail) &&
                c.Email.Equals(CustomerEmail.Trim(), StringComparison.OrdinalIgnoreCase))
            || (!string.IsNullOrWhiteSpace(CustomerPhone) &&
                NormalizeDigits(c.Phone).Equals(NormalizeDigits(CustomerPhone), StringComparison.Ordinal)));

        var customer = existing is null ? new CustomerLookupRecord() : CloneCustomer(existing);
        customer.AccountNumber = string.IsNullOrWhiteSpace(account)
            ? (existing?.AccountNumber ?? GenerateNextCustomerAccountNumber())
            : account;
        customer.FirstName = first;
        customer.LastName = last;
        customer.Phone = phone;
        customer.Email = CustomerEmail.Trim();
        customer.County = CustomerCounty.Trim();
        customer.Postcode = CustomerPostcode.Trim();
        customer.AddressLine1 = CustomerAddressLine1.Trim();
        customer.AddressLine2 = CustomerAddressLine2.Trim();
        customer.Bikes = CustomerBikes.Select(CloneBike).ToList();

        if (existing is not null)
        {
            customer.ProfileId = existing.ProfileId;
            customer.Quotes = existing.Quotes.Select(CloneQuote).ToList();
            customer.Communications = existing.Communications.Select(CloneCommunication).ToList();
        }
        else
        {
            customer.Quotes = new List<CustomerQuoteRecord>();
            customer.Communications = new List<CustomerCommunicationRecord>();
        }

        var saved = await SaveCustomerLookupAsync(customer);
        ApplyCustomerToForm(saved, copyBikes: false);
        return saved;
    }

    private async Task<CustomerLookupRecord> SaveCustomerLookupAsync(CustomerLookupRecord customer)
    {
        var profile = BuildProfileFromLookup(customer);
        var saved = await CustomerProfiles.UpsertAsync(profile);
        return UpsertLookupFromProfile(saved);
    }

    private CustomerLookupRecord UpsertLookupFromProfile(CustomerProfile profile)
    {
        var lookup = MapProfileToLookup(profile);
        var existingIndex = _customerIndex.FindIndex(c =>
            c.AccountNumber.Equals(lookup.AccountNumber, StringComparison.OrdinalIgnoreCase));

        if (existingIndex >= 0)
        {
            _customerIndex[existingIndex] = lookup;
        }
        else
        {
            _customerIndex.Add(lookup);
        }

        return lookup;
    }

    private static CustomerLookupRecord MapProfileToLookup(CustomerProfile profile)
    {
        return new CustomerLookupRecord
        {
            ProfileId = profile.Id,
            AccountNumber = profile.AccountNumber,
            FirstName = profile.FirstName,
            LastName = profile.LastName,
            Phone = profile.Phone,
            Email = profile.Email,
            County = profile.County,
            Postcode = profile.Postcode,
            AddressLine1 = profile.AddressLine1,
            AddressLine2 = profile.AddressLine2,
            Bikes = profile.Bikes
                .Select(b => new CustomerBikeRow
                {
                    RowId = string.IsNullOrWhiteSpace(b.Id) ? NewBikeRowId() : b.Id,
                    Make = b.Make,
                    Model = b.Model,
                    Size = b.Size,
                    FrameNumber = b.FrameNumber,
                    StockNumber = b.StockNumber
                })
                .Select(CloneBike)
                .ToList(),
