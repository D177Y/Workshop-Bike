@page "/super/settings/default-categories"
@attribute [Authorize(Roles = "SuperAdmin")]
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Syncfusion.Blazor.Inputs
@using Workshop.Models
@using Workshop.Services
@inject SuggestedCatalogService SuggestedCatalog
@inject IJSRuntime JS

<div class="sd-shell">
    <header class="sd-header">
        <h3>Default Categories</h3>
        <p>Manage the global service category structure used during tenant setup.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <section class="sd-flash @(IsError ? "error" : "success")">@Message</section>
    }

    <section class="sd-card">
        <div class="sd-toolbar">
            <div class="sd-filter">
                <SfTextBox Placeholder="Category filter"
                           FloatLabelType="FloatLabelType.Never"
                           @bind-Value="CategoryFilter" />
            </div>
            <span class="sd-count">@FilteredCategory1Rows.Count root categories</span>
        </div>

        @if (!CanReorderCategories)
        {
            <div class="sd-note">Clear the filter and finish inline edits to reorder categories by drag and drop.</div>
        }

        @if (FilteredCategory1Rows.Count == 0)
        {
            <div class="sd-empty">No categories match the current filter.</div>
        }
        else
        {
            <div class="root-list" @ref="RootListRef">
                @for (var i = 0; i < FilteredCategory1Rows.Count; i++)
                {
                    var root = FilteredCategory1Rows[i];
                    var subRows = SubRows(root.Category1);

                    <article class="category-card root-dnd-row"
                             data-index="@i"
                             draggable="@(CanReorderCategories ? "true" : "false")">
                        <div class="category-head">
                            <span class="drag-handle root-drag-handle" aria-hidden="true">&#9776;</span>

                            <label class="category-dot-picker" title="Edit category color">
                                <input type="color"
                                       value="@NormalizeColor(root.ColorHex)"
                                       @onchange="e => SaveRootColorAsync(root, e.Value?.ToString())" />
                                <span class="category-dot" style="@($"background:{NormalizeColor(root.ColorHex)};")"></span>
                            </label>

                            <div class="category-main">
                                @if (EditingRootId == root.Id)
                                {
                                    <input class="inline-input root-name-input"
                                           @ref="ActiveInputRef"
                                           @bind="EditingRootNameInput"
                                           @bind:event="oninput"
                                           @onblur="CommitRootEditAsync"
                                           @onkeydown="OnRootEditKeyDown" />
                                }
                                else
                                {
                                    <span class="category-name">@root.Category1</span>
                                }
                                <span class="category-meta">@subRows.Count sub-categories</span>
                            </div>

                            <div class="row-icons">
                                <button type="button" class="icon-btn edit-icon-btn" title="Edit category" @onclick="() => BeginRootEdit(root)">
                                    <i data-lucide="square-pen" class="sd-lucide" aria-hidden="true"></i>
                                </button>
                                <button type="button" class="icon-btn danger" title="Delete category" @onclick="() => DeleteRootAsync(root)">
                                    <i data-lucide="trash-2" class="sd-lucide" aria-hidden="true"></i>
                                </button>
                                <button type="button"
                                        class="icon-btn chevron-btn @(IsExpanded(root.Id) ? "expanded" : "")"
                                        title="Expand/collapse"
                                        @onclick="() => ToggleExpanded(root.Id)">
                                    <svg viewBox="0 0 24 24" class="chevron-svg" aria-hidden="true" focusable="false">
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        @if (IsExpanded(root.Id))
                        {
                            <div class="category-body">
                                <div class="sub-list" @ref="SubListRef">
                                    @for (var subIndex = 0; subIndex < subRows.Count; subIndex++)
                                    {
                                        var sub = subRows[subIndex];
                                        <div class="sub-row sub-dnd-row"
                                             data-index="@subIndex"
                                             draggable="@(CanReorderCategories ? "true" : "false")">
                                            <span class="drag-handle sub-drag-handle" aria-hidden="true">&#9776;</span>

                                            @if (EditingSubId == sub.Id)
                                            {
                                                <input class="inline-input sub-name-input"
                                                       @ref="ActiveInputRef"
                                                       @bind="EditingSubNameInput"
                                                       @bind:event="oninput"
                                                       @onblur="CommitSubEditAsync"
                                                       @onkeydown="OnSubEditKeyDown" />
                                            }
                                            else
                                            {
                                                <span class="sub-name">@sub.Category2</span>
                                            }

                                            <div class="row-icons">
                                                <button type="button" class="icon-btn edit-icon-btn" title="Edit sub-category" @onclick="() => BeginSubEdit(sub)">
                                                    <i data-lucide="square-pen" class="sd-lucide" aria-hidden="true"></i>
                                                </button>
                                                <button type="button" class="icon-btn danger" title="Delete sub-category" @onclick="() => DeleteSubAsync(sub.Id)">
                                                    <i data-lucide="trash-2" class="sd-lucide" aria-hidden="true"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }

                                    @if (IsDraftSubRow(root.Category1))
                                    {
                                        <div class="sub-row draft">
                                            <span class="drag-spacer"></span>
                                            <input class="inline-input sub-name-input"
                                                   @ref="ActiveInputRef"
                                                   placeholder="New category 2"
                                                   @bind="NewSubDraftValue"
                                                   @bind:event="oninput"
                                                   @onblur="CommitNewSubAsync"
                                                   @onkeydown="OnNewSubKeyDown" />
                                            <div class="row-icons">
                                                <button type="button" class="icon-btn danger" title="Discard new row" @onclick="ClearNewSubDraft">
                                                    <i data-lucide="trash-2" class="sd-lucide" aria-hidden="true"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }

                                    <div class="sub-list-footer">
                                        <button type="button" class="icon-btn plus" title="Add Category 2" @onclick="() => BeginNewSub(root.Category1)">
                                            <i data-lucide="plus" class="sd-lucide" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </article>
                }

                @if (IsRootDraftActive)
                {
                    <article class="category-card root-draft-card">
                        <div class="category-head">
                            <span class="drag-spacer" aria-hidden="true">&#9776;</span>
                            <label class="category-dot-picker" title="Choose color">
                                <input type="color"
                                       value="@NormalizeColor(NewRootDraftColor)"
                                       @onchange="OnRootDraftColorChanged" />
                                <span class="category-dot" style="@($"background:{NormalizeColor(NewRootDraftColor)};")"></span>
                            </label>
                            <div class="category-main">
                                <input class="inline-input root-name-input"
                                       @ref="ActiveInputRef"
                                       placeholder="New category 1"
                                       @bind="NewRootDraftName"
                                       @bind:event="oninput"
                                       @onblur="CommitNewRootDraftAsync"
                                       @onkeydown="OnNewRootDraftKeyDown" />
                            </div>
                            <div class="row-icons">
                                <button type="button" class="icon-btn danger" title="Discard new row" @onclick="ClearRootDraft">
                                    <i data-lucide="trash-2" class="sd-lucide" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    </article>
                }

                <div class="root-list-footer">
                    <button type="button" class="icon-btn plus" title="Add Category 1" @onclick="BeginNewRoot">
                        <i data-lucide="plus" class="sd-lucide" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        }
    </section>
</div>

@code {
    private const string OutsideClickBindingKey = "super-default-categories";

    private List<GlobalServiceCategory> Categories = new();
    private string Message = "";
    private bool IsError;
    private string CategoryFilter = "";

    private int? EditingRootId;
    private string EditingRootNameInput = "";
    private int? EditingSubId;
    private string EditingSubNameInput = "";

    private bool IsRootDraftActive;
    private string NewRootDraftName = "";
    private string NewRootDraftColor = "#94a3b8";

    private string NewSubDraftCategory1 = "";
    private string NewSubDraftValue = "";

    private int? ExpandedRootId;
    private bool RootExpansionInitialized;
    private bool ShouldFocusActiveInput;
    private bool IsInlineActionInFlight;
    private bool ShouldScrollActiveInputToBottom;

    private ElementReference RootListRef;
    private ElementReference SubListRef;
    private ElementReference ActiveInputRef;
    private DotNetObjectReference<SuperDefaultCategories>? DotNetRef;

    private bool CanReorderCategories =>
        string.IsNullOrWhiteSpace((CategoryFilter ?? "").Trim());

    private List<GlobalServiceCategory> Category1Rows =>
        Categories
            .Where(c => string.IsNullOrWhiteSpace(c.Category2))
            .OrderBy(c => c.SortOrder)
            .ThenBy(c => c.Category1, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private List<GlobalServiceCategory> FilteredCategory1Rows =>
        Category1Rows
            .Where(root => MatchesFilter(root.Category1))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        DotNetRef ??= DotNetObjectReference.Create(this);

        await RefreshIconsAsync();
        await EnsureOutsideBindingAsync();
        await EnsureRootDndAsync();
        await EnsureSubDndAsync();
        await FocusActiveInputAsync();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("workshopStatusDnd.unbindOutside", OutsideClickBindingKey);
        }
        catch
        {
            // No-op during shutdown.
        }

        DotNetRef?.Dispose();
    }

    private List<GlobalServiceCategory> SubRows(string category1) =>
        Categories
            .Where(c => c.Category1.Equals(category1, StringComparison.OrdinalIgnoreCase)
                        && !string.IsNullOrWhiteSpace(c.Category2))
            .OrderBy(c => c.SortOrder)
            .ThenBy(c => c.Category2, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private bool MatchesFilter(string category1)
    {
        var filter = (CategoryFilter ?? "").Trim();
        if (string.IsNullOrWhiteSpace(filter))
            return true;

        if (category1.Contains(filter, StringComparison.OrdinalIgnoreCase))
            return true;

        return SubRows(category1).Any(c => c.Category2.Contains(filter, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsExpanded(int rootId) => ExpandedRootId.HasValue && ExpandedRootId.Value == rootId;

    private void ToggleExpanded(int rootId)
    {
        ExpandedRootId = ExpandedRootId == rootId ? null : rootId;
        ClearSubEditState();
    }

    private bool IsDraftSubRow(string category1)
        => NewSubDraftCategory1.Equals(category1, StringComparison.OrdinalIgnoreCase);

    private async Task LoadAsync()
    {
        Categories = await SuggestedCatalog.GetGlobalCategoriesAsync();
        var currentRoots = Category1Rows;

        if (!RootExpansionInitialized)
        {
            ExpandedRootId = currentRoots.FirstOrDefault()?.Id;
            RootExpansionInitialized = true;
            return;
        }

        if (ExpandedRootId.HasValue && currentRoots.All(r => r.Id != ExpandedRootId.Value))
            ExpandedRootId = currentRoots.FirstOrDefault()?.Id;
    }

    private async Task RefreshIconsAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("marketingIcons.refresh");
        }
        catch
        {
            // No-op if lucide helper is unavailable.
        }
    }

    private async Task EnsureOutsideBindingAsync()
    {
        if (DotNetRef is null)
            return;

        try
        {
            await JS.InvokeVoidAsync("workshopStatusDnd.bindOutside", OutsideClickBindingKey, DotNetRef, "HandleOutsidePointerDown", ".inline-input");
        }
        catch
        {
            // No-op if outside click binding fails.
        }
    }

    private async Task EnsureRootDndAsync()
    {
        if (FilteredCategory1Rows.Count == 0 || DotNetRef is null)
            return;

        try
        {
            await JS.InvokeVoidAsync("workshopStatusDnd.init", RootListRef, DotNetRef, "ReorderRoot", ".root-dnd-row", ".root-drag-handle");
        }
        catch
        {
            // No-op if drag JS init fails.
        }
    }

    private async Task EnsureSubDndAsync()
    {
        if (!ExpandedRootId.HasValue || DotNetRef is null)
            return;

        try
        {
            await JS.InvokeVoidAsync("workshopStatusDnd.init", SubListRef, DotNetRef, "ReorderSub", ".sub-dnd-row", ".sub-drag-handle");
        }
        catch
        {
            // No-op if drag JS init fails.
        }
    }

    private async Task FocusActiveInputAsync()
    {
        if (!ShouldFocusActiveInput)
            return;

        ShouldFocusActiveInput = false;
        var scrollToBottom = ShouldScrollActiveInputToBottom;
        ShouldScrollActiveInputToBottom = false;

        try
        {
            await JS.InvokeVoidAsync("workshopStatusDnd.focusElement", ActiveInputRef, scrollToBottom, "end", 56);
        }
        catch
        {
            // No-op if focus helper fails.
        }
    }

    [JSInvokable]
    public async Task HandleOutsidePointerDown()
    {
        if (IsInlineActionInFlight)
            return;

        var didChange = false;

        if (EditingRootId.HasValue)
        {
            await CommitRootEditAsync();
            didChange = true;
        }
        else if (EditingSubId.HasValue)
        {
            await CommitSubEditAsync();
            didChange = true;
        }
        else if (!string.IsNullOrWhiteSpace(NewSubDraftCategory1))
        {
            await CommitNewSubAsync();
            didChange = true;
        }
        else if (IsRootDraftActive)
        {
            await CommitNewRootDraftAsync();
            didChange = true;
        }

        if (didChange)
            await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task ReorderRoot(int fromIndex, int toIndex)
    {
        if (!CanReorderCategories)
            return;

        var ordered = Category1Rows.ToList();
        if (fromIndex < 0 || toIndex < 0 || fromIndex >= ordered.Count || toIndex >= ordered.Count || fromIndex == toIndex)
            return;

        var moved = ordered[fromIndex];
        ordered.RemoveAt(fromIndex);
        ordered.Insert(toIndex, moved);

        await PersistRootOrderAsync(ordered);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task ReorderSub(int fromIndex, int toIndex)
    {
        if (!CanReorderCategories || !ExpandedRootId.HasValue)
            return;

        var expandedRoot = Category1Rows.FirstOrDefault(r => r.Id == ExpandedRootId.Value);
        if (expandedRoot is null)
            return;

        var ordered = SubRows(expandedRoot.Category1);
        if (fromIndex < 0 || toIndex < 0 || fromIndex >= ordered.Count || toIndex >= ordered.Count || fromIndex == toIndex)
            return;

        var moved = ordered[fromIndex];
        ordered.RemoveAt(fromIndex);
        ordered.Insert(toIndex, moved);

        await PersistSubOrderAsync(ordered);
        await InvokeAsync(StateHasChanged);
    }

    private async Task PersistRootOrderAsync(List<GlobalServiceCategory> orderedRoots)
    {
        for (var i = 0; i < orderedRoots.Count; i++)
        {
            var root = orderedRoots[i];
            if (root.SortOrder == i)
                continue;

            root.SortOrder = i;
            await SuggestedCatalog.SaveGlobalCategoryAsync(root);
        }

        Message = "Saved category order.";
        IsError = false;
        await LoadAsync();
    }

    private async Task PersistSubOrderAsync(List<GlobalServiceCategory> orderedSubs)
    {
        for (var i = 0; i < orderedSubs.Count; i++)
        {
            var sub = orderedSubs[i];
            if (sub.SortOrder == i)
                continue;

            sub.SortOrder = i;
            await SuggestedCatalog.SaveGlobalCategoryAsync(sub);
        }

        Message = "Saved sub-category order.";
        IsError = false;
        await LoadAsync();
    }

    private void BeginNewRoot()
    {
        CancelRootEdit();
        ClearSubEditState();
        IsRootDraftActive = true;
        NewRootDraftName = "";
        NewRootDraftColor = "#94a3b8";
        ShouldFocusActiveInput = true;
        ShouldScrollActiveInputToBottom = true;
    }

    private void OnRootDraftColorChanged(ChangeEventArgs args)
    {
        NewRootDraftColor = NormalizeColor(args.Value?.ToString());
    }

    private async Task CommitNewRootDraftAsync()
    {
        if (!IsRootDraftActive || IsInlineActionInFlight)
            return;

        IsInlineActionInFlight = true;
        try
        {
            var name = (NewRootDraftName ?? "").Trim();
            if (string.IsNullOrWhiteSpace(name))
            {
                ClearRootDraft();
                return;
            }

            if (Category1Rows.Any(c => c.Category1.Equals(name, StringComparison.OrdinalIgnoreCase)))
            {
                Message = "Category 1 already exists.";
                IsError = true;
                ShouldFocusActiveInput = true;
                return;
            }

            var model = new GlobalServiceCategory
            {
                Category1 = name,
                Category2 = "",
                ColorHex = NormalizeColor(NewRootDraftColor),
                SortOrder = Category1Rows.Count
            };

            await SuggestedCatalog.SaveGlobalCategoryAsync(model);
            ClearRootDraft();
            Message = "Added category.";
            IsError = false;
            await LoadAsync();
        }
        finally
        {
            IsInlineActionInFlight = false;
        }
    }

    private async Task OnNewRootDraftKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await CommitNewRootDraftAsync();
        else if (args.Key == "Escape")
            ClearRootDraft();
    }

    private void ClearRootDraft()
    {
        IsRootDraftActive = false;
        NewRootDraftName = "";
        NewRootDraftColor = "#94a3b8";
    }

    private void BeginRootEdit(GlobalServiceCategory root)
    {
        ClearRootDraft();
        ClearSubEditState();
        EditingRootId = root.Id;
        EditingRootNameInput = root.Category1;
        ShouldFocusActiveInput = true;
        ShouldScrollActiveInputToBottom = false;
    }

    private async Task CommitRootEditAsync()
    {
        if (!EditingRootId.HasValue || IsInlineActionInFlight)
            return;

        IsInlineActionInFlight = true;
        try
        {
            var root = Category1Rows.FirstOrDefault(r => r.Id == EditingRootId.Value);
            if (root is null)
            {
                CancelRootEdit();
                return;
            }

            var updated = (EditingRootNameInput ?? "").Trim();
            if (string.IsNullOrWhiteSpace(updated))
            {
                CancelRootEdit();
                return;
            }

            if (Category1Rows.Any(c => c.Id != root.Id && c.Category1.Equals(updated, StringComparison.OrdinalIgnoreCase)))
            {
                Message = "Category 1 already exists.";
                IsError = true;
                ShouldFocusActiveInput = true;
                return;
            }

            var original = root.Category1;
            if (original.Equals(updated, StringComparison.OrdinalIgnoreCase))
            {
                CancelRootEdit();
                return;
            }

            var relatedRows = Categories
                .Where(c => c.Category1.Equals(original, StringComparison.OrdinalIgnoreCase))
                .ToList();

            foreach (var row in relatedRows)
            {
                row.Category1 = updated;
                await SuggestedCatalog.SaveGlobalCategoryAsync(row);
            }

            CancelRootEdit();
            Message = "Saved category.";
            IsError = false;
            await LoadAsync();
        }
        finally
        {
            IsInlineActionInFlight = false;
        }
    }

    private async Task OnRootEditKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await CommitRootEditAsync();
        else if (args.Key == "Escape")
            CancelRootEdit();
    }

    private void CancelRootEdit()
    {
        EditingRootId = null;
        EditingRootNameInput = "";
    }

    private async Task SaveRootColorAsync(GlobalServiceCategory root, string? rawColor)
    {
        var color = NormalizeColor(rawColor);
        var relatedRows = Categories
            .Where(c => c.Category1.Equals(root.Category1, StringComparison.OrdinalIgnoreCase))
            .ToList();

        var changed = false;
        foreach (var row in relatedRows)
        {
            if (row.ColorHex.Equals(color, StringComparison.OrdinalIgnoreCase))
                continue;

            row.ColorHex = color;
            await SuggestedCatalog.SaveGlobalCategoryAsync(row);
            changed = true;
        }

        if (changed)
            await LoadAsync();
    }

    private void BeginSubEdit(GlobalServiceCategory sub)
    {
        CancelRootEdit();
        ClearRootDraft();
        EditingSubId = sub.Id;
        EditingSubNameInput = sub.Category2;
        ClearNewSubDraft();
        ShouldFocusActiveInput = true;
        ShouldScrollActiveInputToBottom = false;
    }

    private async Task CommitSubEditAsync()
    {
        if (!EditingSubId.HasValue || IsInlineActionInFlight)
            return;

        IsInlineActionInFlight = true;
        try
        {
            var sub = Categories.FirstOrDefault(c => c.Id == EditingSubId.Value);
            if (sub is null)
            {
                CancelSubEdit();
                return;
            }

            var updated = (EditingSubNameInput ?? "").Trim();
            if (string.IsNullOrWhiteSpace(updated))
            {
                CancelSubEdit();
                return;
            }

            if (SubRows(sub.Category1).Any(s => s.Id != sub.Id && s.Category2.Equals(updated, StringComparison.OrdinalIgnoreCase)))
            {
                Message = "Category 2 already exists in this group.";
                IsError = true;
                ShouldFocusActiveInput = true;
                return;
            }

            if (sub.Category2.Equals(updated, StringComparison.OrdinalIgnoreCase))
            {
                CancelSubEdit();
                return;
            }

            sub.Category2 = updated;
            await SuggestedCatalog.SaveGlobalCategoryAsync(sub);

            CancelSubEdit();
            Message = "Saved sub-category.";
            IsError = false;
            await LoadAsync();
        }
        finally
        {
            IsInlineActionInFlight = false;
        }
    }

    private async Task OnSubEditKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await CommitSubEditAsync();
        else if (args.Key == "Escape")
            CancelSubEdit();
    }

    private void CancelSubEdit()
    {
        EditingSubId = null;
        EditingSubNameInput = "";
    }

    private void BeginNewSub(string category1)
    {
        CancelRootEdit();
        ClearRootDraft();
        CancelSubEdit();
        NewSubDraftCategory1 = category1;
        NewSubDraftValue = "";
        ShouldFocusActiveInput = true;
        ShouldScrollActiveInputToBottom = false;
    }

    private async Task CommitNewSubAsync()
    {
        if (string.IsNullOrWhiteSpace(NewSubDraftCategory1) || IsInlineActionInFlight)
            return;

        IsInlineActionInFlight = true;
        try
        {
            var root = Category1Rows.FirstOrDefault(r => r.Category1.Equals(NewSubDraftCategory1, StringComparison.OrdinalIgnoreCase));
            if (root is null)
            {
                ClearNewSubDraft();
                return;
            }

            var name = (NewSubDraftValue ?? "").Trim();
            if (string.IsNullOrWhiteSpace(name))
            {
                ClearNewSubDraft();
                return;
            }

            if (SubRows(root.Category1).Any(s => s.Category2.Equals(name, StringComparison.OrdinalIgnoreCase)))
            {
                Message = "Category 2 already exists in this group.";
                IsError = true;
                ShouldFocusActiveInput = true;
                return;
            }

            var model = new GlobalServiceCategory
            {
                Category1 = root.Category1,
                Category2 = name,
                ColorHex = NormalizeColor(root.ColorHex),
                SortOrder = SubRows(root.Category1).Count
            };

            await SuggestedCatalog.SaveGlobalCategoryAsync(model);
            ClearNewSubDraft();
            Message = "Added sub-category.";
            IsError = false;
            await LoadAsync();
        }
        finally
        {
            IsInlineActionInFlight = false;
        }
    }

    private async Task OnNewSubKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await CommitNewSubAsync();
        else if (args.Key == "Escape")
            ClearNewSubDraft();
    }

    private void ClearNewSubDraft()
    {
        NewSubDraftCategory1 = "";
        NewSubDraftValue = "";
    }

    private async Task DeleteRootAsync(GlobalServiceCategory root)
    {
        var related = Categories
            .Where(c => c.Category1.Equals(root.Category1, StringComparison.OrdinalIgnoreCase))
            .Select(c => c.Id)
            .ToList();

        foreach (var id in related)
            await SuggestedCatalog.DeleteGlobalCategoryAsync(id);

        CancelRootEdit();
        ClearSubEditState();
        Message = "Deleted category and sub-categories.";
        IsError = false;
        await LoadAsync();
    }

    private async Task DeleteSubAsync(int id)
    {
        await SuggestedCatalog.DeleteGlobalCategoryAsync(id);
        CancelSubEdit();
        ClearNewSubDraft();
        Message = "Deleted sub-category.";
        IsError = false;
        await LoadAsync();
    }

    private void ClearSubEditState()
    {
        CancelSubEdit();
        ClearNewSubDraft();
    }

    private static string NormalizeColor(string? value)
    {
        var color = (value ?? "").Trim();
        if (string.IsNullOrWhiteSpace(color))
            return "#94a3b8";
        if (!color.StartsWith("#", StringComparison.Ordinal))
            color = "#" + color;
        return color;
    }
}
