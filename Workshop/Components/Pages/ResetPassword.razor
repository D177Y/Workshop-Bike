@page "/reset-password"
@layout PublicLayout
@attribute [AllowAnonymous]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Workshop.Models
@inject UserManager<AppUser> UserManager

<section class="auth-wrapper">
    <div class="auth-card">
        <h2>Choose a new password</h2>
        <div class="section-subtitle">@Message</div>

        @if (CanReset)
        {
            <EditForm Model="_model" OnValidSubmit="HandleReset">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-row">
                    <label>New password</label>
                    <InputText class="input" type="password" @bind-Value="_model.Password" />
                </div>
                <div class="form-row">
                    <label>Confirm password</label>
                    <InputText class="input" type="password" @bind-Value="_model.ConfirmPassword" />
                </div>

                @if (!string.IsNullOrWhiteSpace(Error))
                {
                    <div style="margin:8px 0 14px; color:#b91c1c;">@Error</div>
                }

                <div style="margin-top:18px;">
                    <button class="btn solid" type="submit">Reset password</button>
                </div>
            </EditForm>
        }
    </div>
</section>

@code {
    [Parameter, SupplyParameterFromQuery]
    public int UserId { get; set; }

    [Parameter, SupplyParameterFromQuery]
    public string? Code { get; set; }

    private readonly ResetModel _model = new();
    private string Message = "Enter your new password.";
    private string Error = "";
    private bool CanReset = true;

    private async Task HandleReset()
    {
        Error = "";

        if (_model.Password != _model.ConfirmPassword)
        {
            Error = "Passwords do not match.";
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId.ToString());
        if (user is null || string.IsNullOrWhiteSpace(Code))
        {
            Message = "Invalid reset link.";
            CanReset = false;
            return;
        }

        var decoded = System.Text.Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        var result = await UserManager.ResetPasswordAsync(user, decoded, _model.Password);
        if (result.Succeeded)
        {
            Message = "Password reset. You can now log in.";
            CanReset = false;
        }
        else
        {
            Error = string.Join(" ", result.Errors.Select(e => e.Description));
        }
    }

    private sealed class ResetModel
    {
        [Required]
        [MinLength(8)]
        public string Password { get; set; } = "";

        [Required]
        [MinLength(8)]
        public string ConfirmPassword { get; set; } = "";
    }
}
