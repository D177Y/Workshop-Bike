@page "/confirm-email"
@layout PublicLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Workshop.Models
@inject UserManager<AppUser> UserManager

<section class="auth-wrapper">
    <div class="auth-card">
        <h2>Email confirmation</h2>
        <div class="section-subtitle">@Message</div>
        <div style="margin-top:18px;">
            <a class="btn solid" href="/login">Go to login</a>
        </div>
    </div>
</section>

@code {
    [Parameter, SupplyParameterFromQuery]
    public int UserId { get; set; }

    [Parameter, SupplyParameterFromQuery]
    public string? Code { get; set; }

    private string Message = "Confirming your email...";

    protected override async Task OnParametersSetAsync()
    {
        if (UserId <= 0 || string.IsNullOrWhiteSpace(Code))
        {
            Message = "Invalid confirmation link.";
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId.ToString());
        if (user is null)
        {
            Message = "Account not found.";
            return;
        }

        var decoded = System.Text.Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        var result = await UserManager.ConfirmEmailAsync(user, decoded);
        Message = result.Succeeded ? "Email confirmed. You can now log in." : "This confirmation link is no longer valid.";
    }
}
