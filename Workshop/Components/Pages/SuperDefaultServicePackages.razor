    private int NextPackageSortOrder()
        => Packages.Select(p => p.SortOrder).DefaultIfEmpty(-1).Max() + 1;

    private int GetCategory1SortOrder(string category1)
    {
        var normalized = NormalizeCategory(category1);
        return Category1Order.TryGetValue(normalized, out var order)
            ? order
            : UnknownCategoryOrder;
    }

    private int GetCategory2SortOrder(string category1, string category2)
    {
        var normalizedCategory2 = NormalizeCategory2(category2);
        var normalizedCategory1 = NormalizeCategory(category1);
        if (Category2Order.TryGetValue(normalizedCategory1, out var map)
            && map.TryGetValue(normalizedCategory2, out var order))
        {
            return order;
        }

        return UnknownCategoryOrder;
    }

    private void RefreshCategoryOrderMaps()
    {
        Category1Order = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        Category2Order = new Dictionary<string, Dictionary<string, int>>(StringComparer.OrdinalIgnoreCase);
        var nextCategory1 = 0;
        var orderedRows = Categories
            .OrderBy(c => c.SortOrder)
            .ThenBy(c => c.Category1, StringComparer.OrdinalIgnoreCase)
            .ThenBy(c => c.Category2, StringComparer.OrdinalIgnoreCase)
            .ToList();
        var rootRows = orderedRows
            .Where(c => string.IsNullOrWhiteSpace((c.Category2 ?? "").Trim()))
            .ToList();
        var subRows = orderedRows
            .Where(c => !string.IsNullOrWhiteSpace((c.Category2 ?? "").Trim()))
            .ToList();

        foreach (var root in rootRows)
        {
            var category1 = NormalizeCategory(root.Category1);
            if (Category1Order.ContainsKey(category1))
                continue;

            Category1Order[category1] = nextCategory1++;
            Category2Order[category1] = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
            {
                [NormalizeCategory2("")] = -1
            };
        }

        foreach (var sub in subRows)
        {
            var category1 = NormalizeCategory(sub.Category1);
            if (!Category1Order.ContainsKey(category1))
                Category1Order[category1] = nextCategory1++;
        }

        foreach (var sub in subRows
                     .OrderBy(c => Category1Order.TryGetValue(NormalizeCategory(c.Category1), out var order) ? order : UnknownCategoryOrder)
                     .ThenBy(c => c.SortOrder)
                     .ThenBy(c => c.Category2, StringComparer.OrdinalIgnoreCase))
        {
            var category1 = NormalizeCategory(sub.Category1);
            var category2 = NormalizeCategory2(sub.Category2);
            if (string.IsNullOrWhiteSpace((sub.Category2 ?? "").Trim()))
                continue;

            if (!Category2Order.TryGetValue(category1, out var map))
            {
                map = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
                Category2Order[category1] = map;
            }

            if (map.ContainsKey(category2))
                continue;

            map[category2] = map.Values.DefaultIfEmpty(-1).Max() + 1;
        }
    }

    private int ResolveExpandedItemCount(GlobalServicePackageTemplate package)
    {
        var visitedPath = new HashSet<int>();
        return ResolveExpandedItemCountInternal(package, visitedPath);
    }

    private int ResolveExpandedItemCountInternal(GlobalServicePackageTemplate package, HashSet<int> visitedPath)
    {
        if (!visitedPath.Add(package.Id))
            return 0;

        var count = 0;
        foreach (var item in package.Items.OrderBy(i => i.SortOrder))
        {
            if (item.ItemType == GlobalServicePackageItemType.IncludePackage && item.IncludedGlobalServicePackageTemplateId.HasValue)
            {
                var included = Packages.FirstOrDefault(p => p.Id == item.IncludedGlobalServicePackageTemplateId.Value);
                if (included is null)
                    continue;

                count += ResolveExpandedItemCountInternal(included, visitedPath);
                continue;
            }

            count++;
        }

        visitedPath.Remove(package.Id);
        return count;
    }

    private string ResolveItemName(GlobalServicePackageItemDefinition item)
    {
        switch (item.ItemType)
        {
            case GlobalServicePackageItemType.Service:
            {
                if (item.LinkedGlobalServiceTemplateId.HasValue)
                {
                    var service = Services.FirstOrDefault(s => s.Id == item.LinkedGlobalServiceTemplateId.Value);
                    if (service is not null)
                        return (service.Name ?? "").Trim();
                }

                var fallback = (item.Name ?? "").Trim();
                return string.IsNullOrWhiteSpace(fallback) ? "Linked service" : fallback;
            }

            case GlobalServicePackageItemType.IncludePackage:
            {
                if (item.IncludedGlobalServicePackageTemplateId.HasValue)
                {
                    var package = Packages.FirstOrDefault(p => p.Id == item.IncludedGlobalServicePackageTemplateId.Value);
                    if (package is not null)
                        return $"Include {package.Name}";
                }

                return "Include package";
            }

            case GlobalServicePackageItemType.Manual:
            default:
            {
                var fallback = (item.Name ?? "").Trim();
                return string.IsNullOrWhiteSpace(fallback) ? "Checklist row" : fallback;
            }
        }
    }

    private string ResolveItemMeta(GlobalServicePackageItemDefinition item)
    {
        switch (item.ItemType)
        {
            case GlobalServicePackageItemType.Service:
            {
                if (item.LinkedGlobalServiceTemplateId.HasValue)
                {
                    var service = Services.FirstOrDefault(s => s.Id == item.LinkedGlobalServiceTemplateId.Value);
                    if (service is not null)
                        return $"Service · {NormalizeCategory(service.Category1)} / {NormalizeCategory2(service.Category2)}";
                }

                return "Service";
            }

            case GlobalServicePackageItemType.IncludePackage:
            {
                if (item.IncludedGlobalServicePackageTemplateId.HasValue)
                {
                    var package = Packages.FirstOrDefault(p => p.Id == item.IncludedGlobalServicePackageTemplateId.Value);
                    if (package is not null)
                        return $"Linked package · {ResolveExpandedItemCount(package)} items";
                }

                return "Linked package";
            }

            case GlobalServicePackageItemType.Manual:
            default:
                return "Manual row";
        }
    }

    private string ResolveItemDescription(GlobalServicePackageItemDefinition item)
    {
        if (item.ItemType == GlobalServicePackageItemType.Service && item.LinkedGlobalServiceTemplateId.HasValue)
        {
            var service = Services.FirstOrDefault(s => s.Id == item.LinkedGlobalServiceTemplateId.Value);
            if (service is not null)
                return string.IsNullOrWhiteSpace((item.Description ?? "").Trim())
                    ? (service.Description ?? "").Trim()
                    : (item.Description ?? "").Trim();
        }

        return (item.Description ?? "").Trim();
    }

    private static string NormalizeCategory(string? value)
    {
        var normalized = (value ?? "").Trim();
        return string.IsNullOrWhiteSpace(normalized) ? "Uncategorized" : normalized;
    }

    private static string NormalizeCategory2(string? value)
    {
        var normalized = (value ?? "").Trim();
        return string.IsNullOrWhiteSpace(normalized) ? "General" : normalized;
    }

    private static string NormalizeSkill(string? value)
    {
        var normalized = (value ?? "").Trim();
        if (string.IsNullOrWhiteSpace(normalized))
            return "All";

        return SkillLevelValues.Contains(normalized) ? normalized : "All";
    }

    private static string FormatPackageMeta(GlobalServicePackageTemplate package)
    {
        var priceValue = package.PricingMode == ServicePricingMode.EstimatedPrice
            ? Math.Max(0m, package.EstimatedPriceIncVat)
            : Math.Max(0m, package.BasePriceIncVat);

        var modeLabel = package.PricingMode switch
        {
            ServicePricingMode.AutoRate => $"Auto ({package.AutoPricingTier})",
            ServicePricingMode.EstimatedPrice => "Estimated",
            _ => "Fixed"
        };

        return $"{"\u00A3"}{priceValue:0.##} / {Math.Max(0, package.DefaultMinutes)} mins / {modeLabel}";
    }

    private static GlobalServicePackageTemplate ClonePackage(GlobalServicePackageTemplate package)
        => new()
        {
            Id = package.Id,
            Name = (package.Name ?? "").Trim(),
            SkillLevel = NormalizeSkill(package.SkillLevel),
            Description = (package.Description ?? "").Trim(),
            DefaultMinutes = Math.Max(0, package.DefaultMinutes),
            BasePriceIncVat = decimal.Round(Math.Max(0m, package.BasePriceIncVat), 2, MidpointRounding.AwayFromZero),
            PricingMode = package.PricingMode,
            AutoPricingTier = package.AutoPricingTier,
            EstimatedPriceIncVat = decimal.Round(Math.Max(0m, package.EstimatedPriceIncVat), 2, MidpointRounding.AwayFromZero),
            SortOrder = Math.Max(0, package.SortOrder),
            Items = (package.Items ?? new List<GlobalServicePackageItemDefinition>())
                .Select(CloneItem)
                .ToList()
        };

    private static GlobalServicePackageItemDefinition CloneItem(GlobalServicePackageItemDefinition item)
        => new()
        {
            Id = string.IsNullOrWhiteSpace((item.Id ?? "").Trim()) ? Guid.NewGuid().ToString("N") : (item.Id ?? "").Trim(),
            SortOrder = Math.Max(0, item.SortOrder),
            ItemType = item.ItemType,
            Name = (item.Name ?? "").Trim(),
            Description = (item.Description ?? "").Trim(),
            LinkedGlobalServiceTemplateId = item.LinkedGlobalServiceTemplateId,
            IncludedGlobalServicePackageTemplateId = item.IncludedGlobalServicePackageTemplateId
        };

