                </div>

                <div style="margin-top:6px; font-weight:600;">Add new category</div>
                <div class="catalog-editor-row">
                    <span class="drag-handle" style="visibility:hidden;">&#8801;</span>
                    <input type="text" @bind="NewCategoryEditorName" class="editor-name" placeholder="Category name" />
                    <div class="editor-color">
                        <input type="color" @bind="NewCategoryEditorColor" />
                        <input type="text" @bind="NewCategoryEditorColor" class="editor-hex" placeholder="#RRGGBB" />
                        <button class="e-btn e-flat" type="button" @onclick="AddCategoryEditorItem">Add</button>
                    </div>
                </div>
            </div>
        </Content>
