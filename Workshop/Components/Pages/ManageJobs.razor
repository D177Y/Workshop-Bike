    [JSInvokable]
    public async Task ReorderCategory(int fromIndex, int toIndex)
    {
        if (fromIndex < 0 || toIndex < 0 || fromIndex >= CategoryEditorItems.Count || toIndex >= CategoryEditorItems.Count)
            return;

        if (fromIndex == toIndex)
            return;

        if (IsServicePackagesCategory(CategoryEditorItems[fromIndex].OriginalName))
            return;

        var item = CategoryEditorItems[fromIndex];
        CategoryEditorItems.RemoveAt(fromIndex);
        if (toIndex > fromIndex) toIndex--;
        CategoryEditorItems.Insert(toIndex, item);
        StateHasChanged();
        await SaveCategoryEdits(closeDialog: false);
    }

