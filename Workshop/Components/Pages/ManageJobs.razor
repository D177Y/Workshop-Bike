@rendermode InteractiveServer
@page "/manage-jobs"
@page "/manage-service-packages"
@attribute [Authorize]
@using System.Globalization
@using Microsoft.JSInterop
@using Workshop.Models
@using Workshop.Services
@using Syncfusion.Blazor.Popups
@using TooltipPosition = Syncfusion.Blazor.Popups.Position
@inject JobCatalogService Catalog
@inject WorkshopData Data
@inject SuggestedCatalogService SuggestedCatalog
@inject Workshop.Data.TenantContext TenantContext
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ILogger<ManageJobs> Logger

<div class="sd-shell">
    <header class="sd-header">
        <h3>@(IsServicePackagesPage ? "Manage Service Packages" : "Manage Services")</h3>
        <p>@(IsServicePackagesPage
            ? "Manage service package templates for this tenant in a dedicated page."
            : "Manage your individual service catalog grouped by categories.")</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <section class="sd-flash @(IsError ? "error" : "success")">@Message</section>
    }
@if (ShowAddForm && ((IsServicePackagesPage && IsServicePackagesEditor) || (!IsServicePackagesPage && !IsServicePackagesEditor)))
{
    <div class="add-job-section">
        <h4>@(EditingJobId is not null
            ? (IsServicePackagesEditor ? "Edit Service Package" : "Edit Service")
            : (IsServicePackagesEditor ? "Add New Service Package" : "Add New Service"))</h4>

        <div class="form-section">
            <label>Name<span class="required-asterisk">*</span></label>
            <input type="text" required @bind="NewJobName" style="width: 320px; padding: 5px;" placeholder="Enter job name" />
        </div>

        <div class="form-section">
            <label>Time (minutes)<span class="required-asterisk">*</span></label>
            <input type="number"
                   min="0"
                   required
                   @bind="NewJobMinutesInput"
                   style="width: 120px; padding: 5px;"
                   placeholder="Enter minutes" />
        </div>

        <div class="form-section">
            <label>Pricing Mode<span class="required-asterisk">*</span></label>
            <select @bind="NewJobPricingMode" style="width: 220px; padding: 5px;">
                <option value="@ServicePricingMode.AutoRate">Auto rate</option>
                <option value="@ServicePricingMode.FixedPrice">Fixed price</option>
                <option value="@ServicePricingMode.EstimatedPrice">Estimated price</option>
            </select>
        </div>

        @if (NewJobPricingMode == ServicePricingMode.AutoRate)
        {
            <div class="form-section">
                <label>Hourly Rate Tier</label>
                <select @bind="NewJobAutoPricingTier" style="width: 220px; padding: 5px;">
                    <option value="@ServiceHourlyRateTier.Default">Default</option>
                    <option value="@ServiceHourlyRateTier.Discounted">Discounted</option>
                    <option value="@ServiceHourlyRateTier.LossLeader">Loss leader</option>
                </select>
                <div style="font-size:12px; color:#666; margin-top:4px;">
                    Auto-calculated price: £@GetDraftDefaultPrice().ToString("0.00")
                </div>
            </div>
        }
        else if (NewJobPricingMode == ServicePricingMode.EstimatedPrice)
        {
            <div class="form-section">
                <label>Estimated Price<span class="required-asterisk">*</span></label>
                <input type="number"
                       min="0"
                       step="0.01"
                       required
                       @bind="NewJobEstimatedPriceInput"
                       style="width: 140px; padding: 5px;"
                       placeholder="Enter estimate" />
            </div>
        }
        else
        {
            <div class="form-section">
                <label>Price<span class="required-asterisk">*</span></label>
                <input type="number"
                       min="0"
                       step="0.01"
                       required
                       @bind="NewJobPriceInput"
                       style="width: 140px; padding: 5px;"
                       placeholder="Enter price" />
            </div>
        }

        @if (!IsServicePackagesEditor)
        {
            <div class="form-section">
                <label>Service Packages</label>
                @if (ServicePackages.Count == 0)
                {
                    <div style="color:#666;">No service packages found yet. Add a service package first.</div>
                }
                else
                {
                    var draftDefaultMinutes = GetDraftDefaultMinutes();
                    var draftDefaultPrice = GetDraftDefaultPrice();
                    <div class="package-override-table">
                        <div class="package-override-header">
                            <span></span>
                            <span>Package</span>
                            <span>Minutes</span>
                            <span>Price</span>
                        </div>
                        @foreach (var package in ServicePackages)
                        {
                            var entry = GetPackageOverrideInput(package.Id);
                            <div class="package-override-row">
                                <input type="checkbox"
                                       checked="@entry.Enabled"
                                       @onchange="e => OnPackageOverrideAvailabilityChanged(entry, e, draftDefaultMinutes, draftDefaultPrice)" />
                                <span>@package.Name</span>
                                <input type="number" min="0" @bind="entry.Minutes" disabled="@(!entry.Enabled)" />
                                <input type="number" min="0" step="0.01" @bind="entry.PriceInput" disabled="@(!entry.Enabled)" />
                            </div>
                        }
                    </div>
                    <div style="font-size:12px; color:#666; margin-top:6px;">
                        Tick a package to make this service available as an additional service in that package.
                        Unticked packages are unavailable and use 0 mins / GBP 0.00.
                    </div>
                }
            </div>
        }

        <div class="form-section">
            <label>
                <span class="label-inline">
                    Part Number
                    <SfTooltip CssClass="job-tooltip"
                               Content="Set this if you or your EPOS system uses a unique identifier for this service."
                               Position="@TooltipPosition.TopRight">
                        <span class="field-tip" tabindex="0" role="button" aria-label="Part Number help">?</span>
                    </SfTooltip>
                </span>
            </label>
            <input type="text" @bind="NewJobPartNumber" style="width: 200px; padding: 5px;" placeholder="Enter part number" />
        </div>

        <div class="form-section">
            <label>
                <span class="label-inline">
                    Category
                    <span class="required-asterisk" aria-hidden="true">*</span>
                    <SfTooltip CssClass="job-tooltip"
                               Content="Use categories to organise your available service jobs, it makes them easier to navigate and by colouring your categories, easier to read whats happening on your calendars at a glance."
                               Position="@TooltipPosition.TopRight">
                        <span class="field-tip" tabindex="0" role="button" aria-label="Category help">?</span>
                    </SfTooltip>
                </span>
            </label>
            <div class="inline-row">
                @if (IsServicePackagesEditor)
                {
                    <select @bind="NewJobCategory" disabled>
                        <option value="@ServicePackagesCategory">@ServicePackagesCategory</option>
                    </select>
                    <span style="font-size: 12px; color: #666;">
                        Service packages always use the Service Packages category.
                    </span>
                }
                else
                {
                    <select @bind="NewJobCategory">
                        @foreach (var c in GetIndividualCategoryOptions())
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                    <a class="btn btn-secondary" href="/manage-service-categories">Manage</a>
                }
            </div>
        </div>

        <div class="form-section">
            <label>Category 2</label>
            @if (IsServicePackagesEditor)
            {
                <input type="text"
                       value=""
                       style="width: 220px; padding: 5px;"
                       placeholder="Not used for service packages"
                       disabled />
            }
            else
            {
                <input type="text"
                       @bind="NewJobCategory2"
                       list="category2-options"
                       style="width: 220px; padding: 5px;"
                       placeholder="Optional sub-category" />
                <datalist id="category2-options">
                    @foreach (var option in Catalog.GetCategory2Options(NewJobCategory))
                    {
                        <option value="@option"></option>
                    }
                </datalist>
            }
        </div>

        <div class="form-section">
            <label>
                <span class="label-inline">
                    Skill Level
                    <span class="required-asterisk" aria-hidden="true">*</span>
                    <SfTooltip CssClass="job-tooltip"
                               Content="This allows you to determine what skill level of mechanic is allowed to carry out this service. Used primerrily to restrict more complex services form new mechanics. Typically bike builders are restricted to building bikes, beginners add on basic services and warranty work, intermediate you might add all but the most challenging services leaving advanced who can carry out all services."
                               Position="@TooltipPosition.TopRight">
                        <span class="field-tip" tabindex="0" role="button" aria-label="Skill Level help">?</span>
                    </SfTooltip>
                </span>
            </label>
            <div class="inline-row">
                <select @bind="NewJobSkillLevel">
                    <option value="All">All</option>
                    @foreach (var level in Catalog.SkillLevels)
                    {
                        <option value="@level">@level</option>
                    }
                </select>
                <button class="btn btn-secondary" type="button" @onclick="OpenSkillEditor">Add/Edit</button>
            </div>
            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                Higher levels can do lower-level jobs. New levels are added at the top of the ladder.
            </div>
        </div>

        <div class="form-section">
            <label>Description</label>
            <textarea @bind="NewJobDescription" rows="4" style="width: 520px; padding: 5px;"></textarea>
        </div>

        @if (IsServicePackagesEditor)
        {
            <div class="form-section">
                <label>Package Checklist</label>
                <div class="package-checklist-builder">
                    <div class="package-checklist-toolbar">
                        <select @bind="ChecklistImportSourcePackageId">
                            <option value="">Copy from existing package...</option>
                            @foreach (var package in ImportablePackageTemplates)
                            {
                                <option value="@package.Id">@package.Name</option>
                            }
                        </select>
                        <button class="btn btn-secondary"
                                type="button"
                                @onclick="ImportChecklistFromExistingPackage"
                                disabled="@string.IsNullOrWhiteSpace(ChecklistImportSourcePackageId)">
                            Import list
                        </button>
                    </div>

                    <div class="package-checklist-service-picker">
                        <input class="package-checklist-service-filter"
                               placeholder="Filter services..."
                               @bind="ChecklistServiceFilter" />
                        @foreach (var group in ChecklistServiceGroups)
                        {
                            <div class="package-checklist-service-group @(IsChecklistServiceGroupOpen(group.Key) ? "" : "group-collapsed")">
                                <button type="button"
                                        class="package-checklist-service-group-header"
                                        @onclick="() => ToggleChecklistServiceGroup(group.Key)">
                                    <span>@(IsChecklistServiceGroupOpen(group.Key) ? "?" : "?") @group.Key (@group.Value.Count)</span>
                                </button>
                                @if (IsChecklistServiceGroupOpen(group.Key))
                                {
                                    @foreach (var service in group.Value)
                                    {
                                        <div class="package-checklist-service-item">
                                            <span>@service.Name</span>
                                            <button class="btn btn-secondary"
                                                    type="button"
                                                    style="margin-right:0;"
                                                    @onclick="() => AddChecklistLinkedService(service.Id)">
                                                Add
                                            </button>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>

                    <div class="package-checklist-toolbar">
                        <input type="text"
                               @bind="ChecklistManualStepName"
                               style="width: 260px;"
                               placeholder="Manual step name" />
                        <input type="text"
                               @bind="ChecklistManualStepDescription"
                               style="width: 320px;"
                               placeholder="Manual step description (optional)" />
                        <button class="btn btn-secondary" type="button" @onclick="AddChecklistManualStep">Add manual step</button>
                    </div>

                    @if (PackageChecklistEditorItems.Count == 0)
                    {
                        <div class="package-checklist-empty">No checklist items yet. Add linked services or manual steps.</div>
                    }
                    else
                    {
                        <div id="jobs-package-checklist-list" @ref="PackageChecklistListRef" class="package-checklist-list">
                            @for (var i = 0; i < PackageChecklistEditorItems.Count; i++)
                            {
                                var itemIndex = i;
                                var item = PackageChecklistEditorItems[i];
                                var isLinked = !string.IsNullOrWhiteSpace((item.LinkedServiceJobId ?? "").Trim());
                                var itemDescription = GetChecklistItemDisplayDescription(item);
                                <div class="package-checklist-row"
                                     data-index="@i"
                                     draggable="true">
                                    <span class="drag-handle" aria-label="Drag to reorder">&#8801;</span>
                                    <div class="package-checklist-main">
                                        <span class="package-checklist-name">@GetChecklistItemDisplayName(item)</span>
                                        @if (!string.IsNullOrWhiteSpace(itemDescription))
                                        {
                                            <span class="package-checklist-description">@itemDescription</span>
                                        }
                                    </div>
                                    <span class="package-checklist-type">@(isLinked ? "Linked service" : "Manual step")</span>
                                    <button class="e-btn e-flat"
                                            style="color:#dc3545;"
                                            type="button"
                                            @onclick="() => RemoveChecklistEditorItem(itemIndex)">Delete</button>
                                </div>
                            }
                        </div>
                    }

                    <div style="font-size:12px; color:#64748b;">
                        Checklist items are mechanic reminders only. Package price/time stays on the parent package.
                    </div>
                </div>
            </div>
        }

        <div class="form-section">
            <label title="Set a colour here if you do not want to use the category colour on your calendar and want this individual service to stand out.">Service Color</label>
            <div class="inline-row">
                <input type="color" @bind="NewJobColor" />
                <input type="text" @bind="NewJobColor" style="width: 110px; padding: 5px;" placeholder="#RRGGBB" />
                <span style="font-size: 12px; color:#666;">Leave empty to use category color.</span>
            </div>
        </div>

        <div>
            <button class="btn btn-success" @onclick="SaveJob">@(EditingJobId is not null ? "Update Job" : "Add Job")</button>
            <button class="btn btn-secondary" @onclick="CancelAddEdit">Cancel</button>
        </div>
    </div>
}


    @if (!IsServicePackagesPage)
    {
        <section class="sd-card">
            <div class="sd-toolbar">
                <div class="sd-filter">
                    <input class="inline-input filter-input"
                           placeholder="Service filter"
                           @bind="ServiceFilter"
                           @bind:event="oninput" />
                </div>
                <div class="sd-toolbar-actions">
                    <span class="sd-count">@FilteredServiceCount services</span>
                    <a class="sd-btn sd-btn-ghost" href="/manage-service-categories">Manage Service Categories</a>
                    <a class="sd-btn sd-btn-ghost" href="/manage-service-packages">Manage Service Packages</a>
                    <button class="sd-btn sd-btn-primary" type="button" @onclick="ShowAddIndividualServiceForm">Add Service</button>
                </div>
            </div>

            <div class="action-strip">
                <button class="sd-btn sd-btn-ghost" type="button" @onclick="ImportSuggestedServicesOnlyAsync">Import Suggested Services</button>
                <button class="sd-btn sd-btn-ghost" type="button" @onclick="ImportSuggestedServicesAndTimesAsync">Import Suggested Services + Times</button>
                <button class="sd-btn sd-btn-ghost" type="button" @onclick="ImportSuggestedServicePricesAsync">Import Suggested Prices</button>
            </div>

            @if (FilteredIndividualServiceGroups.Count == 0)
            {
                <div class="sd-empty">No services match the current filter.</div>
            }
            else
            {
                <div class="service-group-list">
                    @foreach (var group in FilteredIndividualServiceGroups)
                    {
                        <article class="service-group-card">
                            <button type="button"
                                    class="service-group-toggle @(IsServiceGroupExpanded(group.Category1) ? "expanded" : "")"
                                    @onclick="() => ToggleServiceGroup(group.Category1)">
                                <span class="service-group-title">
                                    <span class="category-dot" style="@($"background:{GetCategoryColor(group.Category1)};")"></span>
                                    <span class="service-group-name">@group.Category1</span>
                                </span>
                                <span class="service-group-count">@group.TotalCount services</span>
                                <svg viewBox="0 0 24 24" class="service-chevron" aria-hidden="true" focusable="false">
                                    <path d="m6 9 6 6 6-6"></path>
                                </svg>
                            </button>

                            @if (IsServiceGroupExpanded(group.Category1))
                            {
                                <div class="service-subgroup-list">
                                    @foreach (var subgroup in group.Category2Groups)
                                    {
                                        var subgroupKey = BuildServiceSubgroupKey(group.Category1, subgroup.Category2);
                                        <article class="service-subgroup-card">
                                            <button type="button"
                                                    class="service-subgroup-toggle @(IsServiceSubgroupExpanded(subgroupKey) ? "expanded" : "")"
                                                    @onclick="() => ToggleServiceSubgroup(subgroupKey)">
                                                <span class="service-subgroup-name">@subgroup.Category2</span>
                                                <span class="service-subgroup-count">@subgroup.Services.Count services</span>
                                                <svg viewBox="0 0 24 24" class="service-chevron" aria-hidden="true" focusable="false">
                                                    <path d="m6 9 6 6 6-6"></path>
                                                </svg>
                                            </button>

                                            @if (IsServiceSubgroupExpanded(subgroupKey))
                                            {
                                                <div class="service-list">
                                                    @foreach (var service in subgroup.Services)
                                                    {
                                                        <article class="service-row">
                                                            <span class="service-drag-handle" aria-hidden="true">&#9776;</span>
                                                            <div class="service-main">
                                                                <span class="service-name">@service.Name</span>
                                                                <span class="service-meta">@FormatServiceMeta(service)</span>
                                                                @if (!string.IsNullOrWhiteSpace(service.Description))
                                                                {
                                                                    <span class="service-description">@service.Description</span>
                                                                }
                                                            </div>
                                                            <div class="row-icons">
                                                                <button type="button" class="icon-btn edit-icon-btn" title="Edit service" @onclick="() => EditJob(service.Id)">
                                                                    <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                                                        <path d="M12 20h9"></path>
                                                                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                                                                    </svg>
                                                                </button>
                                                                <button type="button"
                                                                        class="row-link-btn"
                                                                        title="Set package rates"
                                                                        @onclick="() => OpenPackageRatesDialog(service)">
                                                                    Rates
                                                                </button>
                                                                <button type="button" class="icon-btn danger" title="Delete service" @onclick="() => DeleteJob(service.Id)">
                                                                    <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                                                        <path d="M3 6h18"></path>
                                                                        <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"></path>
                                                                        <path d="M10 11v6"></path>
                                                                        <path d="M14 11v6"></path>
                                                                    </svg>
                                                                </button>
                                                            </div>
                                                        </article>
                                                    }
                                                </div>

                                                <div class="service-subgroup-footer">
                                                    <button type="button"
                                                            class="icon-btn plus"
                                                            title="Add service"
                                                            @onclick="() => ShowAddIndividualServiceForm(group.Category1, subgroup.Category2)">
                                                        <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                                            <path d="M12 5v14"></path>
                                                            <path d="M5 12h14"></path>
                                                        </svg>
                                                    </button>
                                                </div>
                                            }
                                        </article>
                                    }
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    }
    @if (IsServicePackagesPage)
    {
        var filteredServicePackages = FilteredServicePackages;

        <section class="sd-card">
            <div class="sd-toolbar">
                <div class="sd-filter">
                    <input class="inline-input filter-input"
                           placeholder="Package filter"
                           @bind="ServicePackageFilter"
                           @bind:event="oninput" />
                </div>
                <div class="sd-toolbar-actions">
                    <span class="sd-count">@filteredServicePackages.Count packages</span>
                    <a class="sd-btn sd-btn-ghost" href="/manage-jobs">Manage Services</a>
                    <button class="sd-btn sd-btn-primary" type="button" @onclick="ShowAddServicePackageForm">Add Service Package</button>
                </div>
            </div>

            @if (filteredServicePackages.Count == 0)
            {
                <div class="sd-empty">No service packages match the current filter.</div>
            }
            else
            {
                <div class="package-list">
                    @foreach (var package in filteredServicePackages)
                    {
                        var checklistItems = (package.PackageChecklistItems ?? new List<ServicePackageChecklistItemDefinition>())
                            .OrderBy(i => i.SortOrder)
                            .ThenBy(i => GetChecklistItemDisplayName(i), StringComparer.OrdinalIgnoreCase)
                            .ToList();
                        <article class="package-card">
                            <div class="package-head">
                                <span class="service-drag-handle" aria-hidden="true">&#9776;</span>
                                <div class="package-main">
                                    <span class="package-name">@package.Name</span>
                                    <span class="package-meta">@FormatServicePackageMeta(package) · @checklistItems.Count checklist items</span>
                                </div>
                                <div class="row-icons">
                                    <button type="button" class="icon-btn edit-icon-btn" title="Edit service package" @onclick="() => EditJob(package.Id)">
                                        <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                            <path d="M12 20h9"></path>
                                            <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                                        </svg>
                                    </button>
                                    <button type="button" class="icon-btn danger" title="Delete service package" @onclick="() => DeleteJob(package.Id)">
                                        <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                            <path d="M3 6h18"></path>
                                            <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"></path>
                                            <path d="M10 11v6"></path>
                                            <path d="M14 11v6"></path>
                                        </svg>
                                    </button>
                                    <button type="button"
                                            class="icon-btn chevron-btn @(IsServicePackageExpanded(package.Id) ? "expanded" : "")"
                                            title="Expand/collapse"
                                            @onclick="() => ToggleServicePackageExpanded(package.Id)">
                                        <svg viewBox="0 0 24 24" class="chevron-svg" aria-hidden="true" focusable="false">
                                            <path d="m6 9 6 6 6-6"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            @if (IsServicePackageExpanded(package.Id))
                            {
                                <div class="package-body">
                                    @if (!string.IsNullOrWhiteSpace((package.Description ?? "").Trim()))
                                    {
                                        <div class="package-description">@package.Description</div>
                                    }

                                    @if (checklistItems.Count == 0)
                                    {
                                        <div class="package-empty">No checklist items yet.</div>
                                    }
                                    else
                                    {
                                        <div class="package-item-list">
                                            @foreach (var item in checklistItems)
                                            {
                                                var itemDescription = GetChecklistItemDisplayDescription(item);
                                                <div class="package-item-row">
                                                    <span class="service-drag-handle" aria-hidden="true">&#9776;</span>
                                                    <div class="package-item-main">
                                                        <span class="package-item-name">@GetChecklistItemDisplayName(item)</span>
                                                        <span class="package-item-meta">@GetPackageChecklistItemMeta(item)</span>
                                                        @if (!string.IsNullOrWhiteSpace(itemDescription))
                                                        {
                                                            <span class="package-item-description">@itemDescription</span>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            <div class="package-item-footer">
                                                <button type="button"
                                                        class="icon-btn plus"
                                                        title="Add checklist items"
                                                        @onclick="() => EditJob(package.Id)">
                                                    <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                                        <path d="M12 5v14"></path>
                                                        <path d="M5 12h14"></path>
                                                    </svg>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </article>
                    }

                    <div class="package-list-footer">
                        <button type="button" class="icon-btn plus" title="Add service package" @onclick="ShowAddServicePackageForm">
                            <svg viewBox="0 0 24 24" class="sd-svg" aria-hidden="true" focusable="false">
                                <path d="M12 5v14"></path>
                                <path d="M5 12h14"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            }

        </section>
    }
</div>
<SfDialog Width="620px"
          IsModal="true"
          ShowCloseIcon="true"
          @bind-Visible="IsCategoryDialogVisible"
          Header="Manage Categories">
    <DialogTemplates>
        <Content>
            <div style="display:grid; gap:10px;">
                @if (!string.IsNullOrWhiteSpace(CategoryEditorMessage))
                {
                    <div style="color:#dc3545;">@CategoryEditorMessage</div>
