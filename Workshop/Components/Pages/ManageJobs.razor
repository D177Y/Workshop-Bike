<SfDialog Width="760px"
          IsModal="true"
          ShowCloseIcon="true"
          @bind-Visible="IsPackageRatesDialogVisible"
          Header="@PackageRatesDialogTitle">
    <DialogTemplates>
        <Content>
            @if (PackageRatesTargetJob is null)
            {
                <div style="color:#dc3545;">Service not found.</div>
            }
            else if (ServicePackages.Count == 0)
            {
                <div style="color:#666;">No service packages available yet.</div>
            }
            else
            {
                var targetDefaultMinutes = PackageRatesTargetJob?.DefaultMinutes ?? 0;
                var targetDefaultPrice = PackageRatesTargetJob?.BasePriceIncVat ?? 0m;
                <div class="package-override-table">
                    <div style="font-size:12px; color:#475569;">
                        Tick a package when this service should be available as an additional service in that package.
                        Untick it to hide the service for that package and force 0 mins / GBP 0.00.
                    </div>
                    @if (!string.IsNullOrWhiteSpace(PackageRatesDialogMessage))
                    {
                        <div style="color:#dc3545;">@PackageRatesDialogMessage</div>
                    }
                    <div class="package-override-header">
                        <span></span>
                        <span>Package</span>
                        <span>Minutes</span>
                        <span>Price</span>
                    </div>
                    @foreach (var package in ServicePackages)
                    {
                        var entry = GetPackageRatesDialogInput(package.Id);
                        <div class="package-override-row">
                            <input type="checkbox"
                                   checked="@entry.Enabled"
                                   @onchange="e => OnPackageOverrideAvailabilityChanged(entry, e, targetDefaultMinutes, targetDefaultPrice)" />
                            <span>@package.Name</span>
                            <input type="number" min="0" @bind="entry.Minutes" disabled="@(!entry.Enabled)" />
                            <input type="number" min="0" step="0.01" @bind="entry.PriceInput" disabled="@(!entry.Enabled)" />
                        </div>
                    }
                </div>
            }
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Cancel" IsPrimary="false" OnClick="ClosePackageRatesDialog" />
        <DialogButton Content="Save package settings" IsPrimary="true" OnClick="SavePackageRatesDialogAsync" />
    </DialogButtons>
</SfDialog>


@code {
    private string _message = "";
    private bool _scrollToTopRequested;
    private bool ShowAddForm;
    private bool IsError;
    private string Message
    {
        get => _message;
        set
        {
            if (_message == value) return;
            _message = value;
            _scrollToTopRequested = !string.IsNullOrWhiteSpace(value);
        }
    }

    private string? EditingJobId;
    private const string ServicePackagesCategory = "Service Packages";
    private ServiceEditorMode CurrentEditorMode = ServiceEditorMode.IndividualServices;
    private bool IsServicePackagesEditor => CurrentEditorMode == ServiceEditorMode.ServicePackages;

    private enum ServiceEditorMode
    {
        ServicePackages,
        IndividualServices
    }

    private string NewJobName = "";
    private string NewJobMinutesInput = "";
    private string NewJobPriceInput = "";
    private string NewJobEstimatedPriceInput = "";
    private ServicePricingMode NewJobPricingMode = ServicePricingMode.FixedPrice;
    private ServiceHourlyRateTier NewJobAutoPricingTier = ServiceHourlyRateTier.Default;
    private string NewJobPartNumber = "";
    private string NewJobCategory = "";
    private string NewJobCategory2 = "";
    private string NewJobSkillLevel = "All";
    private string NewJobDescription = "";
    private string NewJobColor = "";
    private List<ServicePackageChecklistItemDefinition> PackageChecklistEditorItems = new();
    private string ChecklistManualStepName = "";
    private string ChecklistManualStepDescription = "";
    private string ChecklistImportSourcePackageId = "";
    private string ChecklistServiceFilter = "";
    private readonly HashSet<string> ExpandedChecklistServiceGroups = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, PackageOverrideInput> PackageOverrideInputsByJobId = new(StringComparer.OrdinalIgnoreCase);
    private bool IsPackageRatesDialogVisible;
    private string? PackageRatesJobId;
    private string PackageRatesDialogMessage = "";
    private readonly Dictionary<string, PackageOverrideInput> PackageRatesDialogInputsByPackageId = new(StringComparer.OrdinalIgnoreCase);

    private bool IsCategoryDialogVisible;
    private string CategoryEditorMessage = "";
    private List<CategoryEditorItem> CategoryEditorItems = new();
    private string NewCategoryEditorName = "";
    private string NewCategoryEditorColor = "#94a3b8";
    private DotNetObjectReference<ManageJobs>? CategoryDotNetRef;
    private ElementReference CategoryListRef;
    private bool ShouldInitCategoryDnd;

    private bool IsSkillDialogVisible;
    private string SkillEditorMessage = "";
    private List<SkillEditorItem> SkillEditorItems = new();
    private string NewSkillEditorName = "";
    private DotNetObjectReference<ManageJobs>? SkillDotNetRef;
    private ElementReference SkillListRef;
    private bool ShouldInitSkillDnd;

    private DotNetObjectReference<ManageJobs>? PackageChecklistDotNetRef;
    private ElementReference PackageChecklistListRef;
    private bool ShouldInitPackageChecklistDnd;
    private string ServiceFilter = "";
    private string ServicePackageFilter = "";
    private bool ServiceGroupExpansionInitialized;
    private readonly HashSet<string> ExpandedServiceGroups = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> KnownServiceGroups = new(StringComparer.OrdinalIgnoreCase);
    private bool ServiceSubgroupExpansionInitialized;
    private readonly HashSet<string> ExpandedServiceSubgroups = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> KnownServiceSubgroups = new(StringComparer.OrdinalIgnoreCase);
    private bool ServicePackageExpansionInitialized;
    private readonly HashSet<string> ExpandedServicePackages = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> KnownServicePackages = new(StringComparer.OrdinalIgnoreCase);

    private string CurrentPath
    {
        get
        {
            var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
            var withoutQuery = relativePath.Split('?', '#')[0];
            if (string.IsNullOrWhiteSpace(withoutQuery))
                return "/";

            var normalized = withoutQuery.StartsWith("/", StringComparison.Ordinal)
                ? withoutQuery
                : "/" + withoutQuery;
            return normalized.Length > 1
                ? normalized.TrimEnd('/')
                : normalized;
        }
    }

    private bool IsServicePackagesPage
        => string.Equals(CurrentPath, "/manage-service-packages", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await Catalog.EnsureInitializedAsync();
        await Data.EnsureInitializedAsync();
    }

    protected override void OnParametersSet()
    {
        if (!ShowAddForm)
            return;

        if (IsServicePackagesPage && !IsServicePackagesEditor)
            CancelAddEdit();
        else if (!IsServicePackagesPage && IsServicePackagesEditor)
            CancelAddEdit();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollToTopRequested)
        {
            _scrollToTopRequested = false;
            await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
        }

        if (ShouldInitCategoryDnd)
        {
            ShouldInitCategoryDnd = false;
            await EnsureCategoryDndAsync();
        }

        if (ShouldInitSkillDnd)
        {
            ShouldInitSkillDnd = false;
            await EnsureSkillDndAsync();
        }

        if (ShouldInitPackageChecklistDnd)
        {
            ShouldInitPackageChecklistDnd = false;
            await EnsurePackageChecklistDndAsync();
        }
    }

    private void ShowAddServicePackageForm()
        => ShowAddJobForm(ServiceEditorMode.ServicePackages);

    private void ShowAddIndividualServiceForm()
        => ShowAddJobForm(ServiceEditorMode.IndividualServices);

    private void ShowAddIndividualServiceForm(string category1, string category2)
    {
        ShowAddJobForm(ServiceEditorMode.IndividualServices);
        NewJobCategory = NormalizeCategory(category1);
        var normalizedCategory2 = NormalizeCategory2(category2);
        NewJobCategory2 = normalizedCategory2.Equals("General", StringComparison.OrdinalIgnoreCase)
            ? ""
            : normalizedCategory2;
    }

    private void ShowAddJobForm(ServiceEditorMode mode)
    {
        ShowAddForm = true;
        CurrentEditorMode = mode;
        EditingJobId = null;
        NewJobName = "";
        NewJobMinutesInput = "";
        NewJobPriceInput = "";
        NewJobEstimatedPriceInput = "";
        NewJobPricingMode = ServicePricingMode.FixedPrice;
        NewJobAutoPricingTier = ServiceHourlyRateTier.Default;
        NewJobPartNumber = "";
        NewJobCategory = mode == ServiceEditorMode.ServicePackages
            ? GetServicePackagesCategoryValue()
            : GetDefaultIndividualCategory();
        NewJobCategory2 = "";
        NewJobSkillLevel = "All";
        NewJobDescription = "";
        NewJobColor = "";
        if (mode == ServiceEditorMode.IndividualServices)
        {
            InitializePackageOverrideInputs();
            PackageChecklistEditorItems = new();
            ChecklistManualStepName = "";
            ChecklistManualStepDescription = "";
            ChecklistImportSourcePackageId = "";
            ChecklistServiceFilter = "";
            ExpandedChecklistServiceGroups.Clear();
            ShouldInitPackageChecklistDnd = false;
        }
        else
        {
            PackageOverrideInputsByJobId.Clear();
            InitializePackageChecklistEditor();
        }
        Message = "";
        IsError = false;
    }

    private void EditJob(string jobId)
    {
        var job = Catalog.Jobs.FirstOrDefault(j => j.Id == jobId);
        if (job == null)
        {
            Message = "Job not found.";
            IsError = true;
            return;
        }

        ShowAddForm = true;
        CurrentEditorMode = IsServicePackagesCategory(job.Category)
            ? ServiceEditorMode.ServicePackages
            : ServiceEditorMode.IndividualServices;
        EditingJobId = jobId;
        NewJobName = job.Name;
        NewJobMinutesInput = job.DefaultMinutes.ToString(CultureInfo.InvariantCulture);
        NewJobPriceInput = FormatPriceForInput(job.BasePriceIncVat);
        NewJobEstimatedPriceInput = FormatPriceForInput(job.EstimatedPriceIncVat);
        NewJobPricingMode = job.PricingMode;
        NewJobAutoPricingTier = job.AutoPricingTier;
        NewJobPartNumber = job.PartNumber;
        NewJobCategory = IsServicePackagesCategory(job.Category)
            ? GetServicePackagesCategoryValue()
            : job.Category;
        NewJobCategory2 = IsServicePackagesCategory(job.Category) ? "" : (job.Category2 ?? "");
        NewJobSkillLevel = job.SkillLevel;
        NewJobDescription = job.Description;
        NewJobColor = job.ColorHex;
        if (CurrentEditorMode == ServiceEditorMode.IndividualServices)
        {
            InitializePackageOverrideInputs(job);
            PackageChecklistEditorItems = new();
            ChecklistManualStepName = "";
            ChecklistManualStepDescription = "";
            ChecklistImportSourcePackageId = "";
            ChecklistServiceFilter = "";
            ExpandedChecklistServiceGroups.Clear();
            ShouldInitPackageChecklistDnd = false;
        }
        else
        {
            PackageOverrideInputsByJobId.Clear();
            InitializePackageChecklistEditor(job);
        }
        Message = "";
    }

    private void CancelAddEdit()
    {
        ShowAddForm = false;
        EditingJobId = null;
        NewJobEstimatedPriceInput = "";
        NewJobPricingMode = ServicePricingMode.FixedPrice;
        NewJobAutoPricingTier = ServiceHourlyRateTier.Default;
        NewJobCategory2 = "";
        PackageOverrideInputsByJobId.Clear();
        PackageChecklistEditorItems = new();
        ChecklistManualStepName = "";
        ChecklistManualStepDescription = "";
        ChecklistImportSourcePackageId = "";
        ChecklistServiceFilter = "";
        ExpandedChecklistServiceGroups.Clear();
        ShouldInitPackageChecklistDnd = false;
        Message = "";
    }

    private List<ServiceCategory1Group> FilteredIndividualServiceGroups
    {
        get
        {
            var groups = Catalog.Jobs
                .Where(j => !IsServicePackagesCategory(NormalizeCategory(j.Category)))
                .Where(MatchesServiceFilter)
                .GroupBy(j => NormalizeCategory(j.Category), StringComparer.OrdinalIgnoreCase)
                .Select(g => new
                {
                    Group = g,
                    Category1Order = Catalog.GetCategory1SortOrder(g.Key)
                })
                .OrderBy(g => g.Category1Order)
                .ThenBy(g => g.Group.Key, StringComparer.OrdinalIgnoreCase)
                .Select(g =>
                {
                    var category1 = g.Group.Key;
                    var category2Groups = g.Group
                        .GroupBy(j => NormalizeCategory2(j.Category2), StringComparer.OrdinalIgnoreCase)
                        .Select(sub => new
                        {
                            Subgroup = sub,
                            Category2Order = Catalog.GetCategory2SortOrder(category1, sub.Key)
                        })
                        .OrderBy(sub => sub.Category2Order)
                        .ThenBy(sub => sub.Subgroup.Key, StringComparer.OrdinalIgnoreCase)
                        .Select(sub => new ServiceCategory2Group(
                            sub.Subgroup.Key,
                            Catalog.OrderJobsForDisplay(sub.Subgroup).ToList()))
                        .ToList();

                    return new ServiceCategory1Group(category1, category2Groups);
                })
                .ToList();

            SyncServiceExpansion(groups);
            return groups;
        }
    }

    private int FilteredServiceCount => FilteredIndividualServiceGroups.Sum(g => g.TotalCount);

    private List<JobDefinition> FilteredServicePackages
    {
        get
        {
            var packages = ServicePackages
                .Where(MatchesServicePackageFilter)
                .ToList();

            SyncServicePackageExpansion(packages);
            return packages;
        }
    }

    private bool MatchesServicePackageFilter(JobDefinition package)
    {
        var filter = (ServicePackageFilter ?? "").Trim();
        if (string.IsNullOrWhiteSpace(filter))
            return true;

        if ((package.Name ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
            || (package.Description ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
            || (package.PartNumber ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
            || (package.SkillLevel ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
            || GetPricingSummary(package).Contains(filter, StringComparison.OrdinalIgnoreCase))
            return true;

        var checklistItems = package.PackageChecklistItems ?? new List<ServicePackageChecklistItemDefinition>();
        return checklistItems.Any(item =>
            GetChecklistItemDisplayName(item).Contains(filter, StringComparison.OrdinalIgnoreCase)
            || GetChecklistItemDisplayDescription(item).Contains(filter, StringComparison.OrdinalIgnoreCase));
    }

    private void SyncServicePackageExpansion(List<JobDefinition> packages)
    {
        var packageIds = packages
            .Select(p => (p.Id ?? "").Trim())
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!ServicePackageExpansionInitialized)
        {
            ExpandedServicePackages.Clear();
            var firstId = packages
                .Select(p => (p.Id ?? "").Trim())
                .FirstOrDefault(id => !string.IsNullOrWhiteSpace(id));
            if (!string.IsNullOrWhiteSpace(firstId))
                ExpandedServicePackages.Add(firstId);

            KnownServicePackages.Clear();
            foreach (var id in packageIds)
                KnownServicePackages.Add(id);

            ServicePackageExpansionInitialized = true;
            return;
        }

        ExpandedServicePackages.RemoveWhere(id => !packageIds.Contains(id));
        KnownServicePackages.RemoveWhere(id => !packageIds.Contains(id));
        foreach (var id in packageIds)
        {
            if (KnownServicePackages.Add(id))
                ExpandedServicePackages.Add(id);
        }

        if (ExpandedServicePackages.Count == 0)
        {
            var firstId = packages
                .Select(p => (p.Id ?? "").Trim())
                .FirstOrDefault(id => !string.IsNullOrWhiteSpace(id));
            if (!string.IsNullOrWhiteSpace(firstId))
                ExpandedServicePackages.Add(firstId);
        }
    }

    private bool IsServicePackageExpanded(string packageId)
    {
        var normalizedId = (packageId ?? "").Trim();
        return !string.IsNullOrWhiteSpace(normalizedId)
            && ExpandedServicePackages.Contains(normalizedId);
    }

    private void ToggleServicePackageExpanded(string packageId)
    {
        var normalizedId = (packageId ?? "").Trim();
        if (string.IsNullOrWhiteSpace(normalizedId))
            return;

        if (!ExpandedServicePackages.Add(normalizedId))
            ExpandedServicePackages.Remove(normalizedId);
    }

    private bool MatchesServiceFilter(JobDefinition service)
    {
        var filter = (ServiceFilter ?? "").Trim();
        if (string.IsNullOrWhiteSpace(filter))
            return true;

        return (service.Name ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
               || (service.Category ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
               || (service.Category2 ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
               || (service.PartNumber ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
               || (service.Description ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase);
    }

    private void SyncServiceExpansion(List<ServiceCategory1Group> groups)
    {
        var allGroups = groups
            .Select(g => g.Category1)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var allSubgroups = groups
            .SelectMany(g => g.Category2Groups.Select(sub => BuildServiceSubgroupKey(g.Category1, sub.Category2)))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var forceExpandAll = !string.IsNullOrWhiteSpace((ServiceFilter ?? "").Trim());

        if (!ServiceGroupExpansionInitialized || forceExpandAll)
        {
            ExpandedServiceGroups.Clear();
            foreach (var group in allGroups)
                ExpandedServiceGroups.Add(group);
            KnownServiceGroups.Clear();
            foreach (var group in allGroups)
                KnownServiceGroups.Add(group);
            ServiceGroupExpansionInitialized = true;
        }
        else
        {
            ExpandedServiceGroups.RemoveWhere(group => !allGroups.Contains(group));
            KnownServiceGroups.RemoveWhere(group => !allGroups.Contains(group));
            foreach (var group in allGroups)
            {
                if (KnownServiceGroups.Add(group))
                    ExpandedServiceGroups.Add(group);
            }
        }

        if (!ServiceSubgroupExpansionInitialized || forceExpandAll)
        {
            ExpandedServiceSubgroups.Clear();
            foreach (var subgroup in allSubgroups)
                ExpandedServiceSubgroups.Add(subgroup);
            KnownServiceSubgroups.Clear();
            foreach (var subgroup in allSubgroups)
                KnownServiceSubgroups.Add(subgroup);
            ServiceSubgroupExpansionInitialized = true;
        }
        else
        {
            ExpandedServiceSubgroups.RemoveWhere(subgroup => !allSubgroups.Contains(subgroup));
            KnownServiceSubgroups.RemoveWhere(subgroup => !allSubgroups.Contains(subgroup));
            foreach (var subgroup in allSubgroups)
            {
                if (KnownServiceSubgroups.Add(subgroup))
                    ExpandedServiceSubgroups.Add(subgroup);
            }
        }
    }

    private bool IsServiceGroupExpanded(string category)
        => ExpandedServiceGroups.Contains(category);

    private void ToggleServiceGroup(string category)
    {
        if (!ExpandedServiceGroups.Add(category))
            ExpandedServiceGroups.Remove(category);
    }

    private string BuildServiceSubgroupKey(string category1, string category2)
        => $"{NormalizeCategory(category1)}::{NormalizeCategory2(category2)}";

    private bool IsServiceSubgroupExpanded(string subgroupKey)
        => ExpandedServiceSubgroups.Contains(subgroupKey);

    private void ToggleServiceSubgroup(string subgroupKey)
    {
        if (!ExpandedServiceSubgroups.Add(subgroupKey))
            ExpandedServiceSubgroups.Remove(subgroupKey);
    }

    private string GetCategoryColor(string category1)
    {
        if (Catalog.CategoryColors.TryGetValue(category1, out var color))
        {
            var normalized = NormalizeColor(color);
            if (!string.IsNullOrWhiteSpace(normalized))
                return normalized;
        }

        return "#94a3b8";
    }

    private string FormatServiceMeta(JobDefinition service)
    {
        var skill = string.IsNullOrWhiteSpace(service.SkillLevel) ? "All" : service.SkillLevel.Trim();
        var effectivePrice = ResolveEffectivePrice(service);
        return $"£{effectivePrice:0.00} / {Math.Max(0, service.DefaultMinutes)} mins / {GetPricingSummary(service)} / Skill: {skill}";
    }

    private string FormatServicePackageMeta(JobDefinition package)
    {
        var skill = string.IsNullOrWhiteSpace(package.SkillLevel) ? "All" : package.SkillLevel.Trim();
        var effectivePrice = ResolveEffectivePrice(package);
        return $"£{effectivePrice:0.00} / {Math.Max(0, package.DefaultMinutes)} mins / {GetPricingSummary(package)} / Skill: {skill}";
    }

    private string GetPackageChecklistItemMeta(ServicePackageChecklistItemDefinition item)
    {
        var linkedServiceId = (item.LinkedServiceJobId ?? "").Trim();
        if (string.IsNullOrWhiteSpace(linkedServiceId))
            return "Manual step";

        var linkedService = Catalog.Jobs.FirstOrDefault(j => j.Id.Equals(linkedServiceId, StringComparison.OrdinalIgnoreCase));
        if (linkedService is null)
            return "Linked service";

        return $"Linked service · {NormalizeCategory(linkedService.Category)}";
    }

    private List<JobDefinition> IndividualServicesForChecklist =>
        Catalog
            .OrderJobsForDisplay(Catalog.Jobs.Where(j => !IsServicePackagesCategory(j.Category)))
            .ToList();

    private IReadOnlyDictionary<string, List<JobDefinition>> ChecklistServiceGroups
    {
        get
        {
            return IndividualServicesForChecklist
                .Where(j => string.IsNullOrWhiteSpace(ChecklistServiceFilter)
                            || j.Name.Contains(ChecklistServiceFilter, StringComparison.OrdinalIgnoreCase))
                .GroupBy(j => NormalizeCategory(j.Category))
                .ToDictionary(
                    g => g.Key,
                    g => g.OrderBy(j => j.Name, StringComparer.OrdinalIgnoreCase).ToList(),
                    StringComparer.OrdinalIgnoreCase);
        }
    }

    private bool IsChecklistServiceGroupOpen(string key)
    {
        if (!string.IsNullOrWhiteSpace(ChecklistServiceFilter))
            return true;

        if (ExpandedChecklistServiceGroups.Count == 0)
        {
            var first = ChecklistServiceGroups.Keys.FirstOrDefault();
            return first is not null && first.Equals(key, StringComparison.OrdinalIgnoreCase);
        }

        return ExpandedChecklistServiceGroups.Contains(key);
    }

    private void ToggleChecklistServiceGroup(string key)
    {
        if (ExpandedChecklistServiceGroups.Count == 0)
        {
            var first = ChecklistServiceGroups.Keys.FirstOrDefault();
            if (!string.IsNullOrWhiteSpace(first))
                ExpandedChecklistServiceGroups.Add(first);
        }

        if (ExpandedChecklistServiceGroups.Contains(key))
            ExpandedChecklistServiceGroups.Remove(key);
        else
            ExpandedChecklistServiceGroups.Add(key);
    }

