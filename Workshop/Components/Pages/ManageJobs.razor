    private async Task SaveJob()
    {
        Message = "";
        IsError = false;

        if (string.IsNullOrWhiteSpace(NewJobName))
        {
            Message = "Job name is required.";
            IsError = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(NewJobMinutesInput))
        {
            Message = "Time is required.";
            IsError = true;
            return;
        }

        if (!int.TryParse(NewJobMinutesInput, NumberStyles.Integer, CultureInfo.CurrentCulture, out var newJobMinutes)
            && !int.TryParse(NewJobMinutesInput, NumberStyles.Integer, CultureInfo.InvariantCulture, out newJobMinutes))
        {
            Message = "Time must be a valid whole number.";
            IsError = true;
            return;
        }

        if (newJobMinutes < 0)
        {
            Message = "Time must be 0 or greater.";
            IsError = true;
            return;
        }

        decimal newJobPrice;
        decimal estimatedPrice = 0m;
        switch (NewJobPricingMode)
        {
            case ServicePricingMode.AutoRate:
                newJobPrice = RoundPrice((newJobMinutes / 60m) * ResolveDraftHourlyRate(NewJobAutoPricingTier));
                NewJobPriceInput = FormatPriceForInput(newJobPrice);
                NewJobEstimatedPriceInput = "";
                break;
            case ServicePricingMode.EstimatedPrice:
                if (string.IsNullOrWhiteSpace(NewJobEstimatedPriceInput))
                {
                    Message = "Estimated price is required.";
                    IsError = true;
                    return;
                }

                if (!TryParsePrice(NewJobEstimatedPriceInput, out estimatedPrice))
                {
                    Message = "Estimated price must be a valid number.";
                    IsError = true;
                    return;
                }

                if (estimatedPrice < 0)
                {
                    Message = "Estimated price must be 0 or greater.";
                    IsError = true;
                    return;
                }

                estimatedPrice = RoundPrice(estimatedPrice);
                newJobPrice = estimatedPrice;
                NewJobPriceInput = FormatPriceForInput(newJobPrice);
                break;
            case ServicePricingMode.FixedPrice:
            default:
                if (string.IsNullOrWhiteSpace(NewJobPriceInput))
                {
                    Message = "Price is required.";
                    IsError = true;
                    return;
                }

                if (!TryParsePrice(NewJobPriceInput, out newJobPrice))
                {
                    Message = "Price must be a valid number.";
                    IsError = true;
                    return;
                }

                if (newJobPrice < 0)
                {
                    Message = "Price must be 0 or greater.";
                    IsError = true;
                    return;
                }

                newJobPrice = RoundPrice(newJobPrice);
                NewJobEstimatedPriceInput = "";
                break;
        }

        if (IsServicePackagesEditor)
        {
            NewJobCategory = GetServicePackagesCategoryValue();
        }
        else if (IsServicePackagesCategory(NewJobCategory))
        {
            Message = "Service Packages category is only available in the Service Packages section.";
            IsError = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(NewJobCategory))
        {
            Message = "Category is required.";
            IsError = true;
            return;
        }

        NewJobCategory2 = IsServicePackagesEditor ? "" : (NewJobCategory2 ?? "").Trim();

        if (string.IsNullOrWhiteSpace(NewJobSkillLevel))
        {
            Message = "Skill level is required.";
            IsError = true;
            return;
        }

        List<JobServicePackageOverride> packageOverrides = new();
        if (!IsServicePackagesEditor)
        {
            packageOverrides = BuildPackageOverrides(newJobMinutes, newJobPrice, out var validationError);
            if (!string.IsNullOrWhiteSpace(validationError))
            {
                Message = validationError;
                IsError = true;
                return;
            }
        }

        var packageChecklistItems = IsServicePackagesEditor
            ? BuildPackageChecklistItemsFromEditor()
            : new List<ServicePackageChecklistItemDefinition>();

        if (EditingJobId is not null)
        {
            var job = Catalog.Jobs.FirstOrDefault(j => j.Id == EditingJobId);
            if (job == null)
            {
                Message = "Job not found.";
                IsError = true;
                return;
            }

            job.Name = NewJobName.Trim();
            job.DefaultMinutes = newJobMinutes;
            job.BasePriceIncVat = newJobPrice;
            job.EstimatedPriceIncVat = estimatedPrice;
            job.PricingMode = NewJobPricingMode;
            job.AutoPricingTier = NewJobAutoPricingTier;
            job.PartNumber = NewJobPartNumber.Trim();
            job.Category = NewJobCategory.Trim();
            job.Category2 = NewJobCategory2;
            job.SkillLevel = NewJobSkillLevel.Trim();
            job.Description = NewJobDescription.Trim();
            job.ColorHex = NormalizeColor(NewJobColor);
            job.PackageOverrides = IsServicePackagesEditor ? new List<JobServicePackageOverride>() : packageOverrides;
            job.PackageChecklistItems = IsServicePackagesEditor ? packageChecklistItems : new List<ServicePackageChecklistItemDefinition>();

            await Catalog.SaveJobAsync(job);
            Message = $"Job '{job.Name}' updated successfully!";
        }
        else
        {
            var newId = $"JOB_{Catalog.Jobs.Count + 1:000}";
            while (Catalog.Jobs.Any(j => j.Id.Equals(newId, StringComparison.OrdinalIgnoreCase)))
            {
                newId = $"JOB_{Catalog.Jobs.Count + 1:000}";
            }

            var newJob = new JobDefinition
            {
                Id = newId,
                Name = NewJobName.Trim(),
                DefaultMinutes = newJobMinutes,
                BasePriceIncVat = newJobPrice,
                EstimatedPriceIncVat = estimatedPrice,
                PricingMode = NewJobPricingMode,
                AutoPricingTier = NewJobAutoPricingTier,
                PartNumber = NewJobPartNumber.Trim(),
                Category = NewJobCategory.Trim(),
                Category2 = NewJobCategory2,
                SkillLevel = NewJobSkillLevel.Trim(),
                Description = NewJobDescription.Trim(),
                ColorHex = NormalizeColor(NewJobColor),
                PackageOverrides = IsServicePackagesEditor ? new List<JobServicePackageOverride>() : packageOverrides,
                PackageChecklistItems = IsServicePackagesEditor ? packageChecklistItems : new List<ServicePackageChecklistItemDefinition>()
            };

            await Catalog.SaveJobAsync(newJob);
            Message = $"Job '{NewJobName.Trim()}' added successfully!";
        }

        IsError = false;
        ShowAddForm = false;
        EditingJobId = null;
        PackageOverrideInputsByJobId.Clear();
        PackageChecklistEditorItems = new();
        ChecklistManualStepName = "";
        ChecklistManualStepDescription = "";
        ChecklistImportSourcePackageId = "";
        ChecklistServiceFilter = "";
        ExpandedChecklistServiceGroups.Clear();
    }

    private string NormalizeColor(string value)
    {
        var v = (value ?? "").Trim();
        if (string.IsNullOrWhiteSpace(v))
            return "";

        if (!v.StartsWith("#", StringComparison.Ordinal))
            v = "#" + v;

        return v;
    }

    private string NormalizeCategory(string? category)
    {
        var c = (category ?? "").Trim();
        return string.IsNullOrWhiteSpace(c) ? "Uncategorized" : c;
    }

    private static bool IsServicePackagesCategory(string? category)
        => string.Equals((category ?? "").Trim(), ServicePackagesCategory, StringComparison.OrdinalIgnoreCase);

    private string GetServicePackagesCategoryValue()
        => Catalog.Categories.FirstOrDefault(IsServicePackagesCategory) ?? ServicePackagesCategory;

    private string GetDefaultIndividualCategory()
        => Catalog
            .OrderCategories(Catalog.Categories.Where(c => !IsServicePackagesCategory(c)))
            .FirstOrDefault() ?? "";

    private List<string> GetIndividualCategoryOptions()
        => Catalog
            .OrderCategories(Catalog.Categories.Where(c => !IsServicePackagesCategory(c)))
            .ToList();

    private int GetServicePackagesCount()
        => Catalog.Jobs.Count(j => IsServicePackagesCategory(NormalizeCategory(j.Category)));

    private int GetIndividualServicesCount()
        => Catalog.Jobs.Count(j => !IsServicePackagesCategory(NormalizeCategory(j.Category)));

    private List<string> GetIndividualServiceCategories()
        => Catalog
            .OrderCategories(
                Catalog.Jobs
                    .Select(j => NormalizeCategory(j.Category))
                    .Where(c => !IsServicePackagesCategory(c)))
            .ToList();

    private List<JobDefinition> ServicePackages
        => Catalog
            .OrderJobsForDisplay(Catalog.Jobs.Where(j => IsServicePackagesCategory(j.Category)))
            .ToList();

    private void InitializePackageOverrideInputs(JobDefinition? job = null)
    {
        PackageOverrideInputsByJobId.Clear();

        var defaultMinutes = job?.DefaultMinutes
            ?? (int.TryParse(NewJobMinutesInput, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedMinutes) ? parsedMinutes : 0);
        var defaultPrice = job is not null
            ? ResolveEffectivePrice(job)
            : GetDraftDefaultPrice();

        foreach (var package in ServicePackages)
        {
            var existing = job?.PackageOverrides
                .FirstOrDefault(o => o.ServicePackageJobId.Equals(package.Id, StringComparison.OrdinalIgnoreCase));
            var available = existing?.IsAvailableAsAdditionalService ?? true;
            PackageOverrideInputsByJobId[package.Id] = new PackageOverrideInput
            {
                Enabled = available,
                Minutes = available ? (existing?.Minutes ?? defaultMinutes) : 0,
                PriceInput = FormatPriceForInput(available ? (existing?.PriceIncVat ?? defaultPrice) : 0m)
            };
        }
    }

    private PackageOverrideInput GetPackageOverrideInput(string packageJobId)
    {
        if (PackageOverrideInputsByJobId.TryGetValue(packageJobId, out var input))
            return input;

        var defaultMinutes = int.TryParse(NewJobMinutesInput, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedMinutes)
            ? Math.Max(0, parsedMinutes)
            : 0;
        var defaultPrice = GetDraftDefaultPrice();

        input = new PackageOverrideInput
        {
            Enabled = true,
            Minutes = defaultMinutes,
            PriceInput = FormatPriceForInput(defaultPrice)
        };
        PackageOverrideInputsByJobId[packageJobId] = input;
        return input;
    }

    private List<JobServicePackageOverride> BuildPackageOverrides(int defaultMinutes, decimal defaultPrice, out string validationError)
    {
        validationError = "";
        var overrides = new List<JobServicePackageOverride>();

        foreach (var package in ServicePackages)
        {
            var input = GetPackageOverrideInput(package.Id);
            if (!input.Enabled)
            {
                overrides.Add(new JobServicePackageOverride
                {
                    ServicePackageJobId = package.Id,
                    IsAvailableAsAdditionalService = false,
                    Minutes = 0,
                    PriceIncVat = 0m
                });
                continue;
            }

            if (input.Minutes < 0)
            {
                validationError = $"Minutes for {package.Name} must be 0 or greater.";
                return new List<JobServicePackageOverride>();
            }

            if (!TryParsePrice(input.PriceInput, out var packagePrice))
            {
                validationError = $"Price for {package.Name} must be a valid number.";
                return new List<JobServicePackageOverride>();
            }

            if (packagePrice < 0)
            {
                validationError = $"Price for {package.Name} must be 0 or greater.";
                return new List<JobServicePackageOverride>();
            }

            packagePrice = RoundPrice(packagePrice);
            if (input.Minutes == defaultMinutes && packagePrice == defaultPrice)
                continue;

            overrides.Add(new JobServicePackageOverride
            {
                ServicePackageJobId = package.Id,
                IsAvailableAsAdditionalService = true,
                Minutes = input.Minutes,
                PriceIncVat = packagePrice
            });
        }

        return overrides;
    }

    private string GetPackageOverrideSummary(JobDefinition job)
    {
        if (job.PackageOverrides.Count == 0)
            return "Available in all packages (default rates)";

        var labels = job.PackageOverrides
            .Select(overrideItem =>
            {
                var packageName = Catalog.Jobs.FirstOrDefault(j => j.Id.Equals(overrideItem.ServicePackageJobId, StringComparison.OrdinalIgnoreCase))?.Name
                    ?? overrideItem.ServicePackageJobId;
                return overrideItem.IsAvailableAsAdditionalService
                    ? $"{packageName}: {overrideItem.Minutes} mins / £{overrideItem.PriceIncVat:0.00}"
                    : $"{packageName}: Not available";
            })
            .ToList();

        return string.Join(Environment.NewLine, labels);
    }

    private JobDefinition? PackageRatesTargetJob =>
        string.IsNullOrWhiteSpace(PackageRatesJobId)
            ? null
            : Catalog.Jobs.FirstOrDefault(j => j.Id.Equals(PackageRatesJobId, StringComparison.OrdinalIgnoreCase));

    private string PackageRatesDialogTitle =>
        PackageRatesTargetJob is null
            ? "Set package availability and rates"
            : $"Set package availability and rates - {PackageRatesTargetJob.Name}";

    private void OpenPackageRatesDialog(JobDefinition job)
    {
        if (IsServicePackagesCategory(job.Category))
        {
            Message = "Package rates are only available on Individual Services.";
            IsError = true;
            return;
        }

        PackageRatesJobId = job.Id;
        PackageRatesDialogMessage = "";
        PackageRatesDialogInputsByPackageId.Clear();

        foreach (var package in ServicePackages)
        {
            var existing = job.PackageOverrides
                .FirstOrDefault(o => o.ServicePackageJobId.Equals(package.Id, StringComparison.OrdinalIgnoreCase));
            var available = existing?.IsAvailableAsAdditionalService ?? true;
            PackageRatesDialogInputsByPackageId[package.Id] = new PackageOverrideInput
            {
                Enabled = available,
                Minutes = available ? (existing?.Minutes ?? job.DefaultMinutes) : 0,
                PriceInput = FormatPriceForInput(available ? (existing?.PriceIncVat ?? ResolveEffectivePrice(job)) : 0m)
            };
        }

        IsPackageRatesDialogVisible = true;
    }

    private PackageOverrideInput GetPackageRatesDialogInput(string packageJobId)
    {
        if (PackageRatesDialogInputsByPackageId.TryGetValue(packageJobId, out var input))
            return input;

        var job = PackageRatesTargetJob;
        input = new PackageOverrideInput
        {
            Enabled = true,
            Minutes = job?.DefaultMinutes ?? 0,
            PriceInput = FormatPriceForInput(job is null ? 0m : ResolveEffectivePrice(job))
        };
        PackageRatesDialogInputsByPackageId[packageJobId] = input;
        return input;
    }

    private void ClosePackageRatesDialog()
    {
        IsPackageRatesDialogVisible = false;
        PackageRatesDialogMessage = "";
        PackageRatesJobId = null;
        PackageRatesDialogInputsByPackageId.Clear();
    }

    private async Task SavePackageRatesDialogAsync()
    {
        var job = PackageRatesTargetJob;
        if (job is null)
        {
            PackageRatesDialogMessage = "Service not found.";
            return;
        }

        var overrides = new List<JobServicePackageOverride>();
        foreach (var package in ServicePackages)
        {
            var input = GetPackageRatesDialogInput(package.Id);
            if (!input.Enabled)
            {
                overrides.Add(new JobServicePackageOverride
                {
                    ServicePackageJobId = package.Id,
                    IsAvailableAsAdditionalService = false,
                    Minutes = 0,
                    PriceIncVat = 0m
                });
                continue;
            }

            if (input.Minutes < 0)
            {
                PackageRatesDialogMessage = $"Minutes for {package.Name} must be 0 or greater.";
                return;
            }

            if (!TryParsePrice(input.PriceInput, out var packagePrice))
            {
                PackageRatesDialogMessage = $"Price for {package.Name} must be a valid number.";
                return;
            }

            if (packagePrice < 0)
            {
                PackageRatesDialogMessage = $"Price for {package.Name} must be 0 or greater.";
                return;
            }

            packagePrice = RoundPrice(packagePrice);
            if (input.Minutes == job.DefaultMinutes && packagePrice == ResolveEffectivePrice(job))
                continue;

            overrides.Add(new JobServicePackageOverride
            {
                ServicePackageJobId = package.Id,
                IsAvailableAsAdditionalService = true,
                Minutes = input.Minutes,
                PriceIncVat = packagePrice
            });
        }

        job.PackageOverrides = overrides;
        await Catalog.SaveJobAsync(job);

        Message = $"Saved package settings for '{job.Name}'.";
        IsError = false;
        ClosePackageRatesDialog();
    }

    private async Task ImportSuggestedServicesOnlyAsync()
    {
        await ImportSuggestedAsync(SuggestedImportMode.ServicesOnly, "Imported suggested services.");
    }

    private async Task ImportSuggestedServicesAndTimesAsync()
    {
        await ImportSuggestedAsync(SuggestedImportMode.ServicesAndTimes, "Imported suggested services and times.");
    }

    private async Task ImportSuggestedServicePricesAsync()
    {
        await ImportSuggestedAsync(SuggestedImportMode.ServicePrices, "Imported suggested prices.");
    }

    private async Task ImportSuggestedAsync(SuggestedImportMode mode, string successPrefix)
    {
        Message = "";
        IsError = false;

        var result = await SuggestedCatalog.ImportSuggestedAsync(TenantContext.TenantId, mode);
        await Catalog.ReloadAsync();
        Message = $"{successPrefix} Categories +{result.CategoriesAdded}, categories updated {result.CategoriesUpdated}, services +{result.ServicesAdded}, services updated {result.ServicesUpdated}.";
    }

    private async Task PersistInlineChange(JobDefinition job, string field, string? value)
    {
        Message = "";
        IsError = false;

        switch (field)
        {
            case nameof(JobDefinition.Name):
                if (!string.IsNullOrWhiteSpace(value))
                {
                    job.Name = value.Trim();
                }
                else
                {
                    IsError = true;
                    Message = "Job name cannot be empty.";
                }
                break;
            case nameof(JobDefinition.DefaultMinutes):
                if (int.TryParse(value, out var mins) && mins >= 0)
                {
                    job.DefaultMinutes = mins;
                }
                else
                {
                    IsError = true;
                    Message = "Time must be 0 or greater.";
                }
                break;
            case nameof(JobDefinition.BasePriceIncVat):
                if (TryParsePrice(value, out var price) && price >= 0)
                {
                    job.BasePriceIncVat = RoundPrice(price);
                }
                else
                {
                    IsError = true;
                    Message = "Price must be 0 or greater.";
                }
                break;
            case nameof(JobDefinition.PartNumber):
                job.PartNumber = (value ?? "").Trim();
                break;
            case nameof(JobDefinition.Category2):
                job.Category2 = (value ?? "").Trim();
                break;
            case nameof(JobDefinition.SkillLevel):
                if (!string.IsNullOrWhiteSpace(value))
                {
                    job.SkillLevel = value.Trim();
                }
                break;
            case nameof(JobDefinition.Description):
                job.Description = (value ?? "").Trim();
                break;
            case nameof(JobDefinition.ColorHex):
                job.ColorHex = NormalizeColor(value ?? "");
                break;
        }

        if (!IsError)
        {
            await Catalog.SaveJobAsync(job);
            Message = $"Saved changes to '{job.Name}'.";
        }
    }

    private async Task DeleteJob(string jobId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this service type?");
        if (!confirmed)
        {
            return;
        }

        var job = Catalog.Jobs.FirstOrDefault(j => j.Id == jobId);
        if (job is null)
        {
            IsError = true;
            Message = "Job not found.";
            return;
        }

        await Catalog.DeleteJobAsync(jobId);
        IsError = false;
        Message = $"Deleted '{job.Name}'.";
    }

    private decimal ResolveEffectivePrice(JobDefinition job)
    {
        var (_, price, _) = Catalog.PriceAndTime(job.Id, (string?)null);
        return RoundPrice(price);
    }

    private string GetPricingSummary(JobDefinition job)
    {
        return job.PricingMode switch
        {
            ServicePricingMode.AutoRate => $"Auto ({job.AutoPricingTier})",
            ServicePricingMode.EstimatedPrice => $"Estimated £{job.EstimatedPriceIncVat:0.00}",
            _ => $"Fixed £{job.BasePriceIncVat:0.00}"
        };
    }

    private static string NormalizeCategory2(string? category2)
    {
        var c = (category2 ?? "").Trim();
        return string.IsNullOrWhiteSpace(c) ? "General" : c;
    }

    private static decimal RoundPrice(decimal price) => decimal.Round(price, 2, MidpointRounding.AwayFromZero);

    private static string FormatPriceForInput(decimal price)
        => RoundPrice(price).ToString("0.00", CultureInfo.InvariantCulture);

    private static bool TryParsePrice(string? value, out decimal price)
    {
        const NumberStyles style = NumberStyles.AllowLeadingSign
                                   | NumberStyles.AllowDecimalPoint
                                   | NumberStyles.AllowThousands
                                   | NumberStyles.AllowLeadingWhite
                                   | NumberStyles.AllowTrailingWhite;

        return decimal.TryParse(value, style, CultureInfo.CurrentCulture, out price)
            || decimal.TryParse(value, style, CultureInfo.InvariantCulture, out price);
    }
