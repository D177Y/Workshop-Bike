<SfDialog Width="760px"
          IsModal="true"
          ShowCloseIcon="true"
          @bind-Visible="IsPackageRatesDialogVisible"
          Header="@PackageRatesDialogTitle">
    <DialogTemplates>
        <Content>
            @if (PackageRatesTargetJob is null)
            {
                <div style="color:#dc3545;">Service not found.</div>
            }
            else if (ServicePackages.Count == 0)
            {
                <div style="color:#666;">No service packages available yet.</div>
            }
            else
            {
                var targetDefaultMinutes = PackageRatesTargetJob?.DefaultMinutes ?? 0;
                var targetDefaultPrice = PackageRatesTargetJob?.BasePriceIncVat ?? 0m;
                <div class="package-override-table">
                    <div style="font-size:12px; color:#475569;">
                        Tick a package when this service should be available as an additional service in that package.
                        Untick it to hide the service for that package and force 0 mins / GBP 0.00.
                    </div>
                    @if (!string.IsNullOrWhiteSpace(PackageRatesDialogMessage))
                    {
                        <div style="color:#dc3545;">@PackageRatesDialogMessage</div>
                    }
                    <div class="package-override-header">
                        <span></span>
                        <span>Package</span>
                        <span>Minutes</span>
                        <span>Price</span>
                    </div>
                    @foreach (var package in ServicePackages)
                    {
                        var entry = GetPackageRatesDialogInput(package.Id);
                        <div class="package-override-row">
                            <input type="checkbox"
                                   checked="@entry.Enabled"
                                   @onchange="e => OnPackageOverrideAvailabilityChanged(entry, e, targetDefaultMinutes, targetDefaultPrice)" />
                            <span>@package.Name</span>
                            <input type="number" min="0" @bind="entry.Minutes" disabled="@(!entry.Enabled)" />
                            <input type="number" min="0" step="0.01" @bind="entry.PriceInput" disabled="@(!entry.Enabled)" />
                        </div>
                    }
                </div>
            }
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Cancel" IsPrimary="false" OnClick="ClosePackageRatesDialog" />
        <DialogButton Content="Save package settings" IsPrimary="true" OnClick="SavePackageRatesDialogAsync" />
    </DialogButtons>
</SfDialog>

@code {
    private string _message = "";
    private bool _scrollToTopRequested;
    private bool ShowAddForm;
    private bool IsError;
    private string Message
    {
        get => _message;
        set
        {
            if (_message == value) return;
            _message = value;
            _scrollToTopRequested = !string.IsNullOrWhiteSpace(value);
        }
    }

    private string? EditingJobId;
    private const string ServicePackagesCategory = "Service Packages";
    private ServiceEditorMode CurrentEditorMode = ServiceEditorMode.IndividualServices;
    private bool IsServicePackagesEditor => CurrentEditorMode == ServiceEditorMode.ServicePackages;

    private enum ServiceEditorMode
    {
        ServicePackages,
        IndividualServices
    }

    private string NewJobName = "";
    private string NewJobMinutesInput = "";
    private string NewJobPriceInput = "";
    private string NewJobEstimatedPriceInput = "";
    private ServicePricingMode NewJobPricingMode = ServicePricingMode.FixedPrice;
    private ServiceHourlyRateTier NewJobAutoPricingTier = ServiceHourlyRateTier.Default;
    private string NewJobPartNumber = "";
    private string NewJobCategory = "";
    private string NewJobCategory2 = "";
    private string NewJobSkillLevel = "All";
    private string NewJobDescription = "";
    private string NewJobColor = "";
    private List<ServicePackageChecklistItemDefinition> PackageChecklistEditorItems = new();
    private string ChecklistManualStepName = "";
    private string ChecklistManualStepDescription = "";
    private string ChecklistImportSourcePackageId = "";
    private string ChecklistServiceFilter = "";
    private readonly HashSet<string> ExpandedChecklistServiceGroups = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, PackageOverrideInput> PackageOverrideInputsByJobId = new(StringComparer.OrdinalIgnoreCase);
    private bool IsPackageRatesDialogVisible;
    private string? PackageRatesJobId;
    private string PackageRatesDialogMessage = "";
    private readonly Dictionary<string, PackageOverrideInput> PackageRatesDialogInputsByPackageId = new(StringComparer.OrdinalIgnoreCase);

    private bool IsCategoryDialogVisible;
    private string CategoryEditorMessage = "";
    private List<CategoryEditorItem> CategoryEditorItems = new();
    private string NewCategoryEditorName = "";
    private string NewCategoryEditorColor = "#94a3b8";
    private DotNetObjectReference<ManageJobs>? CategoryDotNetRef;
    private ElementReference CategoryListRef;
    private bool ShouldInitCategoryDnd;

    private bool IsSkillDialogVisible;
    private string SkillEditorMessage = "";
    private List<SkillEditorItem> SkillEditorItems = new();
    private string NewSkillEditorName = "";
    private DotNetObjectReference<ManageJobs>? SkillDotNetRef;
    private ElementReference SkillListRef;
    private bool ShouldInitSkillDnd;

    private DotNetObjectReference<ManageJobs>? PackageChecklistDotNetRef;
    private ElementReference PackageChecklistListRef;
    private bool ShouldInitPackageChecklistDnd;

    protected override async Task OnInitializedAsync()
    {
        await Catalog.EnsureInitializedAsync();
        await Data.EnsureInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollToTopRequested)
        {
            _scrollToTopRequested = false;
            await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
        }

        if (ShouldInitCategoryDnd)
        {
            ShouldInitCategoryDnd = false;
            await EnsureCategoryDndAsync();
        }

        if (ShouldInitSkillDnd)
        {
            ShouldInitSkillDnd = false;
            await EnsureSkillDndAsync();
        }

        if (ShouldInitPackageChecklistDnd)
        {
            ShouldInitPackageChecklistDnd = false;
            await EnsurePackageChecklistDndAsync();
        }
    }

    private void ShowAddServicePackageForm()
        => ShowAddJobForm(ServiceEditorMode.ServicePackages);

    private void ShowAddIndividualServiceForm()
        => ShowAddJobForm(ServiceEditorMode.IndividualServices);

    private void ShowAddJobForm(ServiceEditorMode mode)
    {
        ShowAddForm = true;
        CurrentEditorMode = mode;
        EditingJobId = null;
        NewJobName = "";
        NewJobMinutesInput = "";
        NewJobPriceInput = "";
        NewJobEstimatedPriceInput = "";
        NewJobPricingMode = ServicePricingMode.FixedPrice;
        NewJobAutoPricingTier = ServiceHourlyRateTier.Default;
        NewJobPartNumber = "";
        NewJobCategory = mode == ServiceEditorMode.ServicePackages
            ? GetServicePackagesCategoryValue()
            : GetDefaultIndividualCategory();
        NewJobCategory2 = "";
        NewJobSkillLevel = "All";
        NewJobDescription = "";
        NewJobColor = "";
        if (mode == ServiceEditorMode.IndividualServices)
        {
            InitializePackageOverrideInputs();
            PackageChecklistEditorItems = new();
            ChecklistManualStepName = "";
            ChecklistManualStepDescription = "";
            ChecklistImportSourcePackageId = "";
            ChecklistServiceFilter = "";
            ExpandedChecklistServiceGroups.Clear();
            ShouldInitPackageChecklistDnd = false;
        }
        else
        {
            PackageOverrideInputsByJobId.Clear();
            InitializePackageChecklistEditor();
        }
        Message = "";
        IsError = false;
    }

    private void EditJob(string jobId)
    {
        var job = Catalog.Jobs.FirstOrDefault(j => j.Id == jobId);
        if (job == null)
        {
            Message = "Job not found.";
            IsError = true;
            return;
        }

        ShowAddForm = true;
        CurrentEditorMode = IsServicePackagesCategory(job.Category)
            ? ServiceEditorMode.ServicePackages
            : ServiceEditorMode.IndividualServices;
        EditingJobId = jobId;
        NewJobName = job.Name;
        NewJobMinutesInput = job.DefaultMinutes.ToString(CultureInfo.InvariantCulture);
        NewJobPriceInput = FormatPriceForInput(job.BasePriceIncVat);
        NewJobEstimatedPriceInput = FormatPriceForInput(job.EstimatedPriceIncVat);
        NewJobPricingMode = job.PricingMode;
        NewJobAutoPricingTier = job.AutoPricingTier;
        NewJobPartNumber = job.PartNumber;
        NewJobCategory = IsServicePackagesCategory(job.Category)
            ? GetServicePackagesCategoryValue()
            : job.Category;
        NewJobCategory2 = IsServicePackagesCategory(job.Category) ? "" : (job.Category2 ?? "");
        NewJobSkillLevel = job.SkillLevel;
        NewJobDescription = job.Description;
        NewJobColor = job.ColorHex;
        if (CurrentEditorMode == ServiceEditorMode.IndividualServices)
        {
            InitializePackageOverrideInputs(job);
            PackageChecklistEditorItems = new();
            ChecklistManualStepName = "";
            ChecklistManualStepDescription = "";
            ChecklistImportSourcePackageId = "";
            ChecklistServiceFilter = "";
            ExpandedChecklistServiceGroups.Clear();
            ShouldInitPackageChecklistDnd = false;
        }
        else
        {
            PackageOverrideInputsByJobId.Clear();
            InitializePackageChecklistEditor(job);
        }
        Message = "";
    }

    private void CancelAddEdit()
    {
        ShowAddForm = false;
        EditingJobId = null;
        NewJobEstimatedPriceInput = "";
        NewJobPricingMode = ServicePricingMode.FixedPrice;
        NewJobAutoPricingTier = ServiceHourlyRateTier.Default;
        NewJobCategory2 = "";
        PackageOverrideInputsByJobId.Clear();
        PackageChecklistEditorItems = new();
        ChecklistManualStepName = "";
        ChecklistManualStepDescription = "";
        ChecklistImportSourcePackageId = "";
        ChecklistServiceFilter = "";
        ExpandedChecklistServiceGroups.Clear();
        ShouldInitPackageChecklistDnd = false;
        Message = "";
    }

    private List<JobDefinition> IndividualServicesForChecklist =>
        Catalog.Jobs
            .Where(j => !IsServicePackagesCategory(j.Category))
            .OrderBy(j => j.Category, StringComparer.OrdinalIgnoreCase)
            .ThenBy(j => j.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private IReadOnlyDictionary<string, List<JobDefinition>> ChecklistServiceGroups
    {
        get
        {
            return IndividualServicesForChecklist
                .Where(j => string.IsNullOrWhiteSpace(ChecklistServiceFilter)
                            || j.Name.Contains(ChecklistServiceFilter, StringComparison.OrdinalIgnoreCase))
                .GroupBy(j => NormalizeCategory(j.Category))
                .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.OrderBy(j => j.Name, StringComparer.OrdinalIgnoreCase).ToList(), StringComparer.OrdinalIgnoreCase);
        }
    }

    private bool IsChecklistServiceGroupOpen(string key)
    {
        if (!string.IsNullOrWhiteSpace(ChecklistServiceFilter))
            return true;

        if (ExpandedChecklistServiceGroups.Count == 0)
        {
            var first = ChecklistServiceGroups.Keys.FirstOrDefault();
            return first is not null && first.Equals(key, StringComparison.OrdinalIgnoreCase);
        }

        return ExpandedChecklistServiceGroups.Contains(key);
    }

    private void ToggleChecklistServiceGroup(string key)
    {
        if (ExpandedChecklistServiceGroups.Count == 0)
        {
            var first = ChecklistServiceGroups.Keys.FirstOrDefault();
            if (!string.IsNullOrWhiteSpace(first))
                ExpandedChecklistServiceGroups.Add(first);
        }

        if (ExpandedChecklistServiceGroups.Contains(key))
            ExpandedChecklistServiceGroups.Remove(key);
        else
            ExpandedChecklistServiceGroups.Add(key);
    }

    private List<JobDefinition> ImportablePackageTemplates =>
        ServicePackages
            .Where(p => string.IsNullOrWhiteSpace(EditingJobId) || !p.Id.Equals(EditingJobId, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private void InitializePackageChecklistEditor(JobDefinition? sourcePackage = null)
    {
        PackageChecklistEditorItems = (sourcePackage?.PackageChecklistItems ?? new List<ServicePackageChecklistItemDefinition>())
