    private sealed class PackageOverrideInput
    {
        public bool Enabled { get; set; }
        public int Minutes { get; set; }
        public string PriceInput { get; set; } = "0.00";
    }

    private int GetDraftDefaultMinutes()
        => int.TryParse(NewJobMinutesInput, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedMinutes)
            ? Math.Max(0, parsedMinutes)
            : 0;

    private decimal GetDraftDefaultPrice()
    {
        return NewJobPricingMode switch
        {
            ServicePricingMode.AutoRate => RoundPrice((GetDraftDefaultMinutes() / 60m) * ResolveDraftHourlyRate(NewJobAutoPricingTier)),
            ServicePricingMode.EstimatedPrice => TryParsePrice(NewJobEstimatedPriceInput, out var estimatedPrice)
                ? RoundPrice(estimatedPrice)
                : 0m,
            _ => TryParsePrice(NewJobPriceInput, out var parsedPrice)
                ? RoundPrice(parsedPrice)
                : 0m
        };
    }

    private decimal ResolveDraftHourlyRate(ServiceHourlyRateTier tier)
    {
        return tier switch
        {
            ServiceHourlyRateTier.Discounted => Catalog.DiscountedHourlyRate,
            ServiceHourlyRateTier.LossLeader => Catalog.LossLeaderHourlyRate,
            _ => Catalog.DefaultHourlyRate
        };
    }

    private void OnPackageOverrideAvailabilityChanged(
        PackageOverrideInput input,
        Microsoft.AspNetCore.Components.ChangeEventArgs e,
        int defaultMinutes,
        decimal defaultPrice)
    {
        var enabled = e?.Value is bool value && value;
        input.Enabled = enabled;

        if (enabled)
        {
            if (input.Minutes <= 0)
                input.Minutes = Math.Max(0, defaultMinutes);

            if (!TryParsePrice(input.PriceInput, out var parsedPrice) || parsedPrice <= 0)
                input.PriceInput = FormatPriceForInput(defaultPrice);
        }
        else
        {
            input.Minutes = 0;
            input.PriceInput = FormatPriceForInput(0m);
        }
    }

