                <div style="font-weight:600;">Existing categories</div>
                <div id="jobs-category-editor-list" @ref="CategoryListRef">
                    @for (var i = 0; i < CategoryEditorItems.Count; i++)
                    {
                        var itemIndex = i;
                        var item = CategoryEditorItems[i];
                        var isServicePackages = IsServicePackagesCategory(item.OriginalName);
                        <div class="catalog-editor-row"
                             data-index="@i"
                             draggable="@(!isServicePackages)">
                            <span class="drag-handle" aria-label="Drag to reorder">&#8801;</span>
                            <input type="text" @bind="item.Name" class="editor-name" disabled="@isServicePackages" />
                            <div class="editor-color">
                                <input type="color" @bind="item.ColorHex" />
                                <input type="text" @bind="item.ColorHex" class="editor-hex" placeholder="#RRGGBB" />
                                <button class="e-btn e-flat"
                                        style="color:#dc3545;"
                                        type="button"
                                        @onclick="() => RemoveCategoryEditorItem(itemIndex)"
                                        disabled="@isServicePackages">Delete</button>
