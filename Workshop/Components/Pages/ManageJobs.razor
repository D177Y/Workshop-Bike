    private async Task SaveCategoryEdits(bool closeDialog = true)
    {
        var names = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var hasServicePackages = false;

        foreach (var item in CategoryEditorItems)
        {
            item.Name = (item.Name ?? "").Trim();
            item.ColorHex = NormalizeColor(item.ColorHex);

            if (string.IsNullOrWhiteSpace(item.Name))
            {
                CategoryEditorMessage = "Category names cannot be empty.";
                return;
            }

            if (!names.Add(item.Name))
            {
                CategoryEditorMessage = "Category names must be unique.";
                return;
            }

            if (IsServicePackagesCategory(item.OriginalName) && !IsServicePackagesCategory(item.Name))
            {
                CategoryEditorMessage = "Service Packages category name cannot be changed.";
                return;
            }

            if (IsServicePackagesCategory(item.Name))
                hasServicePackages = true;
        }

        if (!hasServicePackages)
        {
            CategoryEditorMessage = "Service Packages category is required.";
            return;
        }

        var renameMap = CategoryEditorItems
            .Where(i => !i.OriginalName.Equals(i.Name, StringComparison.OrdinalIgnoreCase))
            .ToDictionary(i => i.OriginalName, i => i.Name, StringComparer.OrdinalIgnoreCase);

        var existingNames = Catalog.CategoryColors.Keys.ToHashSet(StringComparer.OrdinalIgnoreCase);
        var newNames = CategoryEditorItems.Select(i => i.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var removed = existingNames.Except(newNames, StringComparer.OrdinalIgnoreCase).ToHashSet(StringComparer.OrdinalIgnoreCase);

        var fallbackIndividualCategory = CategoryEditorItems
            .Select(i => i.Name)
            .FirstOrDefault(n => !IsServicePackagesCategory(n)) ?? ServicePackagesCategory;

        Catalog.CategoryColors.Clear();
        foreach (var item in CategoryEditorItems)
            Catalog.CategoryColors[item.Name] = item.ColorHex;

        await Catalog.SaveSettingsAsync();

        foreach (var job in Catalog.Jobs)
        {
            var current = (job.Category ?? "").Trim();
            var updated = current;

            if (renameMap.TryGetValue(current, out var renamed))
                updated = renamed;
            else if (removed.Contains(current))
                updated = IsServicePackagesCategory(current) ? ServicePackagesCategory : fallbackIndividualCategory;

            if (updated.Equals(current, StringComparison.OrdinalIgnoreCase))
                continue;

            job.Category = updated;
            await Catalog.SaveJobAsync(job);
        }

        if (renameMap.TryGetValue(NewJobCategory, out var newCategoryName))
            NewJobCategory = newCategoryName;
        else if (removed.Contains(NewJobCategory))
            NewJobCategory = IsServicePackagesEditor ? ServicePackagesCategory : fallbackIndividualCategory;

        if (string.IsNullOrWhiteSpace(NewJobCategory))
            NewJobCategory = IsServicePackagesEditor ? ServicePackagesCategory : fallbackIndividualCategory;

        CategoryEditorItems = CategoryEditorItems
            .Select(i => new CategoryEditorItem(i.Name, i.ColorHex))
            .ToList();
        if (closeDialog)
            IsCategoryDialogVisible = false;
        CategoryEditorMessage = "";
    }

