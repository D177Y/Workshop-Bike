    private async Task SaveSkillEdits(bool closeDialog = true)
    {
        var names = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var item in SkillEditorItems)
        {
            item.Name = (item.Name ?? "").Trim();

            if (string.IsNullOrWhiteSpace(item.Name))
            {
                SkillEditorMessage = "Skill levels cannot be empty.";
                return;
            }

            if (item.Name.Equals("All", StringComparison.OrdinalIgnoreCase) ||
                item.Name.Equals("Custom", StringComparison.OrdinalIgnoreCase))
            {
                SkillEditorMessage = "'All' and 'Custom' are reserved values.";
                return;
            }

            if (!names.Add(item.Name))
            {
                SkillEditorMessage = "Skill levels must be unique.";
                return;
            }
        }

        if (SkillEditorItems.Count == 0)
        {
            SkillEditorMessage = "At least one skill level is required.";
            return;
        }

        var renameMap = SkillEditorItems
            .Where(i => !i.OriginalName.Equals(i.Name, StringComparison.OrdinalIgnoreCase))
            .ToDictionary(i => i.OriginalName, i => i.Name, StringComparer.OrdinalIgnoreCase);

        var existingLevels = Catalog.SkillLevels.ToHashSet(StringComparer.OrdinalIgnoreCase);
        var newLevels = SkillEditorItems.Select(i => i.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var removed = existingLevels.Except(newLevels, StringComparer.OrdinalIgnoreCase).ToHashSet(StringComparer.OrdinalIgnoreCase);

        var usedByJobs = Catalog.Jobs
            .Where(j => !string.IsNullOrWhiteSpace(j.SkillLevel) &&
                        !j.SkillLevel.Equals("All", StringComparison.OrdinalIgnoreCase) &&
                        removed.Contains(j.SkillLevel))
            .Select(j => j.SkillLevel)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var usedByMechanics = Data.Mechanics
            .Where(m => !string.IsNullOrWhiteSpace(m.SkillLevel) &&
                        !m.SkillLevel.Equals("Custom", StringComparison.OrdinalIgnoreCase) &&
                        removed.Contains(m.SkillLevel))
            .Select(m => m.SkillLevel)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (usedByJobs.Count > 0 || usedByMechanics.Count > 0)
        {
            var inUseLevels = usedByJobs
                .Concat(usedByMechanics)
                .Distinct(StringComparer.OrdinalIgnoreCase);
            SkillEditorMessage = $"Cannot remove skill levels in use: {string.Join(", ", inUseLevels)}";
            return;
        }

        Catalog.SkillLevels.Clear();
        foreach (var item in SkillEditorItems)
            Catalog.SkillLevels.Add(item.Name);

        await Catalog.SaveSettingsAsync();

        foreach (var job in Catalog.Jobs)
        {
            if (renameMap.TryGetValue(job.SkillLevel, out var renamed))
            {
                job.SkillLevel = renamed;
                await Catalog.SaveJobAsync(job);
            }
        }

        foreach (var mech in Data.Mechanics)
        {
            if (renameMap.TryGetValue(mech.SkillLevel, out var renamed))
            {
                mech.SkillLevel = renamed;
                await Data.SaveMechanicAsync(mech);
            }
        }

        if (renameMap.TryGetValue(NewJobSkillLevel, out var newSkillLevel))
            NewJobSkillLevel = newSkillLevel;
        else if (!NewJobSkillLevel.Equals("All", StringComparison.OrdinalIgnoreCase) &&
                 !Catalog.SkillLevels.Any(s => s.Equals(NewJobSkillLevel, StringComparison.OrdinalIgnoreCase)))
            NewJobSkillLevel = "All";

        SkillEditorItems = SkillEditorItems
            .Select(i => new SkillEditorItem(i.Name))
            .ToList();
        if (closeDialog)
            IsSkillDialogVisible = false;
        SkillEditorMessage = "";
    }

