<SfDialog Width="1160px"
          IsModal="true"
          ShowCloseIcon="true"
          Visible="@IsJobCardDialogVisible"
          Header="@JobCardDialogTitle"
          OnClose="CloseJobCard">
    <DialogTemplates>
        <Content>
            @if (JobCardEditor is null || !JobCardBookingId.HasValue)
            {
                <div>Job card unavailable.</div>
            }
            else
            {
                <div class="job-card-shell">
                    <div class="job-card-grid">
                        <div class="job-card-top">
                            <label>
                                Status
                                <select @bind="JobCardEditor.StatusName">
                                    @foreach (var status in Data.Statuses)
                                    {
                                        <option value="@status.Name">@status.Name</option>
                                    }
                                </select>
                            </label>
                            <label>
                                Assigned mechanic
                                <select @bind="JobCardEditor.AssignedMechanicId">
                                    @foreach (var mech in Mechanics.OrderBy(m => m.Name))
                                    {
                                        <option value="@mech.Id">@mech.Name</option>
                                    }
                                </select>
                            </label>
                            <label>
                                Started
                                <input value="@FormatLocalDateTime(JobCardEditor.StartedAtUtc)" readonly />
                            </label>
                        </div>

                        <div class="job-card-section">
                            <div class="job-card-section-head">
                                <h5>Services</h5>
                                <div class="job-card-section-actions">
                                    @if (IsJobCardAmendMode)
                                    {
                                        <button class="e-btn e-flat" type="button" @onclick="ResetJobCardServicesToOriginal">Reset to booked in</button>
                                    }
                                    <button class="e-btn e-primary" type="button" @onclick="ToggleJobCardAmendMode">
                                        @(IsJobCardAmendMode ? "Finish Amend" : "Amend")
                                    </button>
                                </div>
                            </div>

                            <div class="job-card-progress-summary">
                                <div class="job-card-progress-label">
                                    <span>Progress</span>
                                    <span>@GetJobCardProgress(JobCardEditor)</span>
                                </div>
                                <div class="job-card-progress-track">
                                    <div class="job-card-progress-fill" style="@GetJobCardProgressFillStyle(JobCardEditor)"></div>
                                </div>
                                <div class="job-card-progress-meta">@GetJobCardProgressMinutesLabel(JobCardEditor)</div>
                            </div>

                            <div class="job-card-services-list">
                                <div class="job-card-services-header">
                                    <span>Done</span>
                                    <span class="col-service">Service</span>
                                    <span>Description</span>
                                    <span>Mins</span>
                                    <span>Price</span>
                                    <span>@(IsJobCardAmendMode ? "Action" : "")</span>
                                </div>

                                @foreach (var service in GetJobCardTopLevelServices(JobCardEditor))
                                {
                                    var hasChecklist = IsJobCardServicePackageWithChecklist(service);
                                    var isExpanded = hasChecklist && IsPackageChecklistExpanded(service.Id);
                                    <div class="job-card-service-row">
                                        <input type="checkbox"
                                               checked="@service.IsCompleted"
                                               title="Completed"
                                               @onchange="e => ToggleJobCardServiceCompleted(service, e)" />
                                        <div class="col-service">
                                            @if (IsJobCardAmendMode)
                                            {
                                                <input type="text" @bind="service.Name" />
                                            }
                                            else
                                            {
                                                <div class="job-card-service-name-wrap">
                                                    @if (hasChecklist)
                                                    {
                                                        <button type="button"
                                                                class="job-card-expand-btn"
                                                                title="Toggle checklist"
                                                                @onclick="() => TogglePackageChecklist(service.Id)">
                                                            @(isExpanded ? "▾" : "▸")
                                                        </button>
                                                    }
                                                    <span class="job-card-service-name @(hasChecklist ? "clickable" : "")"
                                                          @onclick="() => { if (hasChecklist) TogglePackageChecklist(service.Id); }">@service.Name</span>
                                                </div>
                                            }
                                        </div>
                                        <span class="service-tag">@GetJobCardServiceDescription(service)</span>
                                        @if (IsJobCardAmendMode)
                                        {
                                            <input type="number" min="0" @bind="service.EstimatedMinutes" />
                                        }
                                        else
                                        {
                                            <span class="job-card-service-value">@Math.Max(0, service.EstimatedMinutes)</span>
                                        }
                                        @if (IsJobCardAmendMode)
                                        {
                                            <input type="number" step="0.01" min="0" @bind="service.EstimatedPriceIncVat" />
                                        }
                                        else
                                        {
                                            <span class="job-card-service-value">@Math.Max(0m, service.EstimatedPriceIncVat).ToString("C")</span>
                                        }
                                        @if (IsJobCardAmendMode)
                                        {
                                            <button class="e-btn e-flat" type="button" @onclick="() => RemoveService(service.Id)">Remove</button>
                                        }
                                        else
                                        {
                                            <span></span>
                                        }
                                    </div>

                                    @if (hasChecklist && isExpanded)
                                    {
                                        @foreach (var checklistItem in GetJobCardPackageChecklistServices(service.Id))
                                        {
                                            <div class="job-card-service-row job-card-checklist-row">
                                                <input type="checkbox"
                                                       checked="@checklistItem.IsCompleted"
                                                       title="Checklist item completed"
                                                       @onchange="e => ToggleJobCardServiceCompleted(checklistItem, e)" />
                                                <div class="col-service">
                                                    <span class="job-card-service-name">@checklistItem.Name</span>
                                                </div>
                                                <span class="service-tag">@GetJobCardServiceDescription(checklistItem)</span>
                                                <span class="job-card-service-value">-</span>
                                                <span class="job-card-service-value">-</span>
                                                <span></span>
                                            </div>
                                        }
                                    }
                                }

                                <div class="job-card-services-total">
                                    <span></span>
                                    <span>Totals</span>
                                    <span></span>
                                    <span>@GetJobCardEstimatedMinutes(JobCardEditor)</span>
                                    <span>@GetJobCardServicesTotal(JobCardEditor).ToString("C")</span>
                                    <span></span>
                                </div>
                                @if (HasJobCardTotalChanges(JobCardEditor))
                                {
                                    <div class="job-card-services-original">
                                        <span></span>
                                        <span>Booked in: @FormatJobCardTotals(JobCardOriginalMinutes, JobCardOriginalTotalPrice)</span>
                                        <span></span>
                                        <span></span>
                                        <span>@GetJobCardTotalsDeltaText(JobCardEditor)</span>
                                        <span></span>
                                    </div>
                                }
                            </div>

                            @if (IsJobCardAmendMode)
                            {
                                <div class="job-card-amend-panel">
                                    <div class="job-card-pickers">
                                        <div class="job-picker">
                                            <div class="job-picker-head">Select service or package</div>
                                            <input class="job-filter" placeholder="Filter jobs..." @bind="JobCardServiceFilter" />
                                            @foreach (var group in JobCardServiceGroups)
                                            {
                                                <div class="job-group @(IsJobCardGroupOpen(group.Key) ? "" : "group-collapsed")">
                                                    <button type="button" class="job-group-header" @onclick="() => ToggleJobCardGroup(group.Key)">
                                                        <span>@group.Key</span>
                                                        <span>@(IsJobCardGroupOpen(group.Key) ? "▾" : "▸")</span>
                                                    </button>
                                                    @if (IsJobCardGroupOpen(group.Key))
                                                    {
                                                        @foreach (var job in group.Value)
                                                        {
                                                            <label class="job-item">
                                                                <input type="checkbox"
                                                                       checked="@IsJobCardPrimaryServiceSelected(job.Id)"
                                                                       @onchange="e => ToggleJobCardService(job, e)" />
                                                                <span>@job.Name</span>
                                                                <span class="job-meta">@job.DefaultMinutes mins · £@job.BasePriceIncVat.ToString("0.00")</span>
                                                            </label>
                                                        }
                                                    }
                                                </div>
                                            }
                                        </div>

                                        @if (CanSelectJobCardPackageServices)
                                        {
                                            <div class="job-picker">
                                                <div class="job-picker-head">Select additional services</div>
                                                <input class="job-filter" placeholder="Filter services..." @bind="JobCardAdditionalServiceFilter" />
                                                @foreach (var group in JobCardAdditionalServiceGroups)
                                                {
                                                    <div class="job-group @(IsJobCardAdditionalGroupOpen(group.Key) ? "" : "group-collapsed")">
                                                        <button type="button" class="job-group-header" @onclick="() => ToggleJobCardAdditionalGroup(group.Key)">
                                                            <span>@group.Key</span>
                                                            <span>@(IsJobCardAdditionalGroupOpen(group.Key) ? "▾" : "▸")</span>
                                                        </button>
                                                        @if (IsJobCardAdditionalGroupOpen(group.Key))
                                                        {
                                                            @foreach (var service in group.Value)
                                                            {
                                                                <label class="job-item">
                                                                    <input type="checkbox"
                                                                           checked="@IsJobCardAdditionalServiceSelected(service.Id)"
                                                                           @onchange="e => ToggleJobCardAdditionalService(service.Id, e)" />
                                                                    <span>@service.Name</span>
                                                                    <span class="job-meta">@GetJobCardPackageServiceMeta(service.Id)</span>
                                                                </label>
                                                            }
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="job-card-manual-wrap">
                                        <div class="job-card-manual-title">Manually add work</div>
                                        <div class="job-card-manual-list">
                                            <div class="job-card-manual-header">
                                                <span>Description</span>
                                                <span>Mins</span>
                                                <span>Price</span>
                                                <span>Action</span>
                                            </div>
                                            <div class="job-card-add-manual">
                                                <input type="text" @bind="CustomServiceName" placeholder="Additional work found..." />
                                                <input type="number" min="0" @bind="CustomServiceMinutes" placeholder="Mins" />
                                                <input type="number" min="0" step="0.01" @bind="CustomServicePrice" placeholder="Price" />
                                                <button class="e-btn e-flat" type="button" @onclick="AddCustomService">Add manual</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="job-card-section">
                            <h5>Parts</h5>
                            <div class="job-card-warning">
                                EPOS integration is needed for live stock and pricing. Current lookup uses placeholder parts.
                            </div>

                            <div class="job-card-parts">
                                <div class="job-card-add">
                                    <input type="text" @bind="PartSearch" placeholder="Search parts by name or SKU..." />
                                    <button class="e-btn e-flat" type="button" @onclick="AddBlankPart">Add blank part</button>
                                </div>

                                @if (FilteredPartCatalog.Count > 0)
                                {
                                    <div class="job-card-lookup-results">
                                        @foreach (var part in FilteredPartCatalog)
                                        {
                                            <div class="job-card-lookup-item">
                                                <span>@part.Name (@part.Sku) - £@part.UnitPriceIncVat.ToString("0.00")</span>
                                                <button class="e-btn e-flat" type="button" @onclick="() => AddPartFromLookup(part)">Add</button>
                                            </div>
                                        }
                                    </div>
                                }

                                @for (var i = 0; i < JobCardEditor.Parts.Count; i++)
                                {
                                    var part = JobCardEditor.Parts[i];
                                    <div class="job-card-part-row">
                                        <input type="text" @bind="part.Name" placeholder="Part name" />
                                        <input type="text" @bind="part.Sku" placeholder="SKU" />
                                        <input type="number" min="0" @bind="part.Quantity" />
                                        <input type="number" min="0" step="0.01" @bind="part.UnitPriceIncVat" />
                                        <button class="e-btn e-flat" type="button" @onclick="() => RemovePart(part.Id)">Remove</button>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="job-card-section job-card-notes">
                            <label>
                                Service notes
                                <textarea rows="4" @bind="JobCardEditor.ServiceNotes"></textarea>
                            </label>
                            <label>
                                Customer notes
                                <textarea rows="4" @bind="JobCardEditor.CustomerNotes"></textarea>
                            </label>
                        </div>

                        <div class="job-card-section job-card-comms">
                            <h5>Customer communication</h5>
                            <label>
                                Draft message
                                <textarea rows="3" @bind="JobCardEditor.CommunicationDraft" placeholder="Share updates or approvals..."></textarea>
                            </label>
                            <div style="display:flex; gap:8px; flex-wrap:wrap;">
                                <button class="e-btn e-flat" type="button" @onclick="SendCustomerSms">Send SMS</button>
                                <button class="e-btn e-flat" type="button" @onclick="SendCustomerEmail">Send Email</button>
                                <span style="font-size:12px; color:#4b5563;">
                                    Last SMS: @(JobCardEditor.LastSmsSentUtc.HasValue ? FormatLocalDateTime(JobCardEditor.LastSmsSentUtc.Value) : "Never")
                                </span>
                                <span style="font-size:12px; color:#4b5563;">
                                    Last Email: @(JobCardEditor.LastEmailSentUtc.HasValue ? FormatLocalDateTime(JobCardEditor.LastEmailSentUtc.Value) : "Never")
                                </span>
                            </div>
                            @if (JobCardEditor.MessageLog.Count > 0)
                            {
                                <div class="job-card-log">
                                    @foreach (var entry in JobCardEditor.MessageLog.OrderByDescending(m => m.SentAtUtc).Take(10))
                                    {
                                        <div>@entry.Channel to @entry.Recipient at @FormatLocalDateTime(entry.SentAtUtc) - @entry.Summary</div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="job-card-actions">
                            <span class="job-card-message">@JobCardMessage</span>
                            <span style="font-size:12px; color:#4b5563;">
                                Services: @GetJobCardEstimatedMinutes(JobCardEditor) mins · Parts: @GetJobCardPartsTotal(JobCardEditor).ToString("C") · Total: @GetJobCardEstimatedTotal(JobCardEditor).ToString("C")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Close" IsPrimary="false" OnClick="CloseJobCard" />
        <DialogButton Content="Save Job Card" IsPrimary="true" OnClick="SaveJobCard" />
    </DialogButtons>
</SfDialog>

@code {
    [Parameter] public int StoreId { get; set; }

    private SfSchedule<AppointmentVM>? ScheduleRef;

    private DateTime _selectedDate = DateTime.Today;
    private DateTime SelectedDate
    {
        get => _selectedDate;
        set
        {
            if (_selectedDate == value) return;
            _selectedDate = value;
            UpdateHoursForSelectedDate();
        }
    }

    private string[] GroupResources { get; set; } = new[] { "Mechanics" };

    private List<Mechanic> Mechanics { get; set; } = new();
    private HashSet<int> VisibleMechanicIds { get; set; } = new();
    private List<Mechanic> FilteredMechanics { get; set; } = new();

    private List<AppointmentVM> Appointments { get; set; } = new();
    private List<AppointmentVM> FilteredAppointments { get; set; } = new();
    private bool IsCancelDialogVisible;
    private int? CancelBookingId;

    private string StoreName { get; set; } = "";
    private bool StoreMissing { get; set; }
    private string StoreMissingMessage { get; set; } = "Store not found.";
    private UserAccessScope _userAccess = UserAccessScope.AllowAll();
    private string StartHourText { get; set; } = "09:00";
    private string EndHourText { get; set; } = "17:30";

    // Allow-once flow
    private bool IsOverbookDialogVisible;
    private string OverbookMessage = "";

    private bool BypassLimitOnce;
    private AppointmentVM? PendingAppointment;
    private ActionType? PendingActionType;

#if false
    private bool IsJobCardDialogVisible;
    private int? JobCardBookingId;
    private BookingJobCard? JobCardEditor;
    private string JobCardMessage = "";
    private bool IsJobCardAmendMode;
    private bool IsJobCardOverrunDialogVisible;
    private string JobCardOverrunMessage = "";

    private string JobCardServiceFilter = "";
    private readonly HashSet<string> JobCardExpandedGroups = new(StringComparer.OrdinalIgnoreCase);
    private string JobCardAdditionalServiceFilter = "";
    private readonly HashSet<string> JobCardExpandedAdditionalGroups = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> ExpandedPackageChecklistRows = new(StringComparer.OrdinalIgnoreCase);

    private int JobCardOriginalMinutes;
    private decimal JobCardOriginalTotalPrice;
    private string JobCardOriginalServiceSnapshot = "";
    private string JobCardOriginalServiceSummary = "";
    private List<JobCardServiceItem> JobCardOriginalServices = new();

    private string CustomServiceName = "";
    private int CustomServiceMinutes = 30;
    private decimal CustomServicePrice;

    private string PartSearch = "";
    private List<PartLookupItem> FilteredPartCatalog => SearchParts(PartSearch);

    private static readonly List<PartLookupItem> LocalPartCatalog = new()
    {
        new PartLookupItem("P-CHAIN-11", "11 speed chain", 28.50m),
        new PartLookupItem("P-PAD-DISC", "Disc brake pad set", 14.95m),
        new PartLookupItem("P-TYRE-700", "700c all weather tyre", 32.00m),
        new PartLookupItem("P-TUBE-700", "700c inner tube", 6.50m),
        new PartLookupItem("P-CABLE-GEAR", "Gear cable kit", 11.20m),
        new PartLookupItem("P-CABLE-BRAKE", "Brake cable kit", 10.80m),
        new PartLookupItem("P-BB-SEALED", "Sealed bottom bracket", 24.00m),
        new PartLookupItem("P-CASS-11", "11 speed cassette", 56.00m)
    };

    protected override async Task OnParametersSetAsync()
    {
        await Data.EnsureInitializedAsync();
        await Catalog.EnsureInitializedAsync();
        _userAccess = await UserAccess.GetCurrentAsync();

        var store = Data.Stores.FirstOrDefault(s => s.Id == StoreId);
        if (store is null)
        {
            SetStoreUnavailable("Store not found.");
            return;
        }

        if (!_userAccess.CanAccessStore(StoreId))
        {
            SetStoreUnavailable("You do not have access to this store schedule.");
            return;
        }

        StoreMissing = false;
        StoreMissingMessage = "";
        StoreName = store.Name;

        UpdateHoursForSelectedDate();

        Mechanics = Data.Mechanics
            .Where(m => m.StoreId == StoreId && _userAccess.CanAccessMechanic(m))
            .ToList();
        VisibleMechanicIds = Mechanics.Select(m => m.Id).ToHashSet();
        ReloadAppointmentsFromBookings();
    }

    private void SetStoreUnavailable(string message)
    {
        StoreMissing = true;
        StoreMissingMessage = message;
        StoreName = "";
        Mechanics = new List<Mechanic>();
        VisibleMechanicIds.Clear();
        Appointments = new List<AppointmentVM>();
        FilteredMechanics = new List<Mechanic>();
        FilteredAppointments = new List<AppointmentVM>();
    }

    private string JobCardDialogTitle
    {
        get
        {
            if (!JobCardBookingId.HasValue)
                return "Job Card";

            var booking = Data.Bookings.FirstOrDefault(b => b.Id == JobCardBookingId.Value);
            if (booking is null)
                return $"Job Card #{JobCardBookingId.Value}";

            var customer = BuildCustomerName(booking);
            return $"Job Card #{booking.Id} - {customer}";
        }
    }

    private string GetJobCardActionLabel(int bookingId)
    {
        var booking = Data.Bookings.FirstOrDefault(b => b.Id == bookingId);
        if (booking?.JobCard is null)
            return "Start Job";
        return "Open Job Card";
    }

    private async Task OpenJobCard(int bookingId)
    {
        var booking = Data.Bookings.FirstOrDefault(b => b.Id == bookingId && b.StoreId == StoreId);
        if (booking is null)
            return;

        var created = false;
        if (booking.JobCard is null)
        {
            booking.JobCard = BuildInitialJobCard(booking);
            created = true;

            if (Data.Statuses.Any(s => s.Name.Equals("In Progress", StringComparison.OrdinalIgnoreCase)))
            {
                booking.StatusName = "In Progress";
                booking.JobCard.StatusName = "In Progress";
            }

            await Data.UpdateBookingAsync(booking);
            ReloadAppointmentsFromBookings();
            _ = ScheduleRef?.RefreshEventsAsync();
        }

        JobCardBookingId = bookingId;
        JobCardEditor = CloneJobCard(booking.JobCard ?? BuildInitialJobCard(booking));
        if (JobCardEditor.AssignedMechanicId == 0)
            JobCardEditor.AssignedMechanicId = booking.MechanicId;

        NormalizeJobCardServiceRules();

        JobCardOriginalMinutes = GetJobCardEstimatedMinutes(JobCardEditor);
        if (JobCardOriginalMinutes <= 0)
            JobCardOriginalMinutes = GetBookingDurationMinutes(booking);

        JobCardOriginalTotalPrice = GetJobCardServicesTotal(JobCardEditor);
        if (JobCardOriginalTotalPrice <= 0)
            JobCardOriginalTotalPrice = Math.Max(0, booking.TotalPriceIncVat);
        JobCardOriginalServiceSnapshot = BuildServiceAmendmentSnapshot(JobCardEditor.Services);
        JobCardOriginalServiceSummary = DescribeServicesForNote(JobCardEditor.Services);
        JobCardOriginalServices = CloneServiceItems(JobCardEditor.Services);

        JobCardMessage = created ? "Job card created. Track progress as work is completed." : "";
        IsJobCardAmendMode = false;
        JobCardServiceFilter = "";
        JobCardAdditionalServiceFilter = "";
        JobCardExpandedGroups.Clear();
        JobCardExpandedAdditionalGroups.Clear();
        ExpandedPackageChecklistRows.Clear();
        IsJobCardOverrunDialogVisible = false;
        JobCardOverrunMessage = "";
        CustomServiceName = "";
        CustomServiceMinutes = 30;
        CustomServicePrice = 0;
        PartSearch = "";

        IsJobCardDialogVisible = true;

        if (ScheduleRef is not null)
            await ScheduleRef.CloseQuickInfoPopupAsync();
    }

    private void CloseJobCard()
    {
        IsJobCardDialogVisible = false;
        JobCardBookingId = null;
        JobCardEditor = null;
        JobCardMessage = "";
        IsJobCardAmendMode = false;
        IsJobCardOverrunDialogVisible = false;
        JobCardOverrunMessage = "";
        JobCardServiceFilter = "";
        JobCardAdditionalServiceFilter = "";
        JobCardExpandedGroups.Clear();
        JobCardExpandedAdditionalGroups.Clear();
        ExpandedPackageChecklistRows.Clear();
        JobCardOriginalMinutes = 0;
        JobCardOriginalTotalPrice = 0m;
        JobCardOriginalServiceSnapshot = "";
        JobCardOriginalServiceSummary = "";
        JobCardOriginalServices = new List<JobCardServiceItem>();
        CustomServiceName = "";
        PartSearch = "";
    }

    private BookingJobCard BuildInitialJobCard(Booking booking)
    {
        var card = new BookingJobCard
        {
            StartedAtUtc = DateTime.UtcNow,
            LastUpdatedUtc = DateTime.UtcNow,
            AssignedMechanicId = booking.MechanicId,
            StatusName = string.IsNullOrWhiteSpace(booking.StatusName) ? "Scheduled" : booking.StatusName.Trim(),
            CustomerNotes = (booking.Notes ?? "").Trim(),
            CommunicationDraft = $"Update on your booking ({booking.Title})."
        };

        var selectedJobIds = ResolveBookingJobIds(booking);

        var servicePackageId = ResolveServicePackageId(booking);

        foreach (var jobId in selectedJobIds.Distinct(StringComparer.OrdinalIgnoreCase))
        {
            var job = Catalog.Jobs.FirstOrDefault(j => j.Id.Equals(jobId, StringComparison.OrdinalIgnoreCase));
            if (job is null)
                continue;

            var packageContext = Catalog.IsServicePackage(job.Id) ? null : servicePackageId;
            var (mins, price, _) = Catalog.PriceAndTime(job.Id, packageContext);
            var serviceItem = new JobCardServiceItem
            {
                JobId = job.Id,
                Name = job.Name,
                Description = (job.Description ?? "").Trim(),
                EstimatedMinutes = mins,
                EstimatedPriceIncVat = price
            };
            card.Services.Add(serviceItem);
            if (Catalog.IsServicePackage(job.Id))
                AppendPackageChecklistItems(card, serviceItem);
        }

        if (card.Services.Count == 0)
        {
            card.Services.Add(new JobCardServiceItem
            {
                Name = string.IsNullOrWhiteSpace(booking.Title) ? "Workshop service" : booking.Title.Trim(),
                EstimatedMinutes = Math.Max(0, booking.TotalMinutes),
                EstimatedPriceIncVat = Math.Max(0, booking.TotalPriceIncVat)
            });
        }

        return card;
    }

