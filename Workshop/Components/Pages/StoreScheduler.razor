@rendermode InteractiveServer
@page "/store/{StoreId:int}"
@attribute [Authorize]
@using Syncfusion.Blazor.Schedule
@using Syncfusion.Blazor.Popups
@using Microsoft.JSInterop
@using Workshop.Models
@using Workshop.Services
@inject WorkshopData Data
@inject SchedulingService Scheduler
@inject JobCatalogService Catalog
@inject IJSRuntime JS
@inject ILogger<StoreScheduler> Logger
@inject IEmailSender EmailSender
@inject UserAccessService UserAccess

<style>
.e-schedule .e-appointment {
    position: relative;
    overflow: hidden;
}

.e-schedule .e-appointment.timeoff-block {
    background: repeating-linear-gradient(
        135deg,
        rgba(71, 85, 105, 0.95) 0px,
        rgba(71, 85, 105, 0.95) 8px,
        rgba(241, 245, 249, 0.35) 8px,
        rgba(241, 245, 249, 0.35) 14px
    ) !important;
    border-color: #334155 !important;
    color: #fff !important;
}

.e-schedule .e-appointment.timeoff-block::after {
    display: none;
}

.e-schedule .e-appointment.timeoff-reason-holiday {
    background: repeating-linear-gradient(
        135deg,
        rgba(37, 99, 235, 0.95) 0px,
        rgba(37, 99, 235, 0.95) 8px,
        rgba(146, 177, 245, 0.95) 8px,
        rgba(146, 177, 245, 0.95) 14px
    ) !important;
    border-color: #1d4ed8 !important;
}

.e-schedule .e-appointment.timeoff-reason-illness {
    background: repeating-linear-gradient(
        135deg,
        rgba(185, 28, 28, 0.95) 0px,
        rgba(185, 28, 28, 0.95) 8px,
        rgba(220, 141, 141, 0.95) 8px,
        rgba(220, 141, 141, 0.95) 14px
    ) !important;
    border-color: #991b1b !important;
}

.e-schedule .e-appointment.timeoff-reason-training {
    background: repeating-linear-gradient(
        135deg,
        rgba(124, 58, 237, 0.95) 0px,
        rgba(124, 58, 237, 0.95) 8px,
        rgba(190, 156, 246, 0.95) 8px,
        rgba(190, 156, 246, 0.95) 14px
    ) !important;
    border-color: #6d28d9 !important;
}

.e-schedule .e-appointment.timeoff-reason-shop-floor {
    background: repeating-linear-gradient(
        135deg,
        rgba(217, 119, 6, 0.95) 0px,
        rgba(217, 119, 6, 0.95) 8px,
        rgba(236, 187, 131, 0.95) 8px,
        rgba(236, 187, 131, 0.95) 14px
    ) !important;
    border-color: #b45309 !important;
}

.e-schedule .e-appointment.timeoff-reason-other {
    background: repeating-linear-gradient(
        135deg,
        rgba(15, 118, 110, 0.95) 0px,
        rgba(15, 118, 110, 0.95) 8px,
        rgba(135, 186, 183, 0.95) 8px,
        rgba(135, 186, 183, 0.95) 14px
    ) !important;
    border-color: #0f766e !important;
}

.schedule-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 0 10px 0;
    gap: 16px;
}

.schedule-title {
    margin: 0;
}

.schedule-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
    margin: 0;
}

.mechanic-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 999px;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    font-size: 12px;
    font-weight: 600;
    color: #111827;
}

.mechanic-toggle input {
    margin: 0;
}

    .e-schedule .e-appointment::after {
        content: "";
        position: absolute;
        right: 4px;
        top: 4px;
        width: 20px;
        height: 20px;
        border-radius: 999px;
        background: transparent;
        border: 2px solid rgba(255,255,255,0.9);
        box-sizing: border-box;
    }

    @foreach (var color in GetAllColors())
    {
        <text>
        .e-schedule .e-appointment.job-color-@StoreSchedulerColorService.SanitizeColor(color) {
            background: @color !important;
            border-color: @color !important;
            color: #fff !important;
        }
        .e-schedule .e-appointment.status-color-@StoreSchedulerColorService.SanitizeColor(color)::after {
            background: @color !important;
        }
        </text>
    }

    .status-row {
        display: grid;
        grid-template-columns: 20px 220px 1fr;
        align-items: center;
        gap: 5px;
        padding: 4px 0;
        cursor: grab;
        user-select: none;
    }

    .status-row.dragging {
        opacity: 0.6;
    }

    .status-row-over {
        background: rgba(59, 130, 246, 0.08);
        border-radius: 4px;
    }

    .drag-handle {
        cursor: grab;
        color: #6b7280;
        user-select: none;
        font-size: 18px;
        line-height: 1;
    }

    .status-name {
        width: 100%;
        padding: 4px;
        box-sizing: border-box;
    }

    .status-color {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .status-hex {
        width: 90px;
        padding: 4px;
        box-sizing: border-box;
    }

    .job-card-shell {
        max-height: 78vh;
        overflow-y: auto;
        padding-right: 4px;
    }

    .job-card-grid {
        display: grid;
        gap: 14px;
    }

    .job-card-top {
        display: grid;
        grid-template-columns: repeat(3, minmax(180px, 1fr));
        gap: 10px;
        align-items: end;
    }

    .job-card-top label {
        display: grid;
        gap: 4px;
        font-size: 12px;
        color: #4b5563;
    }

    .job-card-top input,
    .job-card-top select,
    .job-card-parts input,
    .job-card-parts select,
    .job-card-notes textarea,
    .job-card-comms textarea {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        padding: 6px 8px;
        box-sizing: border-box;
        font-size: 13px;
    }

    .job-card-progress-summary {
        display: grid;
        gap: 6px;
        padding: 0;
        border: none;
        border-radius: 0;
        background: transparent;
        align-self: stretch;
    }

    .job-card-progress-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        color: #1f2937;
        font-weight: 600;
    }

    .job-card-progress-track {
        width: 100%;
        height: 10px;
        border-radius: 999px;
        background: #e5e7eb;
        overflow: hidden;
    }

    .job-card-progress-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #2563eb, #0ea5e9);
        transition: width 160ms ease;
    }

    .job-card-progress-meta {
        font-size: 12px;
        color: #4b5563;
    }

    .job-card-section {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 12px;
        display: grid;
        gap: 10px;
        background: #fafafa;
    }

    .job-card-section h5 {
        margin: 0;
        font-size: 15px;
        font-weight: 700;
    }

    .job-card-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .job-card-section-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .job-card-pickers {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .job-picker {
        border: 1px solid #d0d7de;
        border-radius: 8px;
        padding: 10px;
        background: #fff;
        display: grid;
        gap: 8px;
        align-content: start;
    }

    .job-picker-head {
        font-size: 12px;
        font-weight: 700;
        color: #334155;
    }

    .job-filter {
        width: 100%;
        padding: 6px 8px;
        border: 1px solid #c7c7c7;
        border-radius: 4px;
        box-sizing: border-box;
    }

    .job-group {
        border-top: 1px solid #eee;
        padding-top: 6px;
        margin-top: 2px;
    }

    .job-group-header {
        width: 100%;
        text-align: left;
        background: transparent;
        border: none;
        padding: 4px 0;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .group-collapsed .job-group-header {
        opacity: 0.8;
    }

    .job-item {
        display: grid;
        grid-template-columns: 18px 1fr auto;
        align-items: center;
        gap: 8px;
        padding: 4px 0;
        font-size: 13px;
        width: 100%;
        box-sizing: border-box;
    }

    .job-item input[type="checkbox"] {
        margin: 0;
    }

    .job-meta {
        color: #64748b;
        white-space: nowrap;
        font-size: 12px;
    }

    .job-card-services {
        display: grid;
        gap: 8px;
    }

    .job-card-services-list {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
        overflow: hidden;
    }

    .job-card-services-header,
    .job-card-service-row {
        display: grid;
        grid-template-columns: 48px 260px minmax(220px, 1fr) 92px 120px auto;
        gap: 10px;
        align-items: center;
        padding: 8px 10px;
        font-size: 13px;
    }

    .job-card-services-header {
        background: #f8fafc;
        font-size: 11px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .job-card-service-row {
        border-top: 1px solid #f1f5f9;
    }

    .job-card-services-header .col-service,
    .job-card-service-row .col-service {
        padding-left: 4px;
    }

    .job-card-service-row input[type="text"],
    .job-card-service-row input[type="number"] {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        padding: 5px 7px;
        box-sizing: border-box;
        font-size: 13px;
    }

    .job-card-service-name {
        font-weight: 600;
        color: #0f172a;
        line-height: 1.25;
    }

    .job-card-service-name.clickable {
        cursor: pointer;
    }

    .job-card-service-name-wrap {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
    }

    .job-card-expand-btn {
        border: none;
        background: transparent;
        color: #334155;
        width: 20px;
        height: 20px;
        border-radius: 4px;
        padding: 0;
        line-height: 1;
        cursor: pointer;
    }

    .job-card-expand-btn:hover {
        background: #e2e8f0;
    }

    .job-card-checklist-row {
        background: #fcfdff;
    }

    .job-card-checklist-row .col-service {
        padding-left: 24px;
    }

    .job-card-checklist-row .job-card-service-name {
        font-weight: 500;
        color: #334155;
    }

    .job-card-service-value {
        color: #0f172a;
    }

    .job-card-services-total,
    .job-card-services-original {
        display: grid;
        grid-template-columns: 48px 260px minmax(220px, 1fr) 92px 120px auto;
        gap: 10px;
        align-items: center;
        padding: 8px 10px;
        font-size: 13px;
    }

    .job-card-services-total {
        border-top: 1px solid #e5e7eb;
        font-weight: 700;
        background: #f8fafc;
    }

    .job-card-services-original {
        border-top: 1px dashed #dbe5f5;
        color: #334155;
        background: #fcfdff;
        font-size: 12px;
    }

    .job-card-amend-panel {
        display: grid;
        gap: 10px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 10px;
        background: #fff;
    }

    .job-card-service-row .service-tag {
        font-size: 12px;
        color: #334155;
        overflow-wrap: anywhere;
    }

    .job-card-add-manual {
        display: grid;
        grid-template-columns: 1fr 110px 120px auto;
        gap: 8px;
        align-items: center;
    }

    .job-card-manual-wrap {
        display: grid;
        gap: 6px;
    }

    .job-card-manual-title {
        font-size: 12px;
        font-weight: 700;
        color: #334155;
    }

    .job-card-manual-header {
        display: grid;
        grid-template-columns: 1fr 110px 120px auto;
        gap: 8px;
        align-items: center;
        font-size: 11px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .job-card-manual-list {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
        overflow: hidden;
    }

    .job-card-manual-list .job-card-manual-header {
        background: #f8fafc;
        padding: 8px 10px;
        border-bottom: 1px solid #eef2f7;
        gap: 10px;
    }

    .job-card-manual-list .job-card-add-manual {
        padding: 8px 10px;
        gap: 10px;
    }

    .job-card-parts {
        display: grid;
        gap: 8px;
    }

    .job-card-add {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
        align-items: center;
    }

    .job-card-part-row {
        display: grid;
        grid-template-columns: 1fr 110px 74px 96px 72px;
        gap: 8px;
        align-items: center;
    }

    .job-card-lookup-results {
        display: grid;
        gap: 6px;
        max-height: 120px;
        overflow: auto;
    }

    .job-card-lookup-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
        padding: 6px 8px;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        background: #fff;
        font-size: 12px;
    }

    .job-card-notes {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .job-card-notes label,
    .job-card-comms label {
        font-size: 12px;
        color: #4b5563;
        display: grid;
        gap: 4px;
    }

    .job-card-comms {
        display: grid;
        gap: 8px;
    }

    .job-card-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 8px;
        align-items: center;
    }

    .job-card-message {
        color: #065f46;
        font-size: 12px;
    }

    .job-card-warning {
        color: #92400e;
        font-size: 12px;
    }

    .job-card-overrun-message {
        white-space: pre-line;
        font-size: 13px;
        color: #1f2937;
    }

    .job-card-log {
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        background: #fff;
        max-height: 110px;
        overflow: auto;
        padding: 6px;
        display: grid;
        gap: 6px;
        font-size: 12px;
    }

    @@media (max-width: 1100px) {
        .job-card-top {
            grid-template-columns: 1fr 1fr;
        }

        .job-card-pickers {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 900px) {
        .job-card-services-header,
        .job-card-service-row,
        .job-card-services-total,
        .job-card-services-original {
            grid-template-columns: 36px 1fr minmax(90px, 0.7fr) 80px 96px auto;
        }

        .job-card-add-manual {
            grid-template-columns: 1fr;
        }

        .job-card-manual-header {
            grid-template-columns: 1fr;
        }

        .job-card-part-row {
            grid-template-columns: 1fr 90px 70px 90px 58px;
        }

        .job-card-notes {
            grid-template-columns: 1fr;
        }
    }
</style>

@if (StoreMissing)
{
    <div class="alert alert-warning" style="margin: 16px 0;">
        @StoreMissingMessage
    </div>
}
else
{
    <div class="schedule-header">
        <h3 class="schedule-title">@StoreName</h3>
        <div class="schedule-controls">
            @foreach (var mech in Mechanics.OrderBy(m => m.Name))
            {
                var isChecked = VisibleMechanicIds.Contains(mech.Id);
                <label class="mechanic-toggle">
                    <input type="checkbox" checked="@isChecked" @onchange="(e) => ToggleMechanic(mech.Id, e)" />
                    <span>@mech.Name</span>
                </label>
            }
        </div>
    </div>

    <SfSchedule @ref="ScheduleRef"
            TValue="AppointmentVM"
            Height="800px"
                Width="100%"
                StartHour="@StartHourText"
            EndHour="@EndHourText"
            AllowDragAndDrop="true"
            AllowResizing="true"
            @bind-SelectedDate="SelectedDate">

    <ScheduleEvents TValue="AppointmentVM" OnActionBegin="OnActionBegin"></ScheduleEvents>

    <ScheduleGroup Resources="@GroupResources"></ScheduleGroup>

    <ScheduleResources>
        <ScheduleResource TValue="int" TItem="Mechanic"
                           DataSource="@FilteredMechanics"
                           Field="MechanicId"
                           Title="Mechanic"
                           Name="Mechanics"
                           TextField="Name"
                           IdField="Id">
        </ScheduleResource>
    </ScheduleResources>

    <ScheduleViews>
        <ScheduleView Option="View.Day"></ScheduleView>
        <ScheduleView Option="View.Week"></ScheduleView>
        <ScheduleView Option="View.Month"></ScheduleView>
    </ScheduleViews>

    <ScheduleEventSettings DataSource="@FilteredAppointments">
        <ScheduleField CssClass="CategoryColor"></ScheduleField>
    </ScheduleEventSettings>

    <ScheduleQuickInfoTemplates TemplateType="TemplateType.Event">
        <ContentTemplate Context="context">
            @if (context is AppointmentVM appt)
            {
                if (appt.IsTimeOff)
                {
                    <div style="min-width: 280px;">
                        <div style="font-size: 12px; margin-bottom: 8px;"><b>Blocked time</b></div>
                        <div style="font-size: 12px; margin-bottom: 4px;"><b>Mechanic:</b> @Mechanics.FirstOrDefault(m => m.Id == appt.MechanicId)?.Name</div>
                        <div style="font-size: 12px; margin-bottom: 4px;"><b>Reason:</b> @appt.TimeOffReason</div>
                        <div style="font-size: 12px; margin-bottom: 6px;"><b>Notes:</b> @appt.Notes</div>
                        <div style="font-size: 12px;">
                            <b>Date:</b> @($"{appt.StartTime:dd/MM/yyyy} {appt.StartTime:H:mm} - {appt.EndTime:H:mm}")
                        </div>
                    </div>
                }
                else
                {
                <div style="min-width: 280px;">
                    <div style="font-size: 12px; margin-bottom: 4px;"><b>Customer Name:</b> @appt.CustomerName</div>
                    <div style="font-size: 12px; margin-bottom: 4px;"><b>Phone Number:</b> @appt.CustomerPhone</div>
                    <div style="font-size: 12px; margin-bottom: 8px;"><b>Bike Details:</b> @appt.BikeDetails</div>
                    <div style="font-size: 12px; margin-bottom: 6px;"><b>Service:</b> @appt.Subject</div>
                    @if (appt.ServiceLines.Count > 0)
                    {
                        <div style="font-size: 12px; margin-bottom: 6px; display: grid; gap: 2px;">
                            @foreach (var line in appt.ServiceLines)
                            {
                                <div>@line</div>
                            }
                        </div>
                    }
                    <div style="font-size: 12px; margin-bottom: 4px;"><b>Notes:</b> @appt.Notes</div>
                    <div style="font-size: 12px; margin-bottom: 10px;">
                        <b>Date:</b> @($"{appt.StartTime:dd/MM/yyyy} {appt.StartTime:H:mm} - {appt.EndTime:H:mm}")
                    </div>

                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 12px; color:#666;">Status</span>
                        <select value="@appt.StatusName" @onchange="e => ChangeStatus(appt.Id, e)">
                            @foreach (var status in Data.Statuses)
                            {
                                <option value="@status.Name">@status.Name</option>
                            }
                        </select>
                        <button class="e-btn e-flat" type="button" @onclick="OpenStatusEditor">Add/Edit</button>
                    </div>
                </div>
                }
            }
        </ContentTemplate>
        <FooterTemplate Context="context">
            @if (context is AppointmentVM appt)
            {
                @if (appt.IsTimeOff)
                {
                    <div style="display:flex; justify-content:flex-end; gap:12px; align-items:center;">
                        <span style="font-size:12px; color:#475569;">Manage in Book Holiday</span>
                    </div>
                }
                else
                {
                    <div style="display:flex; justify-content:flex-end; gap:12px; align-items:center;">
                        <button class="e-btn e-flat" type="button" @onclick="() => OpenJobCard(appt.Id)">@GetJobCardActionLabel(appt.Id)</button>
                        <button class="e-btn e-primary" type="button" @onclick="() => OpenEdit(appt)">Edit</button>
                        <button class="e-btn e-flat" style="color:#dc2626;" type="button" @onclick="() => OpenCancelDialog(appt.Id)">Cancel</button>
                    </div>
                }
            }
        </FooterTemplate>
    </ScheduleQuickInfoTemplates>
        </SfSchedule>
    }

<SfDialog Width="520px"
          IsModal="true"
          ShowCloseIcon="true"
          @bind-Visible="IsStatusDialogVisible"
          Header="Manage Statuses">
    <DialogTemplates>
        <Content>
            <div style="display: grid; gap: 10px;">
                @if (!string.IsNullOrWhiteSpace(StatusEditorMessage))
                {
                    <div style="color:#dc3545;">@StatusEditorMessage</div>
                }

                <div style="font-weight: 600;">Existing statuses</div>
                <div id="status-editor-list" @ref="StatusListRef">
                @for (var i = 0; i < StatusEditorItems.Count; i++)
                {
                    var itemIndex = i;
                    var item = StatusEditorItems[i];
                    <div class="status-row"
                         data-index="@i"
                         draggable="true">
                        <span class="drag-handle" aria-label="Drag to reorder">≡</span>
                        <input type="text" @bind="item.Name" class="status-name" />
                        <div class="status-color">
                            <input type="color" @bind="item.ColorHex" />
                            <input type="text" @bind="item.ColorHex" class="status-hex" placeholder="#RRGGBB" />
                            <button class="e-btn e-flat"
                                    style="color:#dc3545;"
                                    type="button"
                                    @onclick="() => RemoveStatusEditorItem(itemIndex)">Delete</button>
                        </div>
                    </div>
                }
                </div>

                <div style="margin-top: 6px; font-weight: 600;">Add new status</div>
                <div class="status-row">
                    <span class="drag-handle" style="visibility:hidden;">≡</span>
                    <input type="text" @bind="NewStatusName" class="status-name" placeholder="Status name" />
                    <div class="status-color">
                        <input type="color" @bind="NewStatusColor" />
                        <input type="text" @bind="NewStatusColor" class="status-hex" placeholder="#RRGGBB" />
